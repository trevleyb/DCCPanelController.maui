<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.Components.Symbols"
             xmlns:symbols="clr-namespace:DCCPanelController.Components.Symbols"
             xmlns:symbols1="clr-namespace:DCCPanelController.Components.Symbols"
             x:DataType="symbols1:SymbolViewModel"
             x:Class="DCCPanelController.Components.Symbols.SymbolView">
    
    
    <!-- HeightRequest="50" WidthRequest="50" --> 
    <ContentView.Content>
        <Grid HeightRequest="50" WidthRequest="50" Margin="5,5,5,5"> 
        <Border 
                Style="{StaticResource CardView}"
                BackgroundColor="{StaticResource Transparent}"
                Margin="5,5,5,5" 
                Padding="5,5,5,5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10,10,10,10"/>
            </Border.StrokeShape>
            <Image Source="{Binding Image}"
                   HorizontalOptions="CenterAndExpand"
                   VerticalOptions="CenterAndExpand"/>
        </Border>
            </Grid>
    </ContentView.Content>
    
</ContentView>