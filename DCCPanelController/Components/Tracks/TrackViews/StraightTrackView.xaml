<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.Components.Tracks"
             xmlns:tracks="clr-namespace:DCCPanelController.Components.Tracks"
             x:Class="DCCPanelController.Components.Tracks.Views.StraightTrackView"
             x:DataType="tracks:ITrackViewModel">
    
    <ContentView.Content>
            <Image Source="straight.png"
                   BackgroundColor="{StaticResource Transparent}"
                   Rotation="{Binding Track.Rotation}"
                   HorizontalOptions="CenterAndExpand"
                   VerticalOptions="CenterAndExpand"/>
    </ContentView.Content>
    
</ContentView>

