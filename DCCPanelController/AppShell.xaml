<?xml version="1.0" encoding="utf-8"?>

<Shell
    ForegroundColor="WhiteSmoke"
    BackgroundColor="{StaticResource Primary}"
    x:DataType="services:AppState"
    TabBarBackgroundColor="{StaticResource Primary}"
    TabBarTitleColor="White"
    TabBarForegroundColor="White"
    TabBarUnselectedColor="Black"
    PresentationMode="Animated"
    FlyoutBehavior="Disabled"
    Title="DCC Panel Controller"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.AppShell"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:DCCPanelController.Services"
    xmlns:dccPanelController="clr-namespace:DCCPanelController"
    xmlns:views="clr-namespace:DCCPanelController.Views">

    <FlyoutItem FlyoutDisplayOptions="AsSingleItem">
        <!-- <Tab Icon="control.png" -->
        <!--      Title="Test"> -->
        <!--     <ShellContent ContentTemplate="{DataTemplate view:TestPage}"/> -->
        <!-- </Tab> -->

        <Tab Icon="control.png"
             Title="Operate"
             IsEnabled="{Binding Source={x:Static services:AppState.Instance}, Path=IsNavigationAllowed}">
            <ShellContent ContentTemplate="{DataTemplate views:OperatePage}"/>
        </Tab>
        
        <Tab
            Icon="panels.png"
            Title="Panel Editor"
            IsEnabled="{Binding Source={x:Static services:AppState.Instance}, Path=IsNavigationAllowed}">
            <ShellContent ContentTemplate="{DataTemplate views:PanelViewer}"/>
        </Tab>
        
        <Tab Title="Tables" Icon="tables.png"
             IsEnabled="{Binding Source={x:Static services:AppState.Instance},Path=IsNavigationAllowed}">
            <ShellContent
                ContentTemplate="{DataTemplate views:TurnoutsPage}"
                Title="Turnouts"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:RoutesPage}"
                Title="Routes"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:BlocksPage}"
                Title="Blocks"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:SensorsPage}"
                Title="Sensors"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:LightsPage}"
                Title="Lights"/>
        </Tab>
        
        <Tab Title="Settings" Icon="settings.png"
             IsEnabled="{Binding Source={x:Static services:AppState.Instance},Path=IsNavigationAllowed}">
            <ShellContent
                ContentTemplate="{DataTemplate views:SettingsPage}"
                Title="Settings"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:ServerMessagesPage}"
                Title="Server Messages"/>
            <ShellContent
                ContentTemplate="{DataTemplate views:HelpPage}"
                Title="Help"/>
        </Tab>
    </FlyoutItem>
</Shell>