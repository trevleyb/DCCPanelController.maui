<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:DCCPanelController.Converters"
             xmlns:viewModel="clr-namespace:DCCPanelController.Symbols"
             xmlns:symbols="clr-namespace:DCCPanelController.Symbols"
             x:DataType="symbols:SymbolViewModel"
             x:Class="DCCPanelController.Symbols.SymbolView">
    
    <ContentView.Content>
        <Border HeightRequest="50" WidthRequest="50"
                Style="{StaticResource CardView}"
                BackgroundColor="{StaticResource Transparent}"
                Margin="5,5,5,5" Padding="5,5,5,5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10,10,10,10"/>
            </Border.StrokeShape>
            <Image Source="{Binding Image}"
                   HorizontalOptions="CenterAndExpand"
                   VerticalOptions="CenterAndExpand"/>
        </Border>
    </ContentView.Content>
    
</ContentView>