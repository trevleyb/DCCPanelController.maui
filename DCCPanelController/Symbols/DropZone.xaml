<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
             x:DataType="viewModel:PanelEditorViewModel"
             x:Class="DCCPanelController.Symbols.DropZone">
    
    <ContentView.Content>
        <Border>
            <Border.Triggers>
                <DataTrigger Binding="{Binding IsDropZoneOccupied}" TargetType="Border" Value="true">
                    <Setter Property="Style" Value="{StaticResource DropZoneOccupied}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDropZoneOccupied}" TargetType="Border" Value="false">
                    <Setter Property="Style" Value="{StaticResource DropZoneFree}" />
                </DataTrigger>
            </Border.Triggers>
        </Border>
    </ContentView.Content>
</ContentView>