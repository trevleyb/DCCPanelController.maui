<?xml version="1.0" encoding="UTF-8"?>

<Application
    x:Class="DCCPanelController.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <converters:SelectedBorderConverter x:Key="SelectedBorderConverter"/>
            <converters:BoolToIconConverter x:Key="BoolToIcon"/>
            <converters:MultiBoolToIconConverter x:Key="MultiBoolToIcon"/>
            <converters:ConnectionIconConverter x:Key="ConnectionIconConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>