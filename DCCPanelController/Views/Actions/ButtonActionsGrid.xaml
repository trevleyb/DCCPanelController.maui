<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.Views.Actions.ButtonActionsGrid"
    x:DataType="local1:ButtonActionsGridViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:DCCPanelController.Views.Components"
    xmlns:local="clr-namespace:DCCPanelController.Views.Actions"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:actions="clr-namespace:DCCPanelController.Models.DataModel.Entities.Actions"
    xmlns:local1="clr-namespace:DCCPanelController.Views.Actions"
    xmlns:components1="clr-namespace:DCCPanelController.Views.Components">

    <ContentView.Resources>
        <ResourceDictionary/>
    </ContentView.Resources>

    <ContentView.Content>
        <VerticalStackLayout>
            <Grid Margin="5,5,0,0" ColumnDefinitions="120,auto,auto">
                <Label
                    FontAttributes="Bold"
                    Grid.Column="0"
                    HeightRequest="25"
                    Text="Button Actions"
                    TextColor="{StaticResource Primary}"/>
                <ImageButton
                    Aspect="Center"
                    Command="{Binding AddRowCommand}"
                    Grid.Column="1"
                    HeightRequest="25"
                    IsEnabled="{Binding IsAddButtonEnabled}"
                    Margin="0,-5,0,0"
                    Source="plus_circle.png"
                    WidthRequest="25">
                    <ImageButton.Behaviors>
                        <behaviors:IconTintColorBehavior TintColor="{StaticResource Primary}"/>
                    </ImageButton.Behaviors>
                </ImageButton>
                <Label
                    Grid.Column="2"
                    HeightRequest="25"
                    Style="{StaticResource SmallLabel}"
                    Text="{Binding NoDataText}"
                    VerticalOptions="Center"/>
            </Grid>

            <Grid HeightRequest="{Binding ControlHeight, Mode=OneWay}" IsVisible="{Binding IsGridVisible}">
                <ListView
                    HorizontalOptions="Fill"
                    ItemsSource="{Binding ButtonPanelActions}"
                    SelectionMode="None"
                    VerticalOptions="Fill">

                    <ListView.Header>
                        <Grid
                            ColumnDefinitions="3*,4*,4*,1*"
                            ColumnSpacing="2"
                            RowDefinitions="25">
                            <BoxView Background="{StaticResource Primary}" Grid.Column="0"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="1"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="2"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="3"/>

                            <Label
                                FontAttributes="Bold"
                                Grid.Column="0"
                                Text="Button"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                Margin="10,0,0,0"
                                TextColor="{StaticResource White}"/>

                            <components1:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                Margin="2"
                                State="On"/>

                            <components1:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                Margin="2"
                                State="Off"/>

                            <components1:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                Margin="2"
                                State="Closed"/>

                            <components1:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                Margin="2"
                                State="Thrown"/>

                            <Image
                                Grid.Column="3"
                                Margin="2"
                                Source="trash.png">
                                <Image.Behaviors>
                                    <behaviors:IconTintColorBehavior TintColor="Firebrick"/>
                                </Image.Behaviors>
                            </Image>

                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell x:DataType="actions:ButtonAction">
                                <Grid
                                    ColumnDefinitions="3*,4*,4*,1*"
                                    ColumnSpacing="2"
                                    RowDefinitions="25"
                                    VerticalOptions="Center">
                                    <components1:PickerSelector
                                        WidthRequest="150"
                                        Grid.Column="0"
                                        Margin="0,0,0,0"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"
                                        BackgroundColor="Transparent"
                                        TextColor="Black"
                                        TextSize="15"
                                        SelectedValue="{Binding Id, Mode=TwoWay}"
                                        ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type local1:ButtonActionsGridViewModel}},x:DataType=local:ButtonActionsGridViewModel, Path=SelectableItems, Mode=OneWay}"
                                        Placeholder="Select a Button"/>

                                    <components1:ButtonStateControl
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="1"
                                        HorizontalOptions="Start"
                                        Margin="2,0,0,0"
                                        State="{Binding WhenOn, Mode=TwoWay}"
                                        UnknownText="Leave-AsIs"/>

                                    <components1:ButtonStateControl
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="2"
                                        HorizontalOptions="Start"
                                        Margin="2,0,0,0"
                                        State="{Binding WhenOff, Mode=TwoWay}"
                                        UnknownText="Leave-AsIs"/>

                                    <ImageButton
                                        Aspect="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local1:ButtonActionsGridViewModel}}, x:DataType=local:ButtonActionsGridViewModel, Path=RemoveRowCommand}"
                                        CommandParameter="{Binding .}"
                                        Grid.Column="4"
                                        HeightRequest="10"
                                        Margin="2,0,0,0"
                                        Source="minus_circle.png"
                                        VerticalOptions="Center"
                                        WidthRequest="10"/>

                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>