<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net9.0-android;net9.0-ios;net9.0-maccatalyst</TargetFrameworks>
        <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">$(TargetFrameworks);net9.0-windows10.0.19041.0</TargetFrameworks>
        <!-- Uncomment to also build the tizen app. You will need to install tizen by following this: https://github.com/Samsung/Tizen.NET -->
        <!-- <TargetFrameworks>$(TargetFrameworks);net9.0-tizen</TargetFrameworks> -->

        <!-- Note for MacCatalyst:
        The default runtime is maccatalyst-x64, except in Release config, in which case the default is maccatalyst-x64;maccatalyst-arm64.
        When specifying both architectures, use the plural <RuntimeIdentifiers> instead of the singular <RuntimeIdentifier>.
        The Mac App Store will NOT accept apps with ONLY maccatalyst-arm64 indicated;
        either BOTH runtimes must be indicated or ONLY macatalyst-x64. -->
        <!-- For example: <RuntimeIdentifiers>maccatalyst-x64;maccatalyst-arm64</RuntimeIdentifiers> -->

        <OutputType>Exe</OutputType>
        <RootNamespace>DCCPanelController</RootNamespace>
        <UseMaui>true</UseMaui>
        <SingleProject>true</SingleProject>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <MauiEnableXamlCBindingWithSourceCompilation>true</MauiEnableXamlCBindingWithSourceCompilation>
        <MauiStrictXamlCompilation>false</MauiStrictXamlCompilation>

        <!-- Display name -->
        <ApplicationTitle>DCC Panel Controller</ApplicationTitle>

        <!-- App Identifier -->
        <ApplicationId>com.trevleyb.dccpanelcontroller</ApplicationId>

        <!-- Versions -->
        <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
        <ApplicationVersion>1</ApplicationVersion>

        <!-- To develop, package, and publish an app to the Microsoft Store, see: https://aka.ms/MauiTemplateUnpackaged -->
        <WindowsPackageType>None</WindowsPackageType>

        <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
        <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>
        <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
        <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</SupportedOSPlatformVersion>
        <TargetPlatformMinVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</TargetPlatformMinVersion>
        <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tizen'">6.5</SupportedOSPlatformVersion>
        <LangVersion>13</LangVersion>
        <Title>DCC Panel Controller</Title>
        <Authors>Trevor Leybourne</Authors>
        <Company>trevleyb</Company>
        <Product>DCC Panel Controller</Product>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <NoWarn>1701;1702;CS1998;XC0103</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
        <NoWarn>1701;1702;CS1998;XC0103</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <!-- App Icon -->
        <MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#7CC504"/>

        <MauiImage Update="Resources\Images\settings.svg"/>
        <MauiImage Update="Resources\Images\control.svg"/>
        <MauiImage Update="Resources\Images\panels.svg"/>
        <MauiImage Update="Resources\Images\turnouts.svg"/>
        <MauiImage Update="Resources\Images\routes.svg"/>
        <MauiImage Update="Resources\Images\turnout_closed.svg"/>
        <MauiImage Update="Resources\Images\turnout_thrown.svg"/>
        <MauiImage Update="Resources\Images\turnout_unknown.svg"/>
        <MauiImage Update="Resources\Images\route_active.svg"/>
        <MauiImage Update="Resources\Images\route_inactive.svg"/>
        <MauiImage Update="Resources\Images\route_unknown.svg"/>

        <!-- Splash Screen -->
        <MauiSplashScreen Include="Resources\Splash\splash.svg"/>

        <!-- Track Images -->
        <EmbeddedResource Include="Resources\TrackPieces\*.svg"/>

        <!-- Images -->
        <MauiImage Include="Resources\Images\*"/>
        <MauiImage Include="Resources\Icons\*"/>

        <!-- Custom Fonts -->
        <MauiFont Include="Resources\Fonts\*"/>

        <!-- Raw Assets (also remove the "Resources\Raw" prefix) -->
        <MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)"/>
        <None Remove="Resources\AppIcon\appiconfg.svg"/>
        <MauiIcon Include="Resources\AppIcon\appiconfg.svg"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="akgul.Maui.DataGrid" Version="4.0.6" />
        <PackageReference Include="CommunityToolkit.Maui" Version="9.1.1"/>
        <PackageReference Include="CommunityToolkit.Maui.Markup" Version="5.1.0"/>
        <PackageReference Include="CommunityToolkit.Maui.MediaElement" Version="4.1.2"/>
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0-preview3"/>
        <PackageReference Include="Dynamensions.ColorPicker.Maui" Version="1.2.0"/>
        <PackageReference Include="Microsoft.Maui.Controls" Version="9.0.14"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="9.0.0"/>
        <PackageReference Include="OnScreenSizeMarkup.Maui" Version="3.0.18"/>
        <PackageReference Include="Plugin.Maui.Audio" Version="3.0.1"/>
        <PackageReference Include="Svg.Skia" Version="2.0.0.4"/>
        <PackageReference Include="UraniumUI" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Blurs" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Dialogs.CommunityToolkit" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Icons.FontAwesome" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Icons.MaterialSymbols" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Icons.SegoeFluent" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Material" Version="2.11.0" />
        <PackageReference Include="UraniumUI.Validations.DataAnnotations" Version="2.11.0" />
    </ItemGroup>

