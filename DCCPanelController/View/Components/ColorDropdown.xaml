<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:colorPickerControl="clr-namespace:ColorPickerControl"
             x:Class="ColorPickerControl.ColorDropdown" 
             x:DataType="colorPickerControl:ColorDropdown">

    <ContentView.Content>
            <Button Text="{Binding DisplayText}"
                    BackgroundColor="{Binding SelectedColor}"
                    BorderColor="{Binding ContrastColor}"
                    TextColor="{Binding ContrastColor}"
                    CornerRadius="5"
                    Command="{Binding ShowDropdownCommand}" />
    </ContentView.Content>
</ContentView>