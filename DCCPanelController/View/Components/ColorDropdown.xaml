<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:colorPickerControl="clr-namespace:ColorPickerControl"
             x:Class="ColorPickerControl.ColorDropdown" 
             x:DataType="colorPickerControl:ColorDropdown">

    <ContentView.Content>
        <VerticalStackLayout>
            <!-- Button to show the currently selected color -->
            <Button Text="{Binding DisplayText}"
                    BackgroundColor="{Binding SelectedColor}"
                    TextColor="{Binding TextContrastColor}"
                    Command="{Binding ShowDropdownCommand}" />
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>