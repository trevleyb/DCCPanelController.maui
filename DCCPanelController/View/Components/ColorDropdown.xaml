<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ColorPickerControl.ColorDropdown"
    x:DataType="colorPickerControl:ColorDropdown"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:colorPickerControl="clr-namespace:ColorPickerControl"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Content>
        <Button
            BackgroundColor="{Binding SelectedColor}"
            BorderColor="{StaticResource Gray100}"
            BorderWidth="2"
            Command="{Binding ShowDropdownCommand}"
            CornerRadius="5"
            Text="{Binding DisplayText}"
            TextColor="{Binding ContrastColor}" />
    </ContentView.Content>
</ContentView>