<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.View.Components.ColorDropdown"
    x:DataType="colorPickerControl:ColorDropdown"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:colorPickerControl="clr-namespace:DCCPanelController.View.Components">

    <ContentView.Content>
        <Button
            BackgroundColor="{Binding SelectedColor}"
            BorderColor="{StaticResource Gray100}"
            BorderWidth="2"
            Command="{Binding ShowDropdownCommand}"
            CornerRadius="5"
            Text="{Binding DisplayText}"
            TextColor="{Binding ContrastColor}" />
    </ContentView.Content>
</ContentView>