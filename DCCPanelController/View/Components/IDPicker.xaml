<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="DCCPanelController.View.Components.IDPicker"
    x:DataType="components:IDPicker"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <Grid
        HorizontalOptions="Fill"
        Margin="0"
        Padding="0"
        VerticalOptions="Fill"
        HeightRequest="400"
        WidthRequest="388">
        <Border
            Background="White"
            HorizontalOptions="Fill"
            Stroke="{StaticResource Primary}"
            StrokeShape="RoundRectangle 10,10,10,10"
            StrokeThickness="3"
            VerticalOptions="Fill">

            <Grid RowDefinitions="35,*,50">
                <Grid
                    Grid.Row="0"
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="35"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        Margin="10,5,0,5"
                        Style="{StaticResource LargeLabel}"
                        Text="{Binding Prompt}"
                        TextColor="White"
                        VerticalOptions="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <CollectionView
                        HorizontalOptions="Start"
                        ItemsSource="{Binding Items}"
                        Margin="10"
                        SelectedItem="{Binding Item, Mode=TwoWay}"
                        SelectionChanged="OnSelectionChanged"
                        SelectionMode="Single"
                        VerticalOptions="Start">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="system:String">
                                <Grid RowDefinitions="30,3" Padding="1">
                                <Label Margin="2" VerticalOptions="Center" Text="{Binding .}" Grid.Row="0"/>
                                <BoxView Margin="2" Grid.Row="1" Width="1" Color="Gainsboro"></BoxView>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
                <Button Grid.Row="2"
                        Command="{Binding CloseOnSelectedCommand}"
                        HorizontalOptions="Center"
                        Margin="0,10,0,20"
                        Style="{StaticResource ButtonOutline}"
                        Text="Close"
                        WidthRequest="80"/>
            </Grid>
        </Border>
    </Grid>
</toolkit:Popup>