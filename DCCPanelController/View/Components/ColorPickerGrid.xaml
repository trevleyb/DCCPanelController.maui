<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.View.Components.ColorPickerGrid"
    x:DataType="colorPickerControl:ColorPickerGridViewModel"
    BackgroundColor="{StaticResource Primary}"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:colorPickerControl="clr-namespace:DCCPanelController.View.Components"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">

        <Border
            Background="White"
            HorizontalOptions="Fill"
            Stroke="{StaticResource Primary}"
            StrokeShape="RoundRectangle 10,10,10,10"
            StrokeThickness="3"
            VerticalOptions="Fill">

            <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="30, 130 , 30, 70">
                <Grid Grid.Row="0"
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="30"
                    VerticalOptions="Center">
                    <Label
                        Margin="10,0,0,0"
                        Style="{StaticResource MediumLabel}"
                        Text="Select a Color"
                        TextColor="White"
                        VerticalOptions="Center"/>
                </Grid>

                <CollectionView Grid.Row="1"
                                HorizontalOptions="FillAndExpand"
                                ItemsSource="{Binding SelectableColors}"
                                Margin="5"
                                SelectedItem="{Binding SelectedColor, Mode=TwoWay}"
                                SelectionMode="Single"
                                VerticalOptions="FillAndExpand"
                                x:Name="ColorsView"
                                ItemSizingStrategy="MeasureFirstItem">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="12" VerticalItemSpacing="2"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="Color">
                            <Border
                                BackgroundColor="{Binding .}"
                                HeightRequest="25"
                                Stroke="{StaticResource Gray300}"
                                StrokeThickness="2"
                                WidthRequest="25"
                                Margin="1">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup Name="CommonStates">
                                        <VisualState Name="Normal"/>
                                        <VisualState Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="Stroke" Value="Black"/>
                                                <Setter Property="StrokeThickness" Value="3"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,auto,auto,*" Grid.Row="2">
                    <BoxView
                        BackgroundColor="{StaticResource Primary}"
                        Grid.Column="0"
                        HeightRequest="1"
                        HorizontalOptions="Fill"
                        Margin="10,0,10,0"/>

                    <Border
                        BackgroundColor="{Binding SelectedColor}"
                        Grid.Column="1"
                        HeightRequest="20"
                        HorizontalOptions="Fill"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="2"
                        WidthRequest="20"/>

                    <Label
                        FontSize="15"
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Margin="5"
                        Text="{Binding SelectedColorName}"
                        TextColor="{StaticResource Primary}"/>

                    <BoxView
                        BackgroundColor="{StaticResource Primary}"
                        Grid.Column="3"
                        HeightRequest="1"
                        HorizontalOptions="Fill"
                        Margin="10,0,10,0"/>
                </Grid>

                <HorizontalStackLayout HorizontalOptions="Center" Grid.Row="3">
                    <Button
                        Command="{Binding SaveCommand}"
                        HorizontalOptions="Center"
                        Margin="0,10,10,10"
                        Style="{StaticResource ButtonOutline}"
                        Text="Save"
                        WidthRequest="100"/>

                    <Button 
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Center"
                        Margin="10,10,0,10"
                        Style="{StaticResource ButtonOutline}"
                        Text="Close"
                        WidthRequest="100"/>

                </HorizontalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentView>