<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.View.Components.ColorPickerButton"
    x:DataType="colorPickerControl:ColorPickerButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:colorPickerControl="clr-namespace:DCCPanelController.View.Components">

    <ContentView.Content>
        <Button
            BorderColor="{StaticResource Gray100}"
            BorderWidth="2"
            CornerRadius="10"
            Command="{Binding ShowDropdownCommand}"
            BackgroundColor="{Binding SelectedColor}"/>
    </ContentView.Content>
</ContentView>