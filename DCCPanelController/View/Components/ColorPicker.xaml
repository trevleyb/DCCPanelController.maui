<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="DCCPanelController.View.Components.ColorPicker"
    x:DataType="colorPickerControl:ColorPicker"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:DCCPanelController.Helpers"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:colorPicker="clr-namespace:Dynamensions.ColorPicker.Maui;assembly=Dynamensions.ColorPicker.Maui"
    xmlns:colorPickerControl="clr-namespace:DCCPanelController.View.Components">

    <StackLayout HorizontalOptions="Fill" VerticalOptions="Fill">
        <Border Stroke="{StaticResource Primary}"
                StrokeShape="RoundRectangle 10,10,10,10"
                StrokeThickness="3"
                Background="White"
                HorizontalOptions="Center"
                VerticalOptions="Center">

            <StackLayout>
                <Grid ColumnDefinitions="*,auto" HeightRequest="30" VerticalOptions="Center" BackgroundColor="{StaticResource Primary}">
                    <Label TextColor="White"
                           Grid.Column="0" Style="{StaticResource LargeLabel}"
                           Text="Select a Color" VerticalOptions="Center" />
                </Grid>

                <colorPicker:ColorPicker
                    Margin="10"
                    NumberOfColors="32" 
                    Saturation="1" 
                    Brightness="1" 
                    Wrap="Wrap" 
                    IsSorted="False" 
                    IncludeBlack="True" 
                    IncludeWhite="True"
                    IncludeGrey="True"
                    SelectedColor="{Binding Path=SelectedColor, Mode=TwoWay}" />
                
                <Button Margin="0,10,0,10" Text="Close" HorizontalOptions="Center" Style="{StaticResource ButtonOutline}" WidthRequest="80" Clicked="CloseOnSelected"/>
            </StackLayout>
        </Border>
    </StackLayout>
</toolkit:Popup>