<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="DCCPanelController.View.Components.ColorGridDropdown"
    x:DataType="colorPickerControl:ColorGridDropdown"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:colorPickerControl="clr-namespace:DCCPanelController.View.Components"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Content>
        <Button
            BackgroundColor="{Binding SelectedColor}"
            BorderColor="{StaticResource Gray100}"
            BorderWidth="2"
            Command="{Binding ShowDropdownCommand}"
            CornerRadius="10"
            Text="{Binding SelectedColorName}"
            TextColor="{Binding SelectedColorContrast}" />
    </ContentView.Content>
</ContentView>