<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="settings_green.png"
    Title="Settings"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.View.SettingsPage"
    x:DataType="view:SettingsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:interfaces="clr-namespace:DCCClients.Interfaces;assembly=DCCClients"
    xmlns:dccClients="clr-namespace:DCCClients;assembly=DCCClients">

    <ContentPage.Resources>
        <ResourceDictionary/>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="Upload_OnClicked" IconImageSource="upload.png"/>
        <ToolbarItem Clicked="Download_OnClicked" IconImageSource="download.png"/>
    </ContentPage.ToolbarItems>

    <StackLayout>
        <Label
            Text="Server Connection Details:"
            Margin="10,10,20,0"
            Style="{StaticResource LargeLabel}"
            TextColor="{StaticResource Primary}"/>

        <HorizontalStackLayout Margin="20,20,0,0">
            <RadioButton GroupName="ServerType" Content="JMRI Server" IsChecked="{Binding IsJmriServer}"
                         CheckedChanged="JmriServerButton_OnCheckedChanged" x:Name="JmriServerButton"/>
            <RadioButton GroupName="ServerType" Content="WiThrottle Server" IsChecked="{Binding IsWiThrottle}"
                         CheckedChanged="WiThrottleServerButton_OnCheckedChanged" x:Name="WiThrottleServerButton"/>
        </HorizontalStackLayout>

        <VerticalStackLayout Margin="20,0,0,0">
            <VerticalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource SmallLabel}" HorizontalOptions="Start" VerticalOptions="Start"
                       Text="Client Identifier (unique name for this Device)"/>
                <Border
                    WidthRequest="250"
                    HorizontalOptions="Start"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                    <Entry Text="{Binding Name}" Style="{StaticResource PanelEntry}"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Margin="10,10,10,0">
                <Label Style="{StaticResource SmallLabel}"
                       HorizontalOptions="Start" VerticalOptions="Start"
                       Text="Address"/>

                <HorizontalStackLayout HorizontalOptions="Start" Margin="0,-25,0,0">
                    <Border
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource Primary}"
                        HeightRequest="35"
                        WidthRequest="50"
                        Padding="10,0,5,0"
                        Margin="0,5,0,5"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                        <Entry Focused="OnEntryFocused" Style="{StaticResource PanelEntry}"
                               HorizontalTextAlignment="Center" Text="{Binding IpAddress1}">
                            <Entry.Behaviors>
                                <view:EntryValidationBehavior/>
                            </Entry.Behaviors>
                        </Entry>
                    </Border>
                    <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                    <Border
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource Primary}"
                        HeightRequest="35"
                        WidthRequest="50"
                        Padding="10,0,5,0"
                        Margin="0,5,0,5"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                        <Entry
                            Focused="OnEntryFocused" Style="{StaticResource PanelEntry}"
                            HorizontalTextAlignment="Center" Text="{Binding IpAddress2}">
                            <Entry.Behaviors>
                                <view:EntryValidationBehavior/>
                            </Entry.Behaviors>
                        </Entry>
                    </Border>
                    <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                    <Border
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource Primary}"
                        HeightRequest="35"
                        WidthRequest="50"
                        Padding="10,0,5,0"
                        Margin="0,5,0,5"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                        <Entry
                            Focused="OnEntryFocused" Style="{StaticResource PanelEntry}"
                            HorizontalTextAlignment="Center" Text="{Binding IpAddress3}">
                            <Entry.Behaviors>
                                <view:EntryValidationBehavior/>
                            </Entry.Behaviors>
                        </Entry>
                    </Border>
                    <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                    <Border
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource Primary}"
                        HeightRequest="35"
                        WidthRequest="50"
                        Padding="10,0,5,0"
                        Margin="0,5,0,5"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                        <Entry
                            Focused="OnEntryFocused" Style="{StaticResource PanelEntry}"
                            HorizontalTextAlignment="Center" Text="{Binding IpAddress4}">
                            <Entry.Behaviors>
                                <view:EntryValidationBehavior/>
                            </Entry.Behaviors>
                        </Entry>
                    </Border>
                    <Label FontSize="48" HorizontalOptions="Center" Margin="2,2,2,10" Text=":"
                           TextColor="{StaticResource Primary}" VerticalOptions="Center"/>

                    <Border
                        WidthRequest="75"
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource Primary}"
                        HeightRequest="35"
                        Padding="10,0,5,0"
                        Margin="0,5,0,5"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                        <Entry
                            Style="{StaticResource PanelEntry}"
                            Focused="OnEntryFocused"
                            HorizontalTextAlignment="Center"
                            Text="{Binding Port}"/>
                    </Border>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Button
                Command="{Binding ConnectCommand}"
                HorizontalOptions="Center"
                IsEnabled="{Binding IsNotBusy}"
                Margin="10,0,20,20"
                Style="{StaticResource ButtonOutline}"
                Text="{Binding ConnectLabel}"
                WidthRequest="150"/>

        </VerticalStackLayout>
        <BoxView
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="2"
            HorizontalOptions="FillAndExpand"/>

        <Grid RowDefinitions="auto,2,*">
            <ScrollView Grid.Row="0">
                <StackLayout>
                    <Grid ColumnDefinitions="*,150">
                        <Label
                            Grid.Column="0"
                            HorizontalOptions="Start"
                            Style="{StaticResource MediumLabel}"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center">
                            Available Servers :
                        </Label>
                        <Button
                            BackgroundColor="{StaticResource White}"
                            Command="{Binding RefreshServersCommand}"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            ImageSource="refresh_cw.png"
                            Style="{StaticResource SmallLabel}"
                            Text="Refresh"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center"/>
                    </Grid>
                    <BoxView
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="1"
                        HorizontalOptions="FillAndExpand"/>

                    <RefreshView VerticalOptions="Start" MinimumHeightRequest="100"
                                 Command="{Binding RefreshServersCommand}"
                                 IsRefreshing="{Binding IsRefreshing}">
                        <Grid>
                            <ActivityIndicator
                                Color="{StaticResource Primary}"
                                HorizontalOptions="Fill"
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                Margin="0,20,0,0"
                                VerticalOptions="Start"/>

                            <CollectionView ItemsSource="{Binding Servers}" SelectionMode="Single"
                                            SelectedItem="{Binding SelectedServer}">
                                <CollectionView.EmptyView>
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label IsVisible="{Binding IsNotBusy}" HorizontalOptions="Center"
                                               Text="No Servers could be found."/>
                                        <Label IsVisible="{Binding IsNotBusy}" HorizontalOptions="Center"
                                               Text="Use Refresh to search for available servers"/>
                                        <Label IsVisible="{Binding IsBusy}" HorizontalOptions="Center"
                                               Text="Searching for available servers"/>
                                    </StackLayout>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="dccClients:IDccSettings">
                                        <StackLayout>
                                            <Grid ColumnDefinitions="48,*">
                                                <Label
                                                    Grid.Column="0"
                                                    HorizontalOptions="Start"
                                                    Margin="5"
                                                    Text="◉"
                                                    VerticalOptions="Center"
                                                    x:Name="SelectedServerTick"/>
                                                <Label
                                                    Grid.Column="1"
                                                    HorizontalOptions="Start"
                                                    LineBreakMode="NoWrap"
                                                    Margin="0,5,0,5"
                                                    Style="{StaticResource MediumLabel}"
                                                    Text="{Binding Name}"
                                                    VerticalOptions="Center"
                                                    x:Name="SelectedServerText"/>
                                            </Grid>
                                            <BoxView
                                                BackgroundColor="{StaticResource Primary}"
                                                HeightRequest="0.5"
                                                HorizontalOptions="FillAndExpand"/>
                                        </StackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </RefreshView>
                </StackLayout>
            </ScrollView>

            <BoxView
                Grid.Row="1"
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="2"
                HorizontalOptions="FillAndExpand"/>

            <StackLayout Grid.Row="2">
                <Grid ColumnDefinitions="*,150">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Start"
                        Style="{StaticResource MediumLabel}"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                        Server Messages :
                    </Label>
                    <Button
                        BackgroundColor="{StaticResource White}"
                        Command="{Binding ClearMessagesCommand}"
                        Grid.Column="1"
                        HorizontalOptions="End"
                        ImageSource="trash_2.png"
                        Style="{StaticResource SmallLabel}"
                        Text="Clear"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center"/>
                </Grid>
                <BoxView
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="1"
                    HorizontalOptions="FillAndExpand"/>
                <ScrollView VerticalScrollBarVisibility="Always" HorizontalScrollBarVisibility="Always">
                    <CollectionView
                        ItemsSource="{Binding Messages}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        x:Name="MessagesList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="view:SettingsMessage">
                                <HorizontalStackLayout>
                                    <!-- <Label -->
                                    <!--     Style="{StaticResource MediumLabel}" -->
                                    <!--     Text="{Binding TimeStamp}" Margin="0,0,5,0"/> -->
                                    <Label Style="{StaticResource MediumLabel}"
                                           Text="{Binding Message}"/>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </StackLayout>
        </Grid>
    </StackLayout>
</ContentPage>