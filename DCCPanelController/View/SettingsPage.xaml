<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="settings_green.png"
    Title="Settings"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.View.SettingsPage"
    x:DataType="view:SettingsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:discovery="clr-namespace:DCCCommon.Discovery;assembly=DCCCommon"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:services="clr-namespace:DCCPanelController.Services"
    xmlns:helpers="clr-namespace:DCCPanelController.Helpers"
    xmlns:converters="clr-namespace:DCCPanelController.Helpers.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="Upload_OnClicked" IconImageSource="upload.png"/>
        <ToolbarItem Clicked="Download_OnClicked" IconImageSource="download.png"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,70">
        <ScrollView Grid.Row="0">
            <Grid RowDefinitions="auto,auto,*">
                <StackLayout Margin="10,10,10,10" Grid.Row="0">
                    <Label Text="Profile Settings:" Margin="10,10,20,0" Style="{StaticResource LargeLabel}"
                           TextColor="{StaticResource Primary}"/>
                    <StackLayout Margin="10,10,10,10">
                        <HorizontalStackLayout>
                            <Label Text="Profile Name" HorizontalOptions="Start" Style="{StaticResource MediumLabel}"
                                   VerticalOptions="Center" WidthRequest="175"/>
                            <Border
                                WidthRequest="180"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Primary}"
                                Padding="10,0,5,0"
                                Margin="0,5,0,5"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                                <Entry Text="{Binding Profile.ProfileName}" HorizontalOptions="Start"
                                       Style="{StaticResource PanelEntry}"/>
                            </Border>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout>
                            <Label Text="Background Color" HorizontalOptions="Start"
                                   Style="{StaticResource MediumLabel}"
                                   VerticalOptions="Center" WidthRequest="175"/>
                            <components:ColorPickerButton
                                AllowsNoColor="true"
                                HeightRequest="35"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1"
                                SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type view:SettingsViewModel}}, Path=Settings.BackgroundColor, Mode=TwoWay}"
                                VerticalOptions="Center"
                                HorizontalOptions="Start"
                                WidthRequest="180"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Margin="0,10,0,0">
                            <Label Text="Automatically Connect?" HorizontalOptions="Start"
                                   Style="{StaticResource MediumLabel}"
                                   VerticalOptions="Center" WidthRequest="175"/>
                            <Switch IsToggled="{Binding Settings.ConnectOnStartup}"
                                    OnColor="{StaticResource Primary}"
                                    ThumbColor="{StaticResource Gray200}"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Margin="0,10,0,0">
                            <Label Text="Set Turnouts on Connect?" HorizontalOptions="Start"
                                   Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="175"/>
                            <Switch IsToggled="{Binding Settings.SetTurnoutStatesOnStartup}"
                                    OnColor="{StaticResource Primary}"
                                    ThumbColor="{StaticResource Gray200}"/>
                        </HorizontalStackLayout>


                    </StackLayout>

                    <BoxView Margin="10,10,20,10"
                             BackgroundColor="{StaticResource Primary}"
                             HeightRequest="1"
                             HorizontalOptions="FillAndExpand"/>
                </StackLayout>

                <StackLayout Margin="20,0,0,0" Grid.Row="1">
                    <Label
                        Text="Server Connection Details:"
                        Style="{StaticResource LargeLabel}"
                        TextColor="{StaticResource Primary}"/>
                    <FlexLayout HeightRequest="100" Direction="Row" Wrap="Wrap" AlignContent="SpaceEvenly" AlignItems="Start">
                        <HorizontalStackLayout Margin="-3,0,0,0">
                            <RadioButton Value="jmri"
                                         GroupName="ServerType"
                                         Content="JMRI Server"
                                         IsChecked="{Binding IsJmriServer}"
                                         CheckedChanged="CheckChanged_Jmri"/>
                            <RadioButton Value="withrottle"
                                         GroupName="ServerType"
                                         Content="WiThrottle Server"
                                         IsChecked="{Binding IsWiThrottle}"
                                         CheckedChanged="CheckChanged_WiThrottle"/>
                        </HorizontalStackLayout>

                        <StackLayout>
                            <Label Margin="0,-10,0,0" Text="Server Capabilities" Style="{StaticResource MicroLabel}"/>
                            <CollectionView ItemsSource="{Binding Capabilities.CapabilityIcons}"
                                            Margin="0,0,30,0">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                                </CollectionView.ItemsLayout>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="helpers:CapabilityIcon">
                                        <Grid RowDefinitions="auto,15">
                                            <!-- Stroke="{Binding IsAvailable, Converter={StaticResource BoolToColorConverter}}" -->
                                            <Border StrokeShape="RoundRectangle 5"
                                                    StrokeThickness="0.5">
                                                <Border.BackgroundColor>
                                                    <Binding Path="IsAvailable">
                                                        <Binding.Converter>
                                                            <converters:BoolToColorConverter
                                                                TrueColor="Transparent"
                                                                FalseColor="GhostWhite"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Border.BackgroundColor>
                                                <Border.Stroke>
                                                    <Binding Path="IsAvailable">
                                                        <Binding.Converter>
                                                            <converters:BoolToColorConverter
                                                                TrueColor="{StaticResource Primary}"
                                                                FalseColor="LightGray"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Border.Stroke>
                                            </Border>

                                            <Image Source="{Binding IconSource}" WidthRequest="24" HeightRequest="24"
                                                   Aspect="AspectFit"/>

                                            <Label Grid.Row="1" LineBreakMode="MiddleTruncation"
                                                   Text="{Binding Capability}"
                                                   VerticalOptions="Center" HorizontalOptions="Center"
                                                   FontFamily="OpenSansLight" FontSize="9">
                                                <Label.TextColor>
                                                    <Binding Path="IsAvailable">
                                                        <Binding.Converter>
                                                            <converters:BoolToColorConverter
                                                                TrueColor="{StaticResource Black}"
                                                                FalseColor="Gray"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Label.TextColor>

                                            </Label>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </StackLayout>
                    </FlexLayout>
                </StackLayout>

                <ScrollView Margin="0,20,0,0" Grid.Row="2" VerticalScrollBarVisibility="Always"
                            HorizontalScrollBarVisibility="Always">
                    <ContentView x:Name="SettingsView"/>
                </ScrollView>
            </Grid>
        </ScrollView>
        <Button Grid.Row="1"
                Command="{Binding SaveSettingsCommand}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsEnabled="{Binding IsNotBusy}"
                Margin="0,0,0,0"
                Style="{StaticResource ButtonOutline}"
                Text="Save Settings"
                WidthRequest="150"/>
    </Grid>
</ContentPage>