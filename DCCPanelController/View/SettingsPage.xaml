<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="settings_green.png"
    Title="Settings"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.View.SettingsPage"
    x:DataType="viewmodel:SettingsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:viewmodel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="About_OnClicked" IconImageSource="help.png" />
        <ToolbarItem Clicked="Instructions_OnClicked" IconImageSource="information.png" />
        <ToolbarItem Clicked="Upload_OnClicked" IconImageSource="upload.png" />
        <ToolbarItem Clicked="Download_OnClicked" IconImageSource="download.png" />
    </ContentPage.ToolbarItems>

    <Grid
        Margin="10"
        Padding="10"
        RowDefinitions="220,160,*">
        <!--  Server Address Area  -->
        <StackLayout Grid.Row="0" Margin="10" Padding="10">
            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="2" HorizontalOptions="FillAndExpand" />
            <Grid>
                <StackLayout x:Name="MainStackLayout">
                    <Label Margin="10,10,0,0" Style="{StaticResource MediumLabel}" TextColor="{StaticResource Primary}" Text="WiThrottle Server Address:"/>
                    <HorizontalStackLayout HorizontalOptions="Center" Margin="-15">
                        <Frame Style="{StaticResource IpAddress}">
                            <Entry Focused="OnEntryFocused" IsEnabled="{Binding IsLiveMode}" Text="{Binding IpAddress1}">
                                <Entry.Behaviors>
                                    <view:EntryValidationBehavior />
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                        <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        <Frame Style="{StaticResource IpAddress}">
                            <Entry
                                Focused="OnEntryFocused"
                                IsEnabled="{Binding IsLiveMode}"
                                Text="{Binding IpAddress2}">
                                <Entry.Behaviors>
                                    <view:EntryValidationBehavior />
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                        <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        <Frame Style="{StaticResource IpAddress}">
                            <Entry
                                Focused="OnEntryFocused"
                                IsEnabled="{Binding IsLiveMode}"
                                Text="{Binding IpAddress3}">
                                <Entry.Behaviors>
                                    <view:EntryValidationBehavior />
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                        <Label FontSize="48" Margin="2,2,2,30" Text="." TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        <Frame Style="{StaticResource IpAddress}">
                            <Entry
                                Focused="OnEntryFocused"
                                IsEnabled="{Binding IsLiveMode}"
                                Text="{Binding IpAddress4}">
                                <Entry.Behaviors>
                                    <view:EntryValidationBehavior />
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                        <Label FontSize="48" HorizontalOptions="Center" Margin="2,2,2,10" Text=":" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        <Frame Style="{StaticResource IpPort}" WidthRequest="75">
                            <Entry
                                Focused="OnEntryFocused"
                                IsEnabled="{Binding IsLiveMode}"
                                Text="{Binding Port}" />
                        </Frame>
                    </HorizontalStackLayout>
                    <Grid ColumnDefinitions="40,*">
                        <CheckBox
                            Grid.Column="0"
                            IsChecked="{Binding IsDemoMode}"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource InvertedBoolConverter}}"
                            x:Name="DemoModeCheckBox" />
                        <Label Grid.Column="1" Style="{StaticResource SmallLabel}" Text="Demo Mode (no Server connection)" VerticalOptions="Center" />
                    </Grid>
                </StackLayout>
            </Grid>

            <Button
                Command="{Binding ConnectCommand}"
                HorizontalOptions="Center"
                IsEnabled="{Binding IsConnectAvailable}"
                Margin="10,0,0,20"
                Padding="20"
                Style="{StaticResource ButtonOutline}"
                Text="{Binding ConnectLabel}"
                WidthRequest="150" />
            
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="2"
                HorizontalOptions="FillAndExpand" />
            
        </StackLayout>

        <!--  WiThrottle Servers List  -->
        <StackLayout Grid.Row="1">
            <Grid ColumnDefinitions="*,150">
                <Label
                    Grid.Column="0"
                    HorizontalOptions="Start"
                    Margin="5,0,0,10"
                    Style="{StaticResource MediumLabel}"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center">
                    Available WiThrottle Servers :
                </Label>
                <Button
                    BackgroundColor="{StaticResource White}"
                    Command="{Binding RefreshWiServersCommand}"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    ImageSource="refresh_circle.png"
                    Margin="-10,-7,0,0"
                    Style="{StaticResource SmallLabel}"
                    Text="Refresh"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center" />

            </Grid>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />
            
            <RefreshView Command="{Binding RefreshWiServersCommand}" IsRefreshing="{Binding IsRefreshing}">
                <Grid>
                    <ActivityIndicator
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Fill"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        VerticalOptions="Center" />

                    <CollectionView ItemsSource="{Binding WiServers}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label HorizontalOptions="Center" Text=" " />
                                <Label HorizontalOptions="Center" Text="No WiThrottle Servers could be found." />
                                <Label HorizontalOptions="Center" Text=" " />
                                <Label HorizontalOptions="Center" Text="Use Refresh to search for WiThrottle servers" />
                                <Label HorizontalOptions="Center" Text="available on the network." />
                            </StackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:WiServer">
                                <StackLayout>
                                    <Grid ColumnDefinitions="48,*">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnLabelTapped" />
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:SettingsViewModel}}, Path=SelectWiServerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label
                                            Grid.Column="0"
                                            HorizontalOptions="Start"
                                            Margin="5"
                                            Text="◉"
                                            VerticalOptions="Center"
                                            x:Name="SelectedServerTick" />
                                        <Label
                                            Grid.Column="1"
                                            HorizontalOptions="Start"
                                            LineBreakMode="NoWrap"
                                            Margin="0,5,0,5"
                                            Style="{StaticResource MediumLabel}"
                                            Text="{Binding Name}"
                                            VerticalOptions="Center"
                                            x:Name="SelectedServerText" />
                                    </Grid>
                                    <BoxView
                                        BackgroundColor="{StaticResource Primary}"
                                        HeightRequest="0.5"
                                        HorizontalOptions="FillAndExpand" />
                                </StackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>
        </StackLayout>

        <!--  WiThrottle Messages List  -->
        <StackLayout Grid.Row="2" VerticalOptions="Fill">
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="2"
                HorizontalOptions="FillAndExpand" />
            <Label
                Margin="5,10,5,10"
                Style="{StaticResource MediumLabel}"
                Text="WiThrottle Messages:"
                TextColor="{StaticResource Primary}" />
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />
            <Label>Start of Messages</Label>
            <CollectionView x:DataType="viewmodel:SettingsViewModel" 
                            ItemsSource="{Binding Messages}"
                            ItemsUpdatingScrollMode="KeepLastItemInView">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="system:String">
                        <HorizontalStackLayout>
                        <Label Text="Message: "/>
                        <Label Style="{StaticResource MediumLabel}" Text="{Binding .}" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label>End of Messages</Label>
        </StackLayout>
    </Grid>
</ContentPage>