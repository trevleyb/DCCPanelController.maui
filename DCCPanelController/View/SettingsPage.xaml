<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="settings_green.png"
    Title="Settings"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.View.SettingsPage"
    x:DataType="view:SettingsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:interfaces="clr-namespace:DCCClients.Interfaces;assembly=DCCClients"
    xmlns:dccClients="clr-namespace:DCCClients;assembly=DCCClients">

    <ContentPage.Resources>
        <ResourceDictionary/>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="About_OnClicked" IconImageSource="help_circle.png"/>
        <ToolbarItem Clicked="Instructions_OnClicked" IconImageSource="info.png"/>
        <ToolbarItem
            Clicked="ShowMessages_OnClicked"
            IconImageSource="chevron_down.png"
            x:Name="ShowMessagesButton"/>
        <ToolbarItem Clicked="Upload_OnClicked" IconImageSource="upload.png"/>
        <ToolbarItem Clicked="Download_OnClicked" IconImageSource="download.png"/>
    </ContentPage.ToolbarItems>


    <StackLayout>
        <Label
            Text="Server Connection Details:"
            Margin="10,10,20,0"
            Style="{StaticResource LargeLabel}"
            TextColor="{StaticResource Primary}"/>

        <HorizontalStackLayout Margin="20,20,0,0">
            <RadioButton GroupName="ServerType" Content="JMRI Server"
                         CheckedChanged="JmriServerButton_OnCheckedChanged" x:Name="JmriServerButton"/>
            <RadioButton GroupName="ServerType" Content="WiThrottle Server"
                         CheckedChanged="WiThrottleServerButton_OnCheckedChanged" x:Name="WiThrottleServerButton"/>
        </HorizontalStackLayout>

        <VerticalStackLayout Margin="20,0,0,0">
            <HorizontalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="150" Text="Client Identifier:"/>
                <Border 
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                    <Entry WidthRequest="250" Text="{Binding Name}" Style="{StaticResource PanelEntry}"/>
                </Border>
            </HorizontalStackLayout>

            <HorizontalStackLayout>
            <HorizontalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="150" Text="Server Protocol:"/>
                <Border 
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                <Entry WidthRequest="75" Text="{Binding Protocol}" Style="{StaticResource PanelEntry}" TextChanged="Protocol_OnTextChanged" />
                </Border>
            </HorizontalStackLayout>

            <HorizontalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="75" Text="Address:"/>
                <Border 
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                <Entry WidthRequest="185" Text="{Binding IpAddress}" Style="{StaticResource PanelEntry}" TextChanged="Address_OnTextChanged"/>
                </Border>
            </HorizontalStackLayout>
            
            <HorizontalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="40" Text="Port:"/>
                <Border 
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                <Entry WidthRequest="50" Text="{Binding Port}" Style="{StaticResource PanelEntry}" TextChanged="Port_OnTextChanged"/>
                </Border>
            </HorizontalStackLayout>
            </HorizontalStackLayout>
            <HorizontalStackLayout Margin="10,0,10,0">
                <Label Style="{StaticResource MediumLabel}" VerticalOptions="Center" WidthRequest="150" Text="Server URL:"/>
                <Border 
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    Padding="10,0,5,0"
                    Margin="0,5,0,5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
                <Entry WidthRequest="500" Text="{Binding Url}" Style="{StaticResource PanelEntry}" TextChanged="Url_OnTextChanged"/>
                </Border>
            </HorizontalStackLayout>

            <Button
                Command="{Binding ConnectCommand}"
                HorizontalOptions="Center"
                IsEnabled="{Binding IsConnectAvailable}"
                Margin="10,20,20,20"
                Style="{StaticResource ButtonOutline}"
                Text="{Binding ConnectLabel}"
                WidthRequest="150"/>

        </VerticalStackLayout>
        <BoxView
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="2"
            HorizontalOptions="FillAndExpand"/>

        <!-- <StackLayout IsVisible="{Binding ShowWiServers}"> -->
        <ScrollView>
        <StackLayout HeightRequest="225">
            <Grid ColumnDefinitions="*,150">
                <Label
                    Grid.Column="0"
                    HorizontalOptions="Start"
                    Style="{StaticResource MediumLabel}"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center">
                    Available Servers :
                </Label>
                <Button
                    BackgroundColor="{StaticResource White}"
                    Command="{Binding RefreshServersCommand}"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    ImageSource="refresh_cw.png"
                    Style="{StaticResource SmallLabel}"
                    Text="Refresh"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center"/>
            </Grid>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand"/>

            <RefreshView VerticalOptions="Start" HeightRequest="150" Command="{Binding RefreshServersCommand}" IsRefreshing="{Binding IsRefreshing}">
                <Grid>
                    <ActivityIndicator
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Fill"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        VerticalOptions="Center"/>

                    <CollectionView ItemsSource="{Binding Messages}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label HorizontalOptions="Center" Text=" "/>
                                <Label HorizontalOptions="Center" Text="No Servers could be found."/>
                                <Label HorizontalOptions="Center" Text=" "/>
                                <Label HorizontalOptions="Center" Text="Use Refresh to search for available servers"/>
                            </StackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dccClients:IDccSettings">
                                <StackLayout>
                                    <Grid ColumnDefinitions="48,*">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnLabelTapped"/>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:SettingsViewModel}}, Path=SelectWiServerCommand}"
                                                CommandParameter="{Binding .}"
                                                x:DataType="{x:Type view:SettingsViewModel}"/>
                                        </Grid.GestureRecognizers>
                                        <Label
                                            Grid.Column="0"
                                            HorizontalOptions="Start"
                                            Margin="5"
                                            Text="◉"
                                            VerticalOptions="Center"
                                            x:Name="SelectedServerTick"/>
                                        <Label
                                            Grid.Column="1"
                                            HorizontalOptions="Start"
                                            LineBreakMode="NoWrap"
                                            Margin="0,5,0,5"
                                            Style="{StaticResource MediumLabel}"
                                            Text="{Binding Name}"
                                            VerticalOptions="Center"
                                            x:Name="SelectedServerText"/>
                                    </Grid>
                                    <BoxView
                                        BackgroundColor="{StaticResource Primary}"
                                        HeightRequest="0.5"
                                        HorizontalOptions="FillAndExpand"/>
                                </StackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>
        </StackLayout>
        </ScrollView>
        <!-- <StackLayout IsVisible="{Binding ShowMessages}"> -->

        <BoxView
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="2"
            HorizontalOptions="FillAndExpand"/>

        <StackLayout>
            <Grid ColumnDefinitions="*,150">
                <Label
                    Grid.Column="0"
                    HorizontalOptions="Start"
                    Style="{StaticResource MediumLabel}"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center">
                    WiThrottle Server Messages :
                </Label>
                <Button
                    BackgroundColor="{StaticResource White}"
                    Command="{Binding ClearMessagesCommand}"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    ImageSource="trash_2.png"
                    Style="{StaticResource SmallLabel}"
                    Text="Clear"
                    TextColor="{StaticResource Primary}"
                    VerticalOptions="Center"/>
            </Grid>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand"/>
            <ScrollView>
                <CollectionView
                    ItemsSource="{Binding Messages}"
                    ItemsUpdatingScrollMode="KeepLastItemInView"
                    x:Name="MessagesList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="view:SettingsMessage">
                            <HorizontalStackLayout>
                                <Label
                                    Style="{StaticResource MediumLabel}"
                                    Text="{Binding TimeStamp}"
                                    WidthRequest="200"/>
                                <Label Style="{StaticResource MediumLabel}"
                                       Text="{Binding Message}"/>
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </StackLayout>
    </StackLayout>
</ContentPage>