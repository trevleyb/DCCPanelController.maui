<?xml version="1.0" encoding="utf-8" ?>

<toolkit:Popup
    x:Class="DCCPanelController.View.PanelProperties.PanelPropertyPopup"
    x:DataType="panelProperties:PanelPropertyViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:panelProperties="clr-namespace:DCCPanelController.View.PanelProperties"
    xmlns:propertyPages="clr-namespace:DCCPanelController.View.PanelProperties"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <toolkit:Popup.Content>
        <Border
            BackgroundColor="White"
            HeightRequest="600"
            HorizontalOptions="Center"
            MaximumHeightRequest="600"
            MaximumWidthRequest="500"
            Stroke="{StaticResource Primary}"
            StrokeThickness="1"
            VerticalOptions="Fill"
            WidthRequest="485">

            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid BackgroundColor="{StaticResource Primary}" VerticalOptions="Center">
                    <Button
                        Clicked="ClosePropertyPage"
                        Grid.Column="0"
                        HorizontalOptions="Start"
                        Text="Close" />
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Margin="0,0,0,0"
                        Style="{StaticResource LargeLabel}"
                        Text="{Binding PropertyName}"
                        TextColor="White"
                        VerticalOptions="Center" />
                    <ImageButton
                        Aspect="Center"
                        Grid.Column="0"
                        HeightRequest="25"
                        HorizontalOptions="End"
                        Source="info.png"
                        WidthRequest="25">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="White" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </Grid>
                <Grid
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    x:Name="Properties" />
            </VerticalStackLayout>
        </Border>
    </toolkit:Popup.Content>

</toolkit:Popup>