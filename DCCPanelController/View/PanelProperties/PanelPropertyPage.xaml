<!--  PanelPropertyPage.xaml  -->
<ContentPage
    x:Class="DCCPanelController.View.PanelProperties.PanelPropertyPage"
    x:DataType="panelProperties:PanelPropertyViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:panelProperties="clr-namespace:DCCPanelController.View.PanelProperties"
    xmlns:propertyPages="clr-namespace:DCCPanelController.View.PanelProperties"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ClosePropertyPage" IconImageSource="info.png" />
        <ToolbarItem Clicked="ClosePropertyPage" Text="Close" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid HorizontalOptions="Fill" Margin="5">
            <ScrollView
                BackgroundColor="White"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <Grid
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    x:Name="Properties" />
            </ScrollView>
        </Grid>
        <!--     </VerticalStackLayout> -->
        <!-- </Border> -->
    </ContentPage.Content>
</ContentPage>