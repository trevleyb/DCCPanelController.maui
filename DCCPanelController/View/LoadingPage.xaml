<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:progressBar="http://schemas.syncfusion.com/maui/toolkit"
             xmlns:view="clr-namespace:DCCPanelController.View"
             Title="Loading DCC Panel Controller"
             BackgroundColor="{StaticResource Primary}"
             x:Class="DCCPanelController.View.LoadingPage">
    <ContentPage.Content>
        <Grid>
            <Border BackgroundColor="{StaticResource Primary}" StrokeThickness="0" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid>
                    <Image Source="splash.png" HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5"/>
                    <progressBar:SfLinearProgressBar
                        IsIndeterminate="True"
                        x:DataType="view:LoadingPage"
                        Margin="0,300,0,0"
                        TrackHeight="10"
                        TrackFill="{StaticResource White}"
                        ProgressHeight="10"
                        ProgressFill="{StaticResource Gray400}"
                        WidthRequest="300"
                        HeightRequest="5"/>
                </Grid>
            </Border>
        </Grid>
    </ContentPage.Content>
</ContentPage>