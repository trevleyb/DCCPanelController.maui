<?xml version="1.0" encoding="utf-8"?>

<ContentView
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.TurnoutsEditView"
    x:DataType="view:TurnoutsEditViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <StackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" Text="System Name (ID)" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5" Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" Text="{Binding Turnout.Id}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="User Name" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5"  Style="{StaticResource EntryStyle}" HorizontalOptions="Fill"  Text="{Binding Turnout.Name}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="DCC Address" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}" WidthRequest="60">
                <Entry Keyboard="Numeric" Margin="5" Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" Text="{Binding Turnout.DccAddress}">
                    <Entry.Behaviors>
                        <toolkit:NumericValidationBehavior
                            Flags="ValidateOnValueChanged"
                            MinimumValue="0"
                            MaximumValue="9999"
                            ValidStyle="{StaticResource ValidEntryStyle}"
                            InvalidStyle="{StaticResource InvalidEntryStyle}" />
                    </Entry.Behaviors>
                </Entry>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label
                WidthRequest="170"
                HorizontalOptions="Start"
                Text="Current State"
                VerticalOptions="Center"
                Width="100"/>
            <components:TurnoutStateControl
                CanToggleState="True"
                HorizontalOptions="Start"
                State="{Binding Turnout.State}"
                StateChangedCommand="{Binding ToggleTurnoutStateCommand}"
                Turnout="{Binding Turnout}"/>
        </HorizontalStackLayout>
        <HorizontalStackLayout HeightRequest="40">
            <Label
                WidthRequest="170"
                HorizontalOptions="Start"
                Text="Startup Default State"
                VerticalOptions="Center"
                Width="100"/>
            <components:TurnoutStateControl
                CanToggleState="True"
                HorizontalOptions="Start"
                State="{Binding Turnout.Default}"
                StateChangedCommand="{Binding ToggleTurnoutDefaultStateCommand}"
                Turnout="{Binding Turnout}"/>
        </HorizontalStackLayout>

        <BoxView Margin="0,10,0,10"
                 BackgroundColor="{StaticResource Primary}"
                 HeightRequest="1"
                 VerticalOptions="End"
                 HorizontalOptions="FillAndExpand"/>

    </StackLayout>
</ContentView>