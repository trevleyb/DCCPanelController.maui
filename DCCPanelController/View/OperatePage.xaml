<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
             xmlns:view="clr-namespace:DCCPanelController.View"
             Title="{Binding SelectedPanel.Name}"
             x:DataType="viewModel:OperateViewModel"
             x:Class="DCCPanelController.View.OperatePage">
    
    <ContentPage.BindingContext>
        <viewModel:OperateViewModel />
    </ContentPage.BindingContext>
    
    <ContentPage.Content>
        <Grid ColumnDefinitions="*,auto" RowDefinitions="auto,*" Margin="10"> 
            <StackLayout x:Name="ControlPanelStack" Grid.Column="0" Grid.Row="0">
                <HorizontalStackLayout VerticalOptions="Center">
                    <CheckBox IsChecked="{Binding ShowGrid}"  VerticalOptions="Center"  />
                    <Label Text="Show Grid" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </StackLayout>
            
            <CarouselView x:Name="PanelCarousel" Grid.Column="0" Grid.Row="1" >
                <CarouselView.EmptyView>
                    <Label>There are no Panels to display</Label>
                </CarouselView.EmptyView>
                
                <CarouselView.ItemsSource>
                    <Binding Path="Panels" />
                </CarouselView.ItemsSource>
                
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <view:ControlPanelView BindingContext="{Binding .}" 
                                               BackgroundColor="White"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill"/>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
            
        </Grid>
    </ContentPage.Content>
</ContentPage>
