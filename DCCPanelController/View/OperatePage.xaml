<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="{Binding SelectedPanel.Name, FallbackValue='DCC Panel Controller'}"
    x:Class="DCCPanelController.View.OperatePage"
    x:DataType="viewModel:OperateViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:converters="clr-namespace:DCCPanelController.Helpers.Converters"
    BackgroundColor="{Binding BackgroundColor,  Converter={StaticResource ColorFallbackConverter}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Register ColorFallbackConverter -->
            <converters:ColorFallbackConverter x:Key="ColorFallbackConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <viewModel:OperateViewModel />
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            ToolTipProperties.Text="Hide Bottom Tab Bar"
            Clicked="HideUnHideTabBar"
            IconImageSource="maximize_2.png"
            Text="Hide"
            x:Name="HideUnHide" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
            <Grid ColumnDefinitions="*" Margin="10" RowDefinitions="*,20">
                <ActivityIndicator
                    Grid.Column="0"
                    Grid.Row="0"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    VerticalOptions="Center" />
                <Grid
                    Grid.Column="0"
                    Grid.Row="0">
                    <CarouselView
                        CurrentItem="{Binding SelectedPanel}"
                        IndicatorView="IndicatorView"
                        BackgroundColor="{Binding BackgroundColor,  Converter={StaticResource ColorFallbackConverter}}"
                        x:Name="PanelCarousel">

                        <CarouselView.ItemsSource>
                            <Binding Path="Panels" />
                        </CarouselView.ItemsSource>

                        <CarouselView.EmptyView>
                            <VerticalStackLayout Margin="20" HorizontalOptions="Center" VerticalOptions="Center">
                                <StackLayout
                                    HorizontalOptions="CenterAndExpand" VerticalOptions="Center">
                                    <Label
                                        Margin="0,0,0,20"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        Text="Welcome to the DCC Model Layout Panel Controller" />
                                </StackLayout>
                                
                                <HorizontalStackLayout Margin="20" Padding="20" HorizontalOptions="Center" VerticalOptions="End">
                                    <Button
                                        Clicked="ButtonInstructions_OnClicked"
                                        Margin="10,10,10,10"
                                        Style="{StaticResource ButtonOutline}"
                                        Text="Instructions" />
                                    <Button
                                        Clicked="ButtonAbout_OnClicked"
                                        Margin="10,10,10,10"
                                        Style="{StaticResource ButtonOutline}"
                                        Text="About" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </CarouselView.EmptyView>

                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <view:ControlPanelView
                                    x:Name="PanelView"
                                    x:DataType="model:Panel"
                                    Panel="{Binding Source={RelativeSource AncestorType={x:Type viewModel:OperateViewModel}}, x:DataType=viewModel:OperateViewModel, Path=SelectedPanel}"
                                    BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type viewModel:OperateViewModel}}, x:DataType=viewModel:OperateViewModel, Path=BackgroundColor}"
                                    TrackPieceChanged="PanelView_OnTrackPieceChanged"
                                    TrackPieceTapped="PanelView_OnTrackPieceTapped"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                </Grid>

                <IndicatorView
                    Grid.Column="0"
                    Grid.Row="1"
                    Margin="0,-5,0,0"
                    VerticalOptions="Start"
                    HorizontalOptions="Center"
                    IndicatorColor="DarkGrey"
                    SelectedIndicatorColor="{StaticResource Primary}"
                    x:Name="IndicatorView" />
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>


<!-- Panel="{Binding Path=.}" -->