<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    BackgroundColor="{Binding BackgroundColor, Converter={StaticResource ColorFallbackConverter}}"
    x:Name="OperateRoot"
    x:Class="DCCPanelController.View.OperatePage"
    x:DataType="view:OperateViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:global="clr-namespace:"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
    xmlns:fonts="clr-namespace:Fonts"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ColorFallbackConverter x:Key="ColorFallbackConverter"/>
            <converters:IndicatorColorConverter x:Key="IndicatorColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem 
            Command="{Binding ToggleConnectionCommand}" 
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource MultiBoolToIcon}">
                    <Binding Path="IsConnectionAvailable" />    <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="IsConnected" />              <!-- Parameter 2: bool for name selection -->
                    <Binding Path="IconWifiOn"/>
                    <Binding Path="IconWifiOff"/>
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

        <ToolbarItem Clicked="HideUnHideTabBar" Text="Hide" 
                     ToolTipProperties.Text="Hide Bottom Tab Bar" x:Name="HideUnHide" 
                     IconImageSource="maximize_2"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid RowDefinitions="*,45">

            <!-- Main Panel Content with Swipe Gesture -->
            <ContentView Grid.Row="0"
                         BackgroundColor="{Binding BackgroundColor, Converter={StaticResource ColorFallbackConverter}}">
                <ContentView.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Left" Command="{Binding SwipeLeftCommand}"/>
                    <SwipeGestureRecognizer Direction="Right" Command="{Binding SwipeRightCommand}"/>
                </ContentView.GestureRecognizers>

                <!-- Panel Content or Empty View -->
                <Grid>
                    <!-- Active Panel View -->
                    <view:ControlPanelView
                        TileTapped="PanelViewOnTileTapped"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Interactive="True"
                        DesignMode="False"
                        ShowGrid="false"
                        x:Name="PanelView"/>

                    <!-- Empty View when no panels -->
                    <ContentView HorizontalOptions="Fill" VerticalOptions="Fill" IsVisible="{Binding ShowWelcomePage}">
                        <ScrollView>
                            <Grid ColumnDefinitions="80,*,80">
                                <ImageButton Grid.Column="0" WidthRequest="80" HeightRequest="80" 
                                       Source="chevrons_left.png"
                                       Command="{Binding SwipeLeftCommand}"
                                       HorizontalOptions="Start" VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="#ebebeb"/>
                                    </Image.Behaviors>
                                </ImageButton>
                                <ImageButton Grid.Column="2" WidthRequest="80" HeightRequest="80"
                                       Command="{Binding SwipeRightCommand}"
                                       Source="chevrons_right.png" 
                                       HorizontalOptions="End" VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="#ebebeb"/>
                                    </Image.Behaviors>
                                </ImageButton>
                                <StackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image Source="appiconimage.png" WidthRequest="100" HeightRequest="100"/>
                                    <Label
                                        Style="{StaticResource LargeLabel}"
                                        FontFamily="OpenSansBold"
                                        HorizontalOptions="Center"
                                        LineBreakMode="WordWrap"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,20,0,10"
                                        Text="Welcome to the DCC Model Layout Panel Controller App"
                                        VerticalOptions="Center"/>
                                    <Label
                                        IsVisible="{Binding HasNoPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLight"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,10,0,0"
                                        Text="There are no panels currently defined. Use panel Editor to add a panel."
                                        VerticalOptions="Center"/>
                                    <Label
                                        IsVisible="{Binding HasPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLight"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,10,0,0"
                                        Text="To access panels, Swipe Left or Right or use the dots below."
                                        VerticalOptions="Center"/>
                                    <Label
                                        IsVisible="{Binding HasPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLightItalic"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,10,0,0"
                                        Text="You can turn this welcome page off in settings."
                                        VerticalOptions="Center"/>

                                    <HorizontalStackLayout
                                        HorizontalOptions="Center"
                                        Margin="0"
                                        Padding="10"
                                        VerticalOptions="End">
                                        <Button
                                            WidthRequest="150"
                                            Clicked="ButtonInstructions_OnClicked"
                                            Margin="0,10,10,10"
                                            Style="{StaticResource ButtonOutline}"
                                            Text="Instructions"/>
                                            
                                        <Button
                                            IsVisible="{Binding HasPanels}"
                                            WidthRequest="150"
                                            Clicked="ButtonCloseInstructions"
                                            Margin="10,10,0,10"
                                            Style="{StaticResource ButtonOutline}"
                                            Text="Close"/>

                                    </HorizontalStackLayout>
                                </StackLayout>
                            </Grid>
                        </ScrollView>
                    </ContentView>
                </Grid>
            </ContentView>

            <CollectionView Grid.Row="1"
                            SelectionMode="None"
                            IsVisible="True"
                            ItemsSource="{Binding PanelIndicators, Mode=OneWay}"
                            HorizontalOptions="Center"
                            VerticalOptions="Start"
                            Margin="0,10,0,10">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="view:PanelIndicator">
                        <Border 
                            WidthRequest="12" 
                            HeightRequest="12" 
                            StrokeShape="Ellipse" 
                            StrokeThickness="0">
                            <Border.BackgroundColor>
                                <MultiBinding Converter="{StaticResource IndicatorColorConverter}">
                                    <Binding Path="Index"/>
                                    <Binding Path="Active"/>
                                </MultiBinding>
                            </Border.BackgroundColor>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding x:DataType='view:OperateViewModel', Source={RelativeSource AncestorType={x:Type view:OperateViewModel}},Path=SelectPanelCommand }"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ContentPage.Content>
</ContentPage>