<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="DCC Panel Controller"
    BackgroundColor="{Binding DisplayBackgroundColor, Converter={StaticResource ColorFallbackConverter}}"
    x:Name="OperateRoot"
    x:Class="DCCPanelController.View.OperatePage"
    x:DataType="view:OperateViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
    xmlns:controlPanel="clr-namespace:DCCPanelController.View.ControlPanel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ColorFallbackConverter x:Key="ColorFallbackConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Left" Command="{Binding SwipeLeftCommand}" IsEnabled="{Binding HasPanels}"
                     IconImageSource="{Binding HasPanels, Converter={StaticResource BoolToIcon}, ConverterParameter=chevron_left}"/>
        <ToolbarItem Text="Right" Command="{Binding SwipeRightCommand}" IsEnabled="{Binding HasPanels}"
                     IconImageSource="{Binding HasPanels, Converter={StaticResource BoolToIcon}, ConverterParameter=chevron_right}"/>

        <ToolbarItem
            Command="{Binding ToggleConnectionCommand}"
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource MultiBoolToIcon}">
                    <Binding Path="IsConnectionAvailable"/>    <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="IsConnected"/>              <!-- Parameter 2: bool for name selection -->
                    <Binding Path="IconWifiOn"/>
                    <Binding Path="IconWifiOff"/>
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

        <ToolbarItem Clicked="HideUnHideTabBar" Text="Hide"
                     ToolTipProperties.Text="Hide Bottom Tab Bar" x:Name="HideUnHide"
                     IconImageSource="maximize_2"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid RowDefinitions="*,auto">

            <!-- Main Panel Content with Swipe Gesture -->
            <Grid Grid.Row="0">
                <Grid
                    BackgroundColor="{Binding PanelBackgroundColor, Converter={StaticResource ColorFallbackConverter}}">
                    <Grid.GestureRecognizers>
                        <SwipeGestureRecognizer Direction="Left" Command="{Binding SwipeLeftCommand}"/>
                        <SwipeGestureRecognizer Direction="Right" Command="{Binding SwipeRightCommand}"/>
                    </Grid.GestureRecognizers>

                    <!-- Active Panel View -->
                    <controlPanel:ControlPanelView
                        TileTapped="PanelViewOnTileTapped"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Interactive="True"
                        DesignMode="False"
                        ShowGrid="false"
                        IsVisible="{Binding HideWelcomePage}"
                        Panel="{Binding ActivePanel}"
                        x:Name="PanelView"/>

                    <!-- Empty View when no panels -->
                    <ContentView HorizontalOptions="Fill" VerticalOptions="Fill" IsVisible="{Binding ShowWelcomePage}">
                        <ScrollView>
                            <Grid ColumnDefinitions="*">
                                <StackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image Source="splash.png" WidthRequest="200" HeightRequest="200" Margin="0,10,0,0"/>
                                    <Label Text="{Binding VersionNumber}" HorizontalOptions="Center"
                                           Style="{StaticResource SmallLabel}" FontFamily="OpenSansLightItalic"/>
                                    <Label
                                        FontSize="18"
                                        FontFamily="OpenSansLightBold"
                                        HorizontalOptions="Center"
                                        LineBreakMode="WordWrap"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,20,0,10"
                                        Text="Welcome to the DCC Model Layout Panel Controller"
                                        VerticalOptions="Center"/>
                                    <Label
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLight"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="100,10,100,10"
                                        Text="This application allows you to define layout schematics for your model railway and connect to either WiThrottle or JMRI to control your layout including turnouts and routes and show block occupancy (if supported)."
                                        VerticalOptions="Center"/>

                                    <Label
                                        IsVisible="{Binding HasNoPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLight"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="100,10,100,0"
                                        Text="There are no panels currently defined. Use panel Editor to add a panel."
                                        VerticalOptions="Center"/>
                                    <Label
                                        IsVisible="{Binding HasPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLight"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,10,0,0"
                                        Text="To access panels, Swipe Left or Right or use the dots below."
                                        VerticalOptions="Center"/>
                                    <Label
                                        IsVisible="{Binding HasPanels}"
                                        Style="{StaticResource MediumLabel}"
                                        LineBreakMode="WordWrap"
                                        FontFamily="OpenSansLightItalic"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Margin="0,10,0,0"
                                        Text="You can turn this welcome page off in settings."
                                        VerticalOptions="Center"/>

                                    <FlexLayout
                                        Direction="Row"
                                        Wrap="Wrap"
                                        JustifyContent="Center"
                                        AlignItems="Center"
                                        AlignContent="Center"
                                        HorizontalOptions="Center"
                                        Margin="0,20,0,0"
                                        Padding="10"
                                        VerticalOptions="End">
                                        <Button
                                            WidthRequest="150"
                                            Clicked="ButtonInstructions_OnClicked"
                                            Margin="10,10,10,10"
                                            Style="{StaticResource ButtonOutline}"
                                            Text="Instructions"/>

                                        <Button
                                            WidthRequest="150"
                                            Clicked="ButtonAbout_OnClicked"
                                            Margin="10,10,10,10"
                                            Style="{StaticResource ButtonOutline}"
                                            Text="About"/>

                                        <Button
                                            IsVisible="{Binding HasPanels}"
                                            WidthRequest="150"
                                            Clicked="ButtonCloseInstructions"
                                            Margin="10,10,10,10"
                                            Style="{StaticResource ButtonOutline}"
                                            Text="Close"/>

                                    </FlexLayout>
                                </StackLayout>
                            </Grid>
                        </ScrollView>
                    </ContentView>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" HeightRequest="32">

                <IndicatorView
                    x:Name="Indicators"
                    ItemsSource="{Binding Panels}"
                    IndicatorColor="{StaticResource Gray300}"
                    SelectedIndicatorColor="{StaticResource Primary}"
                    IndicatorsShape="Circle"
                    HideSingle="True"
                    IndicatorSize="12"
                    Position="{Binding CurrentPanelIndex}"/>

                <Label Margin="0,0,10,5"
                       FontSize="8"
                       Text="{Binding ProfileName}"
                       HorizontalOptions="End"
                       VerticalOptions="End" IsVisible="{Binding IsMaximized}"
                       BackgroundColor="Transparent" TextColor="Gainsboro">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchActiveProfileCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>