<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="DCC Panel Controller"
    BackgroundColor="{Binding DisplayBackgroundColor, Converter={StaticResource ColorFallbackConverter}}"
    x:Name="OperateRoot"
    x:Class="DCCPanelController.View.OperatePage"
    x:DataType="view:OperateViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
    xmlns:controlPanel="clr-namespace:DCCPanelController.View.ControlPanel"
    xmlns:services="clr-namespace:DCCPanelController.Services"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ShowConnectingStateConverter x:Key="ShowConnectingStateConverter"/>
            <converters:ShowNotConnectingStateConverter x:Key="ShowNotConnectingStateConverter"/>
            <converters:ColorFallbackConverter x:Key="ColorFallbackConverter"/>
            <converters:ContrastToBackgroundConverter x:Key="ContrastToBg" MinContrast="4.5"/>
            <converters:ContrastToBackgroundMultiConverter x:Key="ContrastToBgMulti" MinContrast="4.5"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Left" Command="{Binding SwipeLeftCommand}" IsEnabled="{Binding HasPanels}"
                     IconImageSource="{Binding HasPanels, Converter={StaticResource BoolToIcon}, ConverterParameter=chevron_left}"/>
        <ToolbarItem Text="Right" Command="{Binding SwipeRightCommand}" IsEnabled="{Binding HasPanels}"
                     IconImageSource="{Binding HasPanels, Converter={StaticResource BoolToIcon}, ConverterParameter=chevron_right}"/>

        <ToolbarItem
            Command="{Binding ToggleConnectionCommand}"
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource ConnectionIconConverter}">
                    <Binding Path="IsConnectionAvailable"/>     <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="ConnectionState"/>           <!-- Parameter 2: bool for name selection -->
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

        <ToolbarItem Clicked="HideUnHideTabBar" Text="Hide"
                     ToolTipProperties.Text="Hide Bottom Tab Bar" x:Name="HideUnHide"
                     IconImageSource="maximize_2.png"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid>
            <Grid RowDefinitions="*,auto,auto" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid Grid.Row="0" x:Name="MainGrid" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <Grid
                        BackgroundColor="{Binding PanelBackgroundColor, Converter={StaticResource ColorFallbackConverter}}">
                        <Grid.GestureRecognizers>
                            <SwipeGestureRecognizer Direction="Left" Command="{Binding SwipeLeftCommand}"/>
                            <SwipeGestureRecognizer Direction="Right" Command="{Binding SwipeRightCommand}"/>
                        </Grid.GestureRecognizers>

                        <!-- Active Panel View -->
                        <controlPanel:ControlPanelView
                            TileTapped="PanelViewOnTileTapped"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Interactive="True"
                            DesignMode="False"
                            ShowGrid="false"
                            IsVisible="{Binding HideWelcomePage}"
                            Panel="{Binding ActivePanel}"
                            x:Name="PanelView"/>

                        <!-- Empty View when no panels -->
                        <ContentView HorizontalOptions="Fill" VerticalOptions="Fill"
                                     IsVisible="{Binding ShowWelcomePage}">
                            <ScrollView>
                                <Grid ColumnDefinitions="*">
                                    <StackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Image Source="splash.png" WidthRequest="200" HeightRequest="200"
                                               Margin="0,10,0,0"/>
                                        <Label Text="{Binding VersionNumber}" HorizontalOptions="Center"
                                               Style="{StaticResource SmallLabel}" FontFamily="OpenSansLightItalic"/>
                                        <Label
                                            FontSize="18"
                                            FontFamily="OpenSansLightBold"
                                            HorizontalOptions="Center"
                                            LineBreakMode="WordWrap"
                                            HorizontalTextAlignment="Center"
                                            Margin="0,20,0,10"
                                            Text="Welcome to the DCC Model Layout Panel Controller"
                                            VerticalOptions="Center"/>
                                        <Label
                                            Style="{StaticResource MediumLabel}"
                                            LineBreakMode="WordWrap"
                                            FontFamily="OpenSansLight"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Margin="{OnIdiom Phone='20,10,20,10', Default='100,10,100,10'}"
                                            Text="This application allows you to define layout schematics for your model railway and connect to either WiThrottle or JMRI to control your layout including turnouts and routes and show block occupancy (if supported)."
                                            VerticalOptions="Center"/>

                                        <Label
                                            IsVisible="{Binding HasNoPanels}"
                                            Style="{StaticResource MediumLabel}"
                                            LineBreakMode="WordWrap"
                                            FontFamily="OpenSansLight"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Margin="{OnIdiom Phone='20,10,20,10', Default='100,10,100,10'}"
                                            Text="There are no panels currently defined. Use panel Editor to add a panel."
                                            VerticalOptions="Center"/>

                                        <Label
                                            IsVisible="{Binding HasPanels}"
                                            Style="{StaticResource MediumLabel}"
                                            LineBreakMode="WordWrap"
                                            FontFamily="OpenSansLight"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Margin="{OnIdiom Phone='20,10,20,10', Default='100,10,100,10'}"
                                            Text="To access panels, Swipe Left or Right, use the dots below, or use the arrow buttons on the toolbar."
                                            VerticalOptions="Center"/>
                                        
                                        <Label
                                            IsVisible="{Binding HasPanels}"
                                            Style="{StaticResource MediumLabel}"
                                            LineBreakMode="WordWrap"
                                            FontFamily="OpenSansLightItalic"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Margin="{OnIdiom Phone='20,10,20,10', Default='100,10,100,10'}"
                                            Text="You can turn this welcome page off in settings."
                                            VerticalOptions="Center"/>

                                        <FlexLayout
                                            Direction="Row"
                                            Wrap="Wrap"
                                            JustifyContent="Center"
                                            AlignItems="Center"
                                            AlignContent="Center"
                                            HorizontalOptions="Center"
                                            Margin="0,5,0,0"
                                            Padding="5"
                                            VerticalOptions="End">
                                            
                                            <Button
                                                WidthRequest="150"
                                                Clicked="ButtonInstructions_OnClicked"
                                                Margin="10,5,10,0"
                                                Style="{StaticResource ButtonOutline}"
                                                Text="Instructions"/>

                                            <Button
                                                WidthRequest="150"
                                                Clicked="ButtonAbout_OnClicked"
                                                Margin="10,5,10,0"
                                                Style="{StaticResource ButtonOutline}"
                                                Text="About"/>

                                            <Button
                                                IsVisible="{Binding HasPanels}"
                                                WidthRequest="150"
                                                Clicked="ButtonCloseInstructions"
                                                Margin="10,5,10,0"
                                                Style="{StaticResource ButtonOutline}"
                                                Text="Close"/>

                                        </FlexLayout>
                                    </StackLayout>
                                </Grid>
                            </ScrollView>
                        </ContentView>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1">
                    <IndicatorView
                        x:Name="Indicators"
                        Margin="0,10,0,0"
                        ItemsSource="{Binding Panels}"
                        IndicatorsShape="Circle"
                        HideSingle="False"
                        IndicatorSize="{OnIdiom Phone='10', Default='12'}"
                        IsVisible="{Binding HideWelcomePage}"
                        Position="{Binding CurrentPanelIndex}">

                        <IndicatorView.IndicatorColor>
                            <MultiBinding Converter="{StaticResource ContrastToBgMulti}">
                                <Binding Path="IndicatorColor"/>
                                <Binding Path="PanelBackgroundColor"
                                         Converter="{StaticResource ColorFallbackConverter}"/>
                            </MultiBinding>
                        </IndicatorView.IndicatorColor>

                        <IndicatorView.SelectedIndicatorColor>
                            <MultiBinding Converter="{StaticResource ContrastToBgMulti}">
                                <Binding Path="IndicatorSelectedColor"/>
                                <Binding Path="PanelBackgroundColor"
                                         Converter="{StaticResource ColorFallbackConverter}"/>
                            </MultiBinding>
                        </IndicatorView.SelectedIndicatorColor>
                    </IndicatorView>
                </Grid>

                <Grid Grid.Row="2" VerticalOptions="Center">
                    <HorizontalStackLayout HeightRequest="16" HorizontalOptions="Start" VerticalOptions="Center" Margin="5,0,0,5" Opacity="0.50">
                        <Image Source="{Binding ConnectionIconPng}" VerticalOptions="Center">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{Binding ConnectionColor, Mode=OneWay}"/>
                            </Image.Behaviors>
                            <Image.Triggers>
                                <DataTrigger TargetType="Image" Binding="{Binding Path=IsMaximized}" Value="True">
                                    <Setter Property="Margin" Value="5,0,0,-20" />
                                </DataTrigger>

                                <DataTrigger TargetType="Image" Binding="{Binding Path=IsMaximized}" Value="False">
                                    <Setter Property="Margin" Value="5,0,0,0" />
                                </DataTrigger>
                            </Image.Triggers>

                        </Image>
                        <Label Margin="5,0,0,0" FontSize="12" Text="{Binding ConnectionTextWithSystem}"
                               HorizontalOptions="Start" VerticalOptions="Center"
                               BackgroundColor="Transparent">

                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Path=IsMaximized}" Value="True">
                                    <Setter Property="Margin" Value="5,0,0,-20" />
                                </DataTrigger>

                                <DataTrigger TargetType="Label" Binding="{Binding Path=IsMaximized}" Value="False">
                                    <Setter Property="Margin" Value="5,0,0,0" />
                                </DataTrigger>
                            </Label.Triggers>
                            
                            <Label.TextColor>
                                <MultiBinding Converter="{StaticResource ContrastToBgMulti}">
                                    <Binding Path="ConnectionColor"/>
                                    <Binding Path="PanelBackgroundColor"
                                             Converter="{StaticResource ColorFallbackConverter}"/>
                                </MultiBinding>
                            </Label.TextColor>

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleConnectionCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                    
                    <HorizontalStackLayout HeightRequest="16" HorizontalOptions="End" Margin="0,0,5,5" Opacity="0.50" IsVisible="{Binding IsNotMaximized}">
                        <Label FontSize="12"
                               Text="{Binding ProfileName}"
                               HorizontalOptions="End"
                               VerticalOptions="End"
                               BackgroundColor="Transparent" >

                            <Label.TextColor>
                                <MultiBinding Converter="{StaticResource ContrastToBgMulti}">
                                    <Binding Path="ProfileNameColor"/>
                                    <Binding Path="PanelBackgroundColor"
                                             Converter="{StaticResource ColorFallbackConverter}"/>
                                </MultiBinding>
                            </Label.TextColor>

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchActiveProfileCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </Grid>

            </Grid>
            <ImageButton x:Name="UnmaximizeFab"
                         Source="minimize_2_active.png"
                         BackgroundColor="#99000000"
                         CornerRadius="20"
                         WidthRequest="40"
                         HeightRequest="40"
                         Padding="12"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="8,8,8,-12"
                         ZIndex="1000"
                         Opacity="0.50"
                         IsVisible="{Binding IsMaximized}"
                         Clicked="UnmaximizeFab_Clicked"/>
            
            <!-- Connecting Overlay -->
            <Grid IsVisible="{Binding ConnectionState, Converter={StaticResource ShowConnectingStateConverter}}"
                  BackgroundColor="WhiteSmoke"
                  Opacity="0.75"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">

                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 25"
                        Stroke="{StaticResource Primary}"
                        StrokeThickness="3"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="325"
                        HeightRequest="120"
                        Opacity="1"
                        Margin="20"
                        Padding="20">

                    <StackLayout
                        BackgroundColor="White"
                        HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                        <ActivityIndicator
                            BackgroundColor="White"
                            IsRunning="{Binding ConnectionState, Converter={StaticResource ShowConnectingStateConverter}}"
                            Color="{StaticResource Primary}"/>
                        <Label Text="DCC System Status"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="15"
                               TextColor="Black"/>
                        <Label Text="{Binding ConnectionText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="15"
                               TextColor="{Binding ConnectionColor}"/>
                    </StackLayout>
                </Border>
            </Grid>
            
