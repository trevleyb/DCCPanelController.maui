<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
             xmlns:view="clr-namespace:DCCPanelController.View"
             Title="{Binding SelectedPanel.Name}"
             x:DataType="viewModel:OperateViewModel"
             x:Class="DCCPanelController.View.OperatePage">
    
    <ContentPage.BindingContext>
        <viewModel:OperateViewModel />
    </ContentPage.BindingContext>
    
    <ContentPage.Content>
        <Grid ColumnDefinitions="*" RowDefinitions="*,Auto" Margin="10"> 
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Grid.Column="0"
                               Grid.Row="0"/>
            <CarouselView x:Name="PanelCarousel"
                          Grid.Column="0"
                          Grid.Row="0"
                          IndicatorView="IndicatorView"
                          CurrentItem="{Binding SelectedPanel}">

                <CarouselView.EmptyView>
                    <Label Text="There are no Panels to display"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           VerticalTextAlignment="Center"/>
                </CarouselView.EmptyView>
                
                <CarouselView.ItemsSource>
                    <Binding Path="PanelViewModels" />
                </CarouselView.ItemsSource>
                
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <view:ControlPanelView BindingContext="{Binding .}" 
                                               BackgroundColor="White"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill"/>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
            <IndicatorView x:Name="IndicatorView"
                           Grid.Column="0"
                           Grid.Row="1"
                           IndicatorColor="LightGray"
                           SelectedIndicatorColor="DarkGray"
                           HorizontalOptions="Center" />
        </Grid>
        
    </ContentPage.Content>
</ContentPage>
