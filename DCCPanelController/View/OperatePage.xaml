<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="{Binding SelectedPanel.Name}"
    x:Class="DCCPanelController.View.OperatePage"
    x:DataType="viewModel:OperateViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.BindingContext>
        <viewModel:OperateViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <Grid
            ColumnDefinitions="*"
            Margin="10"
            RowDefinitions="*,Auto">
            <ActivityIndicator
                Grid.Column="0"
                Grid.Row="0"
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                VerticalOptions="Center" />
            <CarouselView
                CurrentItem="{Binding SelectedPanel}"
                Grid.Column="0"
                Grid.Row="0"
                IndicatorView="IndicatorView"
                x:Name="PanelCarousel">
                <CarouselView.EmptyView>
                    <StackLayout
                        HorizontalOptions="CenterAndExpand"
                        Padding="20"
                        VerticalOptions="CenterAndExpand">
                        <StackLayout
                            HorizontalOptions="CenterAndExpand"
                            Padding="20"
                            VerticalOptions="CenterAndExpand">
                            <Label
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                Text="Welcome to the DCC Model Layout Panel Controller" />
                            <Label HorizontalOptions="Center" Text="  " />
                            <Label HorizontalOptions="Center"
                                   Text="This page will populate once you have created panels and turnout control. " />
                            <Label HorizontalOptions="Center"
                                   Text="To get started, head over to the instructions page and then to Settings to connect to your WiThrottle server." />
                            <Label HorizontalOptions="Center" Text="  " />
                        </StackLayout>
                        <StackLayout
                            HorizontalOptions="CenterAndExpand"
                            Padding="20"
                            VerticalOptions="CenterAndExpand">
                            <Button
                                Clicked="ButtonInstructions_OnClicked"
                                Margin="0,10,0,10"
                                Style="{StaticResource ButtonOutline}"
                                Text="Instructions" />
                            <Button
                                Clicked="ButtonAbout_OnClicked"
                                Margin="0,10,0,10"
                                Style="{StaticResource ButtonOutline}"
                                Text="About" />
                        </StackLayout>
                    </StackLayout>
                </CarouselView.EmptyView>

                <CarouselView.ItemsSource>
                    <Binding Path="Panels" />
                </CarouselView.ItemsSource>

                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <view:ControlPanelView
                            BackgroundColor="White"
                            DesignMode="False"
                            HorizontalOptions="Fill"
                            Panel="{Binding .}"
                            ShowGrid="False"
                            VerticalOptions="Fill" />
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
            <IndicatorView
                Grid.Column="0"
                Grid.Row="1"
                HorizontalOptions="Center"
                IndicatorColor="LightGray"
                SelectedIndicatorColor="DarkGray"
                x:Name="IndicatorView" />
        </Grid>

    </ContentPage.Content>
</ContentPage>