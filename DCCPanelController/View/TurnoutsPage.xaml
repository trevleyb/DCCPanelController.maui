<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="DCCPanelController.View.TurnoutsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Content>
        <StackLayout>
            <Grid Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Text="Name" TextColor="Black" />
                <Label Text="User Name" TextColor="Black" />
                <Label
                    HorizontalTextAlignment="Center"
                    Text="State"
                    TextColor="Black" />
                <BoxView
                    BackgroundColor="Black"
                    HeightRequest="1"
                    Margin="0,0,5,0"
                    VerticalOptions="End" />
                <BoxView
                    BackgroundColor="Black"
                    HeightRequest="1"
                    Margin="0,0,5,0"
                    VerticalOptions="End" />
                <BoxView
                    BackgroundColor="Black"
                    HeightRequest="1"
                    Margin="0,0,5,0"
                    VerticalOptions="End" />
            </Grid>
            <CollectionView ItemsSource="{Binding Turnouts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Text="{Binding Name}" />
                            <Label FontAttributes="Bold" Text="{Binding UserName}" />
                            <Label HorizontalTextAlignment="Center" Text="{Binding State}">
                                <Label.Triggers>
                                    <DataTrigger
                                        Binding="{Binding State}"
                                        TargetType="Label"
                                        Value="Closed">
                                        <Setter Property="TextColor" Value="White" />
                                        <Setter Property="BackgroundColor" Value="Green" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding State}"
                                        TargetType="Label"
                                        Value="Thrown">
                                        <Setter Property="TextColor" Value="White" />
                                        <Setter Property="BackgroundColor" Value="Red" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding State}"
                                        TargetType="Label"
                                        Value="Unknown">
                                        <Setter Property="TextColor" Value="White" />
                                        <Setter Property="BackgroundColor" Value="Grey" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>