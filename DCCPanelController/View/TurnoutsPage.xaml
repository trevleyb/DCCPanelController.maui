        <!-- Connecting Overlay -->
        <Grid IsVisible="{Binding ConnectionState, Converter={StaticResource ShowConnectingStateConverter}}"
              BackgroundColor="WhiteSmoke"
              Opacity="0.75"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 25"
                    Stroke="{StaticResource Primary}"
                    StrokeThickness="3"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="200"
                    HeightRequest="120"
                    Opacity="1"
                    Margin="20"
                    Padding="20">

                <StackLayout
                    BackgroundColor="White"
                    HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <ActivityIndicator
                        BackgroundColor="White"
                        IsRunning="{Binding ConnectionState, Converter={StaticResource ShowConnectingStateConverter}}"
                        Color="{StaticResource Primary}" />
                    <Label Text="DCC System Status"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="15"
                           TextColor="Black" />
                    <Label Text="{Binding ConnectionText}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="15"
                           TextColor="{Binding ConnectionColor}" />
                </StackLayout>
            </Border>
        </Grid>
        <!-- Bottom Sheet for editing the Connection Details -->
        <navigationDrawer:SfBottomSheet
            x:Name="BottomSheet"
            CornerRadius="15, 15, 0, 0"
            HalfExpandedRatio="0.50"
            ContentPadding="10" />

    </Grid>
</ContentPage>