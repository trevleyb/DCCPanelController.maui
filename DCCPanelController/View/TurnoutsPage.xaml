<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="turnouts_green.png"
    Title="Turnouts List"
    ios:Page.UseSafeArea="False"
    x:Class="DCCPanelController.View.TurnoutsPage"
    x:DataType="view:TurnoutsViewModel"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding AddTurnoutCommand}" IsEnabled="{Binding CanAddTurnout}"
                     IconImageSource="plus_circle.png"/>
        <ToolbarItem Command="{Binding EditTurnoutCommand}" IsEnabled="{Binding IsTurnoutSelected}"
                     IconImageSource="edit.png"/>
        <ToolbarItem Command="{Binding DeleteTurnoutCommand}" IsEnabled="{Binding IsTurnoutSelected}"
                     IconImageSource="minus_circle.png"/>
        <ToolbarItem Command="{Binding RefreshTurnoutsCommand}" IsEnabled="{Binding IsConnected}"
                     IconImageSource="refresh_cw.png"/>
        <ToolbarItem Command="{Binding ToggleConnectionCommand}" IconImageSource="{Binding ConnectionIcon}"
                     IsEnabled="{Binding IsConnectionAvailable}"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <Style x:Key="SelectableItemStyle" TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="DarkSeaGreen"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshTurnoutsCommand}">
        <Grid VerticalOptions="FillAndExpand">
            <CollectionView ItemsSource="{Binding Turnouts}" SelectedItem="{Binding SelectedTurnout}"
                            SelectionMode="Single">
                <CollectionView.Header>
                    <StackLayout>
                        <Grid
                            ColumnDefinitions="150,*,100"
                            HorizontalOptions="Fill"
                            Padding="5">
                            <Button
                                Grid.Column="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SortByColumnCommand}"
                                CommandParameter="{Binding LabelID}"
                                HorizontalOptions="Start"
                                Style="{StaticResource ButtonLabel}"
                                Text="{Binding ColumnLabelID}"
                                Margin="10,0,10,0"/>
                            <Button
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SortByColumnCommand}"
                                CommandParameter="{Binding LabelName}"
                                Style="{StaticResource ButtonLabel}"
                                Text="{Binding ColumnLabelName}"/>
                            <Button
                                Grid.Column="2"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SortByColumnCommand}"
                                CommandParameter="{Binding LabelState}"
                                HorizontalOptions="Start"
                                Style="{StaticResource ButtonLabel}"
                                Text="{Binding ColumnLabelState}"/>
                        </Grid>
                        <!-- This is your existing BoxView separator -->
                        <BoxView
                            BackgroundColor="{StaticResource Primary}"
                            HeightRequest="1"
                            HorizontalOptions="FillAndExpand"/>
                    </StackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                        <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                            <Label Text="No Turnout data available"/>
                        </StackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dataModel:Turnout">
                        <Grid Style="{StaticResource SelectableItemStyle}">
                            <StackLayout x:DataType="dataModel:Turnout">
                                <Grid ColumnDefinitions="150,*,100" Padding="5">
                                    <!-- <Grid.GestureRecognizers> -->
                                    <!--     <TapGestureRecognizer -->
                                    <!--         Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=EditTurnoutCommand, x:DataType=view:TurnoutsViewModel}" -->
                                    <!--         CommandParameter="{Binding .}"/> -->
                                    <!-- </Grid.GestureRecognizers> -->

                                    <Label
                                        Grid.Column="0"
                                        HorizontalOptions="Start"
                                        LineBreakMode="NoWrap"
                                        Margin="10,0,10,0"
                                        Style="{StaticResource MediumLabel}"
                                        Text="{Binding Id}"
                                        VerticalOptions="Center"/>
                                    <Label
                                        Grid.Column="1"
                                        FontAttributes="Bold"
                                        Style="{StaticResource MediumLabel}"
                                        Text="{Binding Name}"
                                        VerticalOptions="Center"/>
                                    <components:TurnoutStateControl
                                        IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=ConnectionService.IsConnected, x:DataType=view:TurnoutsViewModel}"
                                        CanToggleState="true"
                                        Grid.Column="2"
                                        Margin="0,0,10,0"
                                        State="{Binding State}"
                                        StateChangedCommand="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SendTurnoutStateCommand, x:DataType=view:TurnoutsViewModel}"
                                        Turnout="{Binding .}"/>
                                </Grid>

                                <BoxView
                                    BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="1"
                                    HorizontalOptions="FillAndExpand"/>
                            </StackLayout>
                        </Grid>
                        <!--     </SwipeView.Content> -->
                        <!-- </SwipeView> -->
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </RefreshView>

</ContentPage>