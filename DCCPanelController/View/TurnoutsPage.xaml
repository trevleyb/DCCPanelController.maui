<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="turnouts_green.png"
    Title="Turnouts"
    ios:Page.UseSafeArea="False"
    x:Class="DCCPanelController.View.TurnoutsPage"
    x:DataType="view:TurnoutsViewModel"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:navigationDrawer="http://schemas.syncfusion.com/maui/toolkit"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
    xmlns:accessories="clr-namespace:DCCPanelController.Models.DataModel.Accessories">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding AddTurnoutCommand}" IconImageSource="plus_circle_active.png" />

        <ToolbarItem
            Command="{Binding DeleteTurnoutCommand}" IsEnabled="{Binding IsTurnoutSelected}"
            IconImageSource="{Binding IsTurnoutSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=minus_circle}" />

        <ToolbarItem Command="{Binding EditTurnoutCommand}" IsEnabled="{Binding IsTurnoutSelected}"
                     IconImageSource="{Binding IsTurnoutSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}" />

        <ToolbarItem Command="{Binding RefreshTurnoutsCommand}" IsEnabled="{Binding IsConnected}"
                     IconImageSource="{Binding IsConnected, Converter={StaticResource BoolToIcon}, ConverterParameter=refresh_cw}" />

        <ToolbarItem
            Command="{Binding ToggleConnectionCommand}"
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource ConnectionIconConverter}">
                    <Binding Path="IsConnectionAvailable" />     <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="ConnectionState" />           <!-- Parameter 2: bool for name selection -->
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <converters:ShowConnectingStateConverter x:Key="ShowConnectingStateConverter"/>
        <Style x:Key="SelectableItemStyle" TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="LightGray" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <StackLayout x:Name="MainStackLayout">
            <Grid
                ColumnDefinitions="120,*,100, 80"
                HorizontalOptions="Fill">
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelID}"
                    Grid.Column="0"
                    HorizontalOptions="CenterAndExpand"
                    Margin="10,0,0,0"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelID}" />
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelName}"
                    Grid.Column="1"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelName}" />
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelState}"
                    Grid.Column="2"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelState}" />
                
                <Label Text="Source"
                       Grid.Column="3"
                       Style="{StaticResource ColumnLabel}"/>
            </Grid>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />

            <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshTurnoutsCommand}">
                <Grid VerticalOptions="FillAndExpand"
                      IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, x:DataType=view:TurnoutsViewModel, Path=IsConnected}">

                    <CollectionView ItemsSource="{Binding Turnouts}" SelectionMode="Single"
                                    SelectedItem="{Binding SelectedTurnout}">
                        <CollectionView.EmptyView>
                            <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                                <Border WidthRequest="350" HeightRequest="100" StrokeShape="RoundRectangle 15"
                                        BackgroundColor="WhiteSmoke">
                                    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                                        <Label IsVisible="{Binding IsSupported}" Text="No Turnout data available."
                                               VerticalOptions="Center" HorizontalOptions="Center" />
                                        <Label IsVisible="{Binding IsNotSupported}"
                                               Text="The current server type does not support Turnouts."
                                               VerticalOptions="Center" HorizontalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="accessories:Turnout">
                                <Grid>
                                    <StackLayout Padding="0">
                                        <Grid ColumnDefinitions="120,*,100,80" Margin="0,5,0,5" Padding="0">
                                            <Label
                                                Grid.Column="0"
                                                Margin="10,0,0,0"
                                                HorizontalOptions="Start"
                                                LineBreakMode="NoWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Id}"
                                                VerticalOptions="Center" />
                                            <Label
                                                FontAttributes="Bold"
                                                Grid.Column="1"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Name}"
                                                VerticalOptions="Center" />
                                            <Label
                                                IsVisible="False"
                                                Grid.Column="2"
                                                HorizontalOptions="Start"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding State}"
                                                VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, x:DataType=view:TurnoutsViewModel, Path=IsConnected}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1.00" />
                                                    </DataTrigger>

                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, x:DataType=view:TurnoutsViewModel, Path=IsConnected}"
                                                                 Value="False">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>

                                                    <DataTrigger
                                                        Binding="{Binding State}"
                                                        TargetType="Label"
                                                        Value="Closed">
                                                        <Setter Property="TextColor" Value="Green" />
                                                        <Setter Property="Text" Value="Closed" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                        Binding="{Binding State}"
                                                        TargetType="Label"
                                                        Value="Thrown">
                                                        <Setter Property="TextColor" Value="Red" />
                                                        <Setter Property="Text" Value="Thrown" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SendTurnoutStateCommand}"
                                                        CommandParameter="{Binding .}"
                                                        x:DataType="{x:Type view:TurnoutsViewModel}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <components:TurnoutStateControl
                                                StateChangedCommand="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SendTurnoutStateCommand, x:DataType=view:TurnoutsViewModel}"
                                                InputTransparent="False"
                                                IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=IsConnected, x:DataType=view:TurnoutsViewModel}"
                                                CanToggleState="true"
                                                Grid.Column="2"
                                                Margin="0,0,10,0"
                                                State="{Binding State}"
                                                Turnout="{Binding .}">
                                                <components:TurnoutStateControl.Triggers>
                                                    <DataTrigger TargetType="components:TurnoutStateControl"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, x:DataType=view:TurnoutsViewModel, Path=IsConnected}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1.00" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="components:TurnoutStateControl"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, x:DataType=view:TurnoutsViewModel, Path=IsConnected}"
                                                                 Value="False">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>
                                                </components:TurnoutStateControl.Triggers>
                                                <components:TurnoutStateControl.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type view:TurnoutsViewModel}}, Path=SendTurnoutStateCommand}"
                                                        CommandParameter="{Binding .}"
                                                        x:DataType="{x:Type view:TurnoutsViewModel}" />
                                                </components:TurnoutStateControl.GestureRecognizers>
                                            </components:TurnoutStateControl>
                                            
                                            <Label
                                                Grid.Column="3"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Source}"
                                                VerticalOptions="Center" />

                                        </Grid>
                                        <BoxView
                                            BackgroundColor="{StaticResource Primary}"
                                            HeightRequest="1"
                                            HorizontalOptions="FillAndExpand" />
                                    </StackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>

            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />

        </StackLayout>


