<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    Title="Test Panel Page"
    iOsSpecific:Page.UseSafeArea="True"
    x:Class="DCCPanelController.View.TestPanelPage"
    x:DataType="view:TestPanelPageModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:iOsSpecific="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Clicked="ToggleDesignMode"
            IconImageSource="edit.png"
            x:Name="DesignModeToolbar" />
        <ToolbarItem
            Clicked="ToggleEditMode"
            IconImageSource="edit.png"
            x:Name="EditModeToolbar" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid
            BackgroundColor="Coral"
            HorizontalOptions="Fill"
            RowDefinitions="auto,*"
            VerticalOptions="Fill">

            <StackLayout
                Grid.Row="0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <Label HorizontalOptions="Center" Margin="10">Test Panel Page</Label>
                <Button
                    Clicked="Button_OnClicked"
                    HorizontalOptions="Center"
                    Margin="10"
                    Text="Test"
                    WidthRequest="100" />
            </StackLayout>
            <Grid
                BackgroundColor="Transparent"
                Grid.Row="1"
                HorizontalOptions="Fill"
                Margin="10"
                VerticalOptions="Fill">
                <view:ControlPanelView
                    BackgroundColor="Transparent"
                    DesignMode="{Binding Source={RelativeSource AncestorType={x:Type view:TestPanelPageModel}}, x:DataType=view:TestPanelPageModel, Path=DesignMode}"
                    EditMode="{Binding Source={RelativeSource AncestorType={x:Type view:TestPanelPageModel}}, x:DataType=view:TestPanelPageModel, Path=EditMode}"
                    HorizontalOptions="Fill"
                    Panel="{Binding Source={RelativeSource AncestorType={x:Type view:TestPanelPageModel}}, x:DataType=view:TestPanelPageModel, Path=Panel}"
                    VerticalOptions="Fill"
                    x:Name="PanelView" />
            </Grid>

        </Grid>
    </ContentPage.Content>
</ContentPage>