<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DCCPanelController.View.Welcome">
    <ContentPage.Content>
        <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand" Padding="20">
            <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand" Padding="20">
                <Label HorizontalOptions="Center" Text="Welcome to the DCC Panel Controller!" FontAttributes="Bold" />
                <Label HorizontalOptions="Center" Text="  " />
                <Label HorizontalOptions="Center" Text="This page will populate once you have created panels and turnout control. To get started, head over to the instructions page and then to Settings to connect to your WiThrottle server." />
                <Label HorizontalOptions="Center" Text="  " />
            </StackLayout>
            <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand" Padding="20">
                <Button Style="{StaticResource ButtonOutline}" Text="Instructions" Margin="0,10,0,10" Clicked="ButtonInstructions_OnClicked" />
                <Button Style="{StaticResource ButtonOutline}" Text="About" Margin="0,10,0,10" Clicked="ButtonAbout_OnClicked" />
            </StackLayout>
        </StackLayout>

    </ContentPage.Content>
</ContentPage>