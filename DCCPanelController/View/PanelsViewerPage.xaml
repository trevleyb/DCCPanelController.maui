<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    Title="{Binding SelectedPanel.Title, FallbackValue='DCC Panel Controller'}"
    x:Class="DCCPanelController.View.PanelsViewerPage"
    x:DataType="view:PanelsViewerViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding EditPanelCommand}"
            IconImageSource="edit.png"
            IsEnabled="{Binding IsPanelSelected}"
            Text="Edit" />
        <ToolbarItem />
        <ToolbarItem
            Command="{Binding AddPanelCommand}"
            IconImageSource="plus_circle.png"
            Text="Add" />
        <ToolbarItem
            Command="{Binding DuplicatePanelCommand}"
            IconImageSource="copy.png"
            IsEnabled="{Binding IsPanelSelected}"
            Text="Duplicate" />
        <ToolbarItem
            Command="{Binding DeletePanelCommand}"
            IconImageSource="trash_2.png"
            IsEnabled="{Binding IsPanelSelected}"
            Text="Delete" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" x:Name="LeftPanelColumn" />
                <ColumnDefinition Width="2" x:Name="PanelEdge" />
                <ColumnDefinition Width="*" x:Name="RightPanelColumn" />
            </Grid.ColumnDefinitions>

            <CollectionView
                BackgroundColor="WhiteSmoke"
                IsVisible="{Binding IsSidePanelOpen}"
                ItemsSource="{Binding Panels}"
                SelectedItem="{Binding SelectedPanel, Mode=TwoWay}"
                SelectionChangedCommand="{Binding SelectionChangedCommand}"
                SelectionMode="Single"
                x:Name="PanelsList">

                <CollectionView.EmptyView>
                    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
                        <StackLayout HorizontalOptions="Fill" VerticalOptions="Center">
                            <Label HorizontalOptions="Center" Text="No Panels were found." />
                            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                                <Label Text="Please use" VerticalOptions="Center" />
                                <ImageButton
                                    Command="{Binding AddPanelCommand}"
                                    Margin="-5,0,-5,0"
                                    Scale="0.50"
                                    Source="plus_circle.png">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </Image.Behaviors>
                                </ImageButton>
                                <Label Text="to add a new Panel." VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </StackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Panel">
                        <StackLayout
                            HeightRequest="35"
                            Margin="10"
                            Padding="10"
                            Spacing="10">
                            <StackLayout.GestureRecognizers>
                                <DragGestureRecognizer DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=DragPanelCommand}" DragStartingCommandParameter="{Binding}" />
                                <DropGestureRecognizer
                                    DragLeaveCommand="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=DragPanelLeaveCommand}"
                                    DragLeaveCommandParameter="{Binding}"
                                    DragOverCommand="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=DragPanelOverCommand}"
                                    DragOverCommandParameter="{Binding}"
                                    DropCommand="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=DropPanelCommand}"
                                    DropCommandParameter="{Binding}" />
                            </StackLayout.GestureRecognizers>
                            <Label
                                FontSize="15"
                                Text="{Binding Name}"
                                TextColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                            <Label
                                FontSize="10"
                                Text="{Binding Description}"
                                TextColor="{StaticResource PrimaryDisabled}"
                                VerticalOptions="Center" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView
                BackgroundColor="{StaticResource PrimaryDisabled}"
                Grid.Column="1"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsWideMode}"
                VerticalOptions="Fill" />

            <Grid
                Grid.Column="2"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsWideMode}"
                VerticalOptions="Fill">
                <Grid
                    ColumnDefinitions="*"
                    Margin="10"
                    RowDefinitions="*,Auto">
                    <ActivityIndicator
                        Grid.Column="0"
                        Grid.Row="0"
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsBusy}"
                        VerticalOptions="Center" />

                    <view:ControlPanelView
                        DesignMode="false"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=IsPanelSelected}"
                        Panel="{Binding Source={RelativeSource AncestorType={x:Type view:PanelsViewerViewModel}}, x:DataType=view:PanelsViewerViewModel, Path=SelectedPanel}"
                        ShowGrid="false"
                        ShowTrackErrors="False"
                        TrackPieceDoubleTapped="ControlPanelView_OnTrackPieceDoubleTapped"
                        TrackPieceTapped="ControlPanelView_OnTrackPieceTapped"
                        VerticalOptions="Fill"
                        x:Name="ControlPanelView" />
                </Grid>
            </Grid>
        </Grid>

    </ContentPage.Content>

</ContentPage>


