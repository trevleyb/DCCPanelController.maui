<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.PropertyPages.PanelPropertyPage"
    x:DataType="model:Panel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary />
    </ContentPage.Resources>

    <ContentPage.Content>
        <Border
            Background="White"
            HeightRequest="600"
            HorizontalOptions="Center"
            Stroke="{StaticResource Primary}"
            StrokeShape="RoundRectangle 10,10,10,10"
            StrokeThickness="3"
            VerticalOptions="Center"
            WidthRequest="500">

            <StackLayout>
                <Grid
                    BackgroundColor="{StaticResource Primary}"
                    ColumnDefinitions="*,auto"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        Margin="10,0,0,0"
                        Style="{StaticResource LargeLabel}"
                        Text="Panel Properties"
                        TextColor="White"
                        VerticalOptions="Center" />
                    <ImageButton
                        Aspect="Center"
                        Grid.Column="1"
                        HeightRequest="30"
                        Source="info.png"
                        WidthRequest="25" />
                </Grid>

                <VerticalStackLayout Margin="10">
                    <!--  Panel Name  -->
                    <HorizontalStackLayout Margin="0,5,0,5">
                        <Label
                            Text="Panel Name"
                            VerticalOptions="Center"
                            WidthRequest="100" />
                        <Entry
                            HorizontalOptions="FillAndExpand"
                            Placeholder="Enter Panel Name"
                            Text="{Binding Name}"
                            WidthRequest="150" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Margin="0,5,0,5">
                        <Label
                            Text="Description"
                            VerticalOptions="Center"
                            WidthRequest="100" />
                        <Entry
                            HorizontalOptions="FillAndExpand"
                            Placeholder="Panel Description"
                            Text="{Binding Description}"
                            WidthRequest="350" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout>

                        <VerticalStackLayout>
                            <!--  Panel Columns  -->
                            <HorizontalStackLayout Margin="0,5,0,5">
                                <Label
                                    Text="Columns"
                                    VerticalOptions="Center"
                                    WidthRequest="100" />
                                <Entry
                                    Keyboard="Numeric"
                                    Margin="0,0,10,0"
                                    Text="{Binding Cols}"
                                    TextChanged="Cols_OnTextChanged"
                                    VerticalOptions="Center"
                                    WidthRequest="50" />
                                <Stepper
                                    HorizontalOptions="FillAndExpand"
                                    Increment="1"
                                    Maximum="48"
                                    Minimum="8"
                                    Value="{Binding Cols}"
                                    x:Name="ColsStepper" />
                            </HorizontalStackLayout>

                            <!--  Panel Rows  -->
                            <HorizontalStackLayout Margin="0,5,0,5">
                                <Label
                                    Text="Rows"
                                    VerticalOptions="Center"
                                    WidthRequest="100" />
                                <Entry
                                    Keyboard="Numeric"
                                    Margin="0,0,10,0"
                                    Text="{Binding Rows}"
                                    TextChanged="Rows_OnTextChanged"
                                    VerticalOptions="Center"
                                    WidthRequest="50" />
                                <Stepper
                                    HorizontalOptions="FillAndExpand"
                                    Increment="1"
                                    Maximum="48"
                                    Minimum="8"
                                    Value="{Binding Rows}"
                                    x:Name="RowsStepper" />
                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Margin="5,5,5,5"
                            Padding="10"
                            WidthRequest="80">
                            <Label
                                HorizontalOptions="Center"
                                Style="{StaticResource SmallLabel}"
                                Text="Panel Ratio"
                                VerticalOptions="Center" />
                            <Label
                                HorizontalOptions="Center"
                                IsEnabled="False"
                                Margin="0,10,0,0"
                                Style="{StaticResource LargeLabel}"
                                Text="{Binding PanelRatio}"
                                VerticalOptions="Center" />
                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                    <BoxView
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="2"
                        HorizontalOptions="Fill"
                        Margin="0,15,0,15" />

                    <Grid
                        ColumnDefinitions="*"
                        HeightRequest="20"
                        Margin="0,-5,0,5"
                        VerticalOptions="Center">
                        <HorizontalStackLayout Grid.Column="0" HeightRequest="20">
                            <Label
                                FontAttributes="Bold"
                                HorizontalOptions="Start"
                                Style="{StaticResource MediumLabel}"
                                Text="Panel Colors" />
                            <Label
                                HorizontalOptions="Start"
                                Style="{StaticResource MediumLabel}"
                                Text=" (scroll for more colors)" />
                            <ImageButton
                                Aspect="Center"
                                Clicked="ResetColorsClicked"
                                Height="25"
                                Margin="10,0,0,0"
                                Source="refresh_cw.png"
                                Width="25" />
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="0.5"
                        HorizontalOptions="Fill"
                        Margin="0,0,0,5" />

                    <ScrollView Orientation="Vertical" VerticalScrollBarVisibility="Always">
                        <StackLayout>
                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="Background"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=BackgroundColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="Track Border"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=BorderColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="MainLine Track"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=MainLineColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="BranchLine Track"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=BranchLineColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="Diverging Track"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=DivergingColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="Button Border"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=ButtonBorder, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="Button(On)"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=ButtonOnColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="Button(off)"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=ButtonOffColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="Occupied Track"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=OccupiedColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="Hidden Track"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=HiddenColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,20,5">
                                    <Label
                                        Text="Terminator"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=TerminatorColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Margin="0,5,0,5">
                                    <Label
                                        Text="Continuation"
                                        VerticalOptions="Center"
                                        WidthRequest="120" />
                                    <components:ColorPickerButton
                                        HeightRequest="30"
                                        SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type model:Panel}}, Path=ContinuationColor, Mode=TwoWay}"
                                        VerticalOptions="Center"
                                        WidthRequest="100" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                        </StackLayout>
                    </ScrollView>

                </VerticalStackLayout>

                <Button
                    Clicked="ClosePropertyPage"
                    HorizontalOptions="Center"
                    Margin="0,5,0,0"
                    Style="{StaticResource ButtonOutline}"
                    Text="Close"
                    VerticalOptions="End"
                    WidthRequest="150" />

            </StackLayout>
        </Border>
    </ContentPage.Content>
</ContentPage>