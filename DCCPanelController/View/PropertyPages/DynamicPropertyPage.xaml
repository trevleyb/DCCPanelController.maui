<!--  PanelPropertyPage.xaml  -->
<ContentPage
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.PropertyPages.DynamicPropertyPage"
    x:DataType="propertyPages:DynamicPropertyPageViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:propertyPages="clr-namespace:DCCPanelController.View.PropertyPages"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModel="clr-namespace:DCCPanelController.View.PropertyPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Content>
        <Border
            Background="White"
            HorizontalOptions="Center"
            MaximumHeightRequest="500"
            MaximumWidthRequest="500"
            Stroke="{StaticResource Primary}"
            StrokeShape="RoundRectangle 10,10,10,10"
            StrokeThickness="3"
            VerticalOptions="Fill">

            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid
                    BackgroundColor="{StaticResource Primary}"
                    ColumnDefinitions="*,40"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Fill"
                        Margin="10,0,0,0"
                        Style="{StaticResource LargeLabel}"
                        Text="{Binding PropertyName}"
                        TextColor="White"
                        VerticalOptions="Center" />
                    <ImageButton
                        Aspect="Center"
                        Grid.Column="1"
                        HeightRequest="25"
                        HorizontalOptions="End"
                        Source="info.png"
                        WidthRequest="25">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="White" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </Grid>
                <ScrollView
                    HeightRequest="380"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">
                    <VerticalStackLayout
                        HorizontalOptions="Fill"
                        Margin="10,20,0,0"
                        VerticalOptions="Fill"
                        x:Name="PropertyContainer" />
                </ScrollView>
                <Button
                    Clicked="ClosePropertyPage"
                    HorizontalOptions="Center"
                    Margin="10,20,10,20"
                    Style="{StaticResource ButtonOutline}"
                    Text="Close"
                    VerticalOptions="End"
                    WidthRequest="150" />
            </VerticalStackLayout>
        </Border>
    </ContentPage.Content>
</ContentPage>