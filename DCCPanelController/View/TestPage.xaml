<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:DCCPanelController.View.Components"
             xmlns:view="clr-namespace:DCCPanelController.View"
             xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
             xmlns:tileSelectors="clr-namespace:DCCPanelController.View.TileSelectors"
             x:DataType="view:TestPageViewModel"
             BindingContext="TestPageViewModel"
             x:Class="DCCPanelController.View.TestPage">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="plus_circle.png"
            Command="{Binding SetModeCommand}">
        </ToolbarItem>

        <ToolbarItem
            x:Name="ModeToolbar"
            IsEnabled="{Binding CanSetModes}"
            Text="Mode"
            IconImageSource="{Binding CanSetModes, Converter={StaticResource BoolToIcon}, ConverterParameter=move}"
            Command="{Binding SetModeCommand}">
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <!-- IsEnabled="{Binding CanSetModes}" -->

    <ContentPage.Content>
        <Grid RowDefinitions="*,200" ColumnDefinitions="*,100">
            <Grid Grid.Column="0" Grid.Row="1" ColumnSpan="2" WidthRequest="300" HeightRequest="120" HorizontalOptions="Center">
                <tileSelectors:PillSelectorPanel x:Name="PillSelectorContainer" OnDockSideChanged="PillSelectorContainer_OnOnDockSideChanged" IsVisible="False" />
            </Grid>

            <Grid Grid.Column="1" Grid.Row="0" RowSpan="2"  HorizontalOptions="Center">
                <tileSelectors:SideSelectorPanel x:Name="SideSelectorContainer" OnDockSideChanged="SideSelectorContainer_OnOnDockSideChanged" IsVisible="True"/>
            </Grid>
        </Grid>

    </ContentPage.Content>
</ContentPage>