<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:DCCPanelController.View.Components"
             xmlns:view="clr-namespace:DCCPanelController.View"
             xmlns:converters="clr-namespace:DCCPanelController.View.Converters"
             xmlns:tileSelectors="clr-namespace:DCCPanelController.View.TileSelectors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:progressBar="clr-namespace:Syncfusion.Maui.Toolkit.ProgressBar;assembly=Syncfusion.Maui.Toolkit"
             x:DataType="view:TestPageViewModel"
             BindingContext="TestPageViewModel"
             x:Class="DCCPanelController.View.TestPage">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="plus_circle.png"
            Command="{Binding SetModeCommand}">
        </ToolbarItem>

        <ToolbarItem
            x:Name="ModeToolbar"
            IsEnabled="{Binding CanSetModes}"
            Text="Mode"
            IconImageSource="{Binding CanSetModes, Converter={StaticResource BoolToIcon}, ConverterParameter=move}"
            Command="{Binding SetModeCommand}">
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <!-- IsEnabled="{Binding CanSetModes}" -->

    <ContentPage.Content>

        <StackLayout>
            <progressBar:SfCircularProgressBar
                 WidthRequest="100"
                 HeightRequest="100"
                 TrackThickness="4"
                 ProgressThickness="6"
                 TrackFill="{StaticResource PrimaryDisabled}"
                 ProgressFill="{StaticResource Primary}"
                 BackgroundColor="Transparent"
                 IndeterminateAnimationEasing="{x:Static Easing.Linear}"
                 SegmentCount="10"
                 SegmentGapWidth="2"
                 IsIndeterminate="True">
                <Label Text="Loading"/>
            </progressBar:SfCircularProgressBar>
            
            <Grid BackgroundColor="WhiteSmoke"
                  Opacity="0.75"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">
                <Grid.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="DynamicGridPanUpdated"/>
                </Grid.GestureRecognizers>  

                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 25"
                        Stroke="{StaticResource Primary}"
                        StrokeThickness="2"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="200"
                        HeightRequest="120"
                        Margin="20"
                        Padding="20">

                    <StackLayout
                        HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                        <ActivityIndicator IsRunning="true" Color="{StaticResource Primary}"/>
                        <Label Text="Loading Panel Editor"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="15"
                               TextColor="Black"/>
                    </StackLayout>
                </Border>
            </Grid>
            
            <Border Margin="0,2,0,0"
                    BackgroundColor="White"
                    HorizontalOptions="Center" WidthRequest="30" HeightRequest="30" StrokeThickness="3"
                    Stroke="{StaticResource Primary}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_OnTapped1" NumberOfTapsRequired="1"/>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_OnTapped2" NumberOfTapsRequired="2"/>
                </Border.GestureRecognizers>
                
                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultBackgroundColor="Red"
                        DefaultOpacity="0.50"
                        HoveredBackgroundColor="Blue"
                        HoveredOpacity="1.00"
                        PressedBackgroundColor="Gray"
                        PressedOpacity="0.75"
                        DefaultScale="1.0"
                        HoveredScale="2.00"
                        PressedScale="0.75"/>
                </Border.Behaviors>
            </Border>

            <Grid RowDefinitions="*,200" ColumnDefinitions="*,100">
                <Grid Grid.Column="0" Grid.Row="1" ColumnSpan="2" WidthRequest="300" HeightRequest="120"
                      HorizontalOptions="Center">
                    <tileSelectors:PillSelectorPanel x:Name="PillSelectorContainer"
                                                     OnDockSideChanged="PillSelectorContainer_OnOnDockSideChanged"
                                                     IsVisible="False"/>
                </Grid>

                <Grid Grid.Column="1" Grid.Row="0" RowSpan="2" HorizontalOptions="Center">
                    <tileSelectors:SideSelectorPanel x:Name="SideSelectorContainer"
                                                     OnDockSideChanged="SideSelectorContainer_OnOnDockSideChanged"
                                                     IsVisible="True"/>
                </Grid>
            </Grid>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>