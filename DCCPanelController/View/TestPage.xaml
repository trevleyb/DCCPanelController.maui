                        <Border Grid.Column="2" Grid.Row="2" Margin="5" Padding="5" StrokeThickness="2" Stroke="Black"
                                BackgroundColor="Azure"/>
                        <Border Grid.Column="3" Grid.Row="2" Margin="5" Padding="5" StrokeThickness="2" Stroke="Black"
                                BackgroundColor="Azure"/>
                        <Border Grid.Column="4" Grid.Row="2" Margin="5" Padding="5" StrokeThickness="2" Stroke="Black"
                                BackgroundColor="Azure"/>

                        <Border Grid.Column="0" Grid.Row="3" Margin="5" Padding="5" StrokeThickness="2" Stroke="Black"
