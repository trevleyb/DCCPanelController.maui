<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.View.Properties.PanelProperties.PanelPropertyPage"
    x:DataType="panelProperties:PanelPropertyViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:panelProperties="clr-namespace:DCCPanelController.View.Properties.PanelProperties"
    SizeChanged="PanelPropertyPage_SizeChanged"> <!-- Add SizeChanged handler -->

    <ContentView.Content>
        <VerticalStackLayout>
            <!--  Panel Name  -->
            <HorizontalStackLayout>
                <Label Text="Panel Name" VerticalOptions="Center" WidthRequest="100"/>
                <Entry HorizontalOptions="FillAndExpand" Placeholder="Enter Panel Name" Text="{Binding Panel.Id}"
                       HeightRequest="35" WidthRequest="150"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout>
                <Label Text="Description" VerticalOptions="Center" WidthRequest="100"/>
                <Entry HorizontalOptions="FillAndExpand" Placeholder="Panel Description"
                       Text="{Binding Panel.Description}" HeightRequest="35" WidthRequest="350"/>
            </HorizontalStackLayout>
            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="2" HorizontalOptions="Fill"
                     Margin="0,5,0,5"/>

            <HorizontalStackLayout>
                <VerticalStackLayout>
                    <HorizontalStackLayout Margin="0,5,0,5">
                        <Label Text="Columns" VerticalOptions="Center" WidthRequest="100"/>
                        <Entry Keyboard="Numeric" Margin="0,0,10,0" Text="{Binding Panel.Cols, Mode=TwoWay}"
                               TextChanged="Cols_OnTextChanged" VerticalOptions="Center" WidthRequest="30"/>
                        <Stepper HorizontalOptions="FillAndExpand" Increment="1" Maximum="48" Minimum="8"
                                 Value="{Binding Panel.Cols, Mode=TwoWay}" x:Name="ColsStepper"/>
                    </HorizontalStackLayout>
                    <!--  Panel Rows  -->
                    <HorizontalStackLayout Margin="0,5,0,5">
                        <Label Text="Rows" VerticalOptions="Center" WidthRequest="100"/>
                        <Entry Keyboard="Numeric" Margin="0,0,10,0" Text="{Binding Panel.Rows, Mode=TwoWay}"
                               TextChanged="Rows_OnTextChanged" VerticalOptions="Center" WidthRequest="30"/>
                        <Stepper HorizontalOptions="FillAndExpand" Increment="1" Maximum="48" Minimum="8"
                                 Value="{Binding Panel.Rows, Mode=TwoWay}" x:Name="RowsStepper"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <VerticalStackLayout Margin="30,5,5,5" Padding="10" WidthRequest="80">
                    <Label HorizontalOptions="Center" Style="{StaticResource SmallLabel}" Text="Panel Ratio"
                           VerticalOptions="Center"/>
                    <Label HorizontalOptions="Center" IsEnabled="False" Margin="0,0,0,0"
                           Style="{StaticResource Headline}" Text="{Binding Panel.PanelRatio}" VerticalOptions="Center"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="2" HorizontalOptions="Fill"
                     Margin="0,0,0,15"/>

            <ScrollView VerticalScrollBarVisibility="Always">
                <CollectionView ItemsSource="{Binding ColorSettings}" VerticalScrollBarVisibility="Always">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="{Binding ColorGridSpan}"
                                         VerticalItemSpacing="5"
                                         HorizontalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="panelProperties:ColorSettingItemViewModel">
                            <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center" Padding="0,2">
                                <Label Grid.Column="0"
                                       Text="{Binding Source={RelativeSource AncestorType={x:Type panelProperties:ColorSettingItemViewModel}}, Path=LabelText, Mode=OneWay}"
                                       VerticalOptions="Center"
                                       WidthRequest="130"/>
                                <components:ColorPickerButton
                                    Grid.Column="1"
                                    AllowsNoColor="{Binding Source={RelativeSource AncestorType={x:Type panelProperties:ColorSettingItemViewModel}}, Path=AllowsNoColor, Mode=OneWay}"
                                    HeightRequest="30"
                                    SelectedColor="{Binding Source={RelativeSource AncestorType={x:Type panelProperties:ColorSettingItemViewModel}}, Path=ColorValue, Mode=TwoWay}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"
                                    WidthRequest="120"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="2" HorizontalOptions="Fill"
                     Margin="0,10,0,10"/>

            <Grid HeightRequest="40" ColumnDefinitions="*" HorizontalOptions="Fill" VerticalOptions="Center">
                <FlexLayout Grid.Column="0" HorizontalOptions="Center" AlignContent="SpaceEvenly" Wrap="NoWrap">
                    <Button Command="{Binding ResetDefaultsClickedCommand}"
                            FontSize="11" Margin="5,1,1,5"
                            Text="Reset Defaults" WidthRequest="100"/>
                    <Button Command="{Binding ResetOverridesClickedCommand}"
                            FontSize="11" Margin="5,1,1,5"
                            Text="Clear Overrides" WidthRequest="120"/>
                    <Button Command="{Binding ToAllPanelsClickedCommand}"
                            FontSize="11" Margin="5,1,1,5"
                            Text="Copy To All" WidthRequest="100"/>
                </FlexLayout>
            </Grid>
            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="2" HorizontalOptions="Fill"
                     Margin="0,0,0,15"/>
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>