<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="DCCPanelController.View.Properties.DynamicProperties.DynamicTilePropertyPopupContent"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dynamicProperties="clr-namespace:DCCPanelController.View.Properties.DynamicProperties">

    <!-- Top-level container sized for a popup -->
    <Grid Padding="20,5,10,0" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="PropertyHost" Spacing="10" />
        </ScrollView>
    </Grid>
</ContentView>