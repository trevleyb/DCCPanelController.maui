<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="Details"
    x:Class="DCCPanelController.View.PanelDetailsPage"
    x:DataType="viewModel:PanelsDetailsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding SavePanelCommand}" IconImageSource="save.png" IsEnabled="{Binding IsNotBusy}" />
        <ToolbarItem Command="{Binding RestorePanelCommand}" IconImageSource="undo_circle.png"
                     IsEnabled="{Binding IsNotBusy}" />
        <ToolbarItem Command="{Binding ClearImageCommand}" IconImageSource="erase.png" IsEnabled="{Binding IsNotBusy}" />
        <ToolbarItem Command="{Binding AddNewTurnoutPointCommand}" IconImageSource="plus_circle.png"
                     IsEnabled="{Binding IsNotBusy}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="100,*,10">
        <StackLayout Grid.Row="0" HeightRequest="100">
            <Grid ColumnDefinitions="75,*,150" ColumnSpacing="10" RowDefinitions="20,auto" Margin="10,10,10,10">
                <Label Grid.Column="0" Grid.Row="0" Style="{StaticResource MediumLabel}"
                       TextColor="{StaticResource Primary}" Text="ID" />
                <Entry Grid.Column="0" Grid.Row="1" ClearButtonVisibility="WhileEditing" MaxLength="10"
                       Text="{Binding Panel.Id, Mode=TwoWay}">
                    <Entry.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="TextChanged" Command="{Binding ValidateCommand}" />
                    </Entry.Behaviors>
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding HasErrors}"
                                     Value="true">
                            <Setter Property="TextColor" Value="Red" />
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding HasErrors}"
                                     Value="false">
                            <Setter Property="TextColor" Value="Black" />
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Grid.Column="1" Grid.Row="0" Style="{StaticResource MediumLabel}"
                       TextColor="{StaticResource Primary}" Text="Name or Description" />
                <Entry Grid.Column="1" Grid.Row="1" ClearButtonVisibility="WhileEditing"
                       Text="{Binding Panel.Name, Mode=TwoWay}">
                    <Entry.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="TextChanged" Command="{Binding ValidateCommand}" />
                    </Entry.Behaviors>
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding HasErrors}"
                                     Value="true">
                            <Setter Property="TextColor" Value="Red" />
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding HasErrors}"
                                     Value="false">
                            <Setter Property="TextColor" Value="Black" />
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Grid>
            <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="1" HorizontalOptions="FillAndExpand" />
        </StackLayout>

        <ScrollView Grid.Row="1">
        <Grid x:Name="ImageGrid">
            <Image x:Name="SelectedImage"
                   Source="{Binding Panel.Image, Mode=TwoWay }"
                   Aspect="AspectFit"
                   BackgroundColor="{StaticResource PrimaryDisabled}"
                   IsVisible="{Binding HasImage}">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnImageTapped" />
                    </Image.GestureRecognizers>
                </Image>
            <AbsoluteLayout x:Name="SelectedImageGrid">
                <AbsoluteLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnImageGridTapped" />
                </AbsoluteLayout.GestureRecognizers>
            </AbsoluteLayout>
        </Grid>
        </ScrollView>

        <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Grid.Row="1" Padding="20" Spacing="20"
                     IsVisible="{Binding HasNoImage}">
            <Label HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Text="Select an Image for the Panel" Style="{StaticResource MediumLabel}" />
            <Grid ColumnDefinitions="*,*">
                <Button WidthRequest="250"
                        Margin="5,5,5,5" Clicked="FileSystemButton_OnClicked"
                        Style="{StaticResource ButtonOutline}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Grid.Column="0" Text="From File System"
                        IsVisible="{Binding HasNoImage}" />
                <Button WidthRequest="250"
                        Margin="5,5,5,5" Clicked="PhotosButton_OnClicked"
                        Style="{StaticResource ButtonOutline}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Grid.Column="1" Text="From Photos" IsVisible="{Binding HasNoImage}" />
            </Grid>
        </StackLayout>
    </Grid>
</ContentPage>

