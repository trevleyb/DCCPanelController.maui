<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DCCPanelController.View.ControlPanelView"
             x:DataType="viewModel:ControlPanelViewModel"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel">

    <Grid
        ColumnDefinitions="*"
        RowDefinitions="*"
        HorizontalOptions="Fill" 
        VerticalOptions="Fill">
        
        <Grid x:Name="MainGrid" 
              Padding="0" Margin="0"
              Grid.Column="0" Grid.Row="1"
              HorizontalOptions="Fill" 
              VerticalOptions="Fill">
            <AbsoluteLayout  
                x:Name="ControlPanelLayout"
                HorizontalOptions="Fill" 
                VerticalOptions="Fill">
                <Grid x:Name="DynamicGrid" 
                      BackgroundColor="Transparent"
                      WidthRequest="{Binding ViewWidth}"
                      HeightRequest="{Binding ViewHeight}"
                      AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                      AbsoluteLayout.LayoutFlags="PositionProportional" />
            </AbsoluteLayout>
        </Grid>
    </Grid>
</ContentView>