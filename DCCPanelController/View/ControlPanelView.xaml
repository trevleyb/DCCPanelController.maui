<ContentView
    x:Class="DCCPanelController.View.ControlPanelView"
    x:DataType="view:ControlPanelView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:helpers="clr-namespace:DCCPanelController.View.Helpers"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:ClassModifier="internal">

    <ContentView.Resources>
        <ResourceDictionary />
    </ContentView.Resources>

    <Grid
        HorizontalOptions="Fill"
        VerticalOptions="Fill"
        x:Name="MainGrid">
        <AbsoluteLayout
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            x:Name="ControlPanelLayout">
            <Grid
                AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                BackgroundColor="{Binding Path=BackgroundColor, Source={RelativeSource AncestorType={x:Type dataModel:Panel}}, FallbackValue=#FFFFFF}"
                HorizontalOptions="Center"
                Margin="5"
                VerticalOptions="Center"
                x:DataType="dataModel:Panel"
                x:Name="DynamicGrid" />
        </AbsoluteLayout>
    </Grid>
</ContentView>