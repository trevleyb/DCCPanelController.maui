<ContentView
    x:Name="ControlPanelViewRoot"
    x:Class="DCCPanelController.View.ControlPanelView"
    x:DataType="view:ControlPanelView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Resources>
        <ResourceDictionary/>
    </ContentView.Resources>

    <Grid
        x:Name="MainGrid"
        HorizontalOptions="Fill"
        VerticalOptions="Fill">
        <AbsoluteLayout
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            x:Name="ControlPanelLayout">
            <Grid x:Name="DynamicGrid"
                  AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                  AbsoluteLayout.LayoutFlags="PositionProportional"
                  HorizontalOptions="Center"
                  Margin="5"
                  VerticalOptions="Center">
            </Grid>
        </AbsoluteLayout>

        <ActivityIndicator
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsRunning="{Binding Source={x:Reference ControlPanelViewRoot}, Path=IsPanelDrawing}"
            IsVisible="{Binding Source={x:Reference ControlPanelViewRoot}, Path=IsPanelDrawing}"
            Color="{StaticResource Primary}"/>
    </Grid>

</ContentView>