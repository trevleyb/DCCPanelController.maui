<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DCCPanelController.View.ControlPanelView"
             x:DataType="view:ControlPanelView"
             xmlns:view="clr-namespace:DCCPanelController.View">

    <ContentView.Resources>
        <ResourceDictionary />
    </ContentView.Resources>

    <Grid x:Name="MainGrid" HorizontalOptions="Fill" VerticalOptions="Fill">
        <AbsoluteLayout
            x:Name="ControlPanelLayout"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
            <Grid x:Name="DynamicGrid"
                  BackgroundColor="Transparent"
                  HorizontalOptions="Center"
                  VerticalOptions="Center"
                  AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                  AbsoluteLayout.LayoutFlags="PositionProportional" />
        </AbsoluteLayout>
    </Grid>
</ContentView>