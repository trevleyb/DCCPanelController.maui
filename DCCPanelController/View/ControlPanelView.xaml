<ContentView
    x:Class="DCCPanelController.View.ControlPanelView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Resources>
        <ResourceDictionary/>
    </ContentView.Resources>

    <Grid
        HorizontalOptions="Fill"
        VerticalOptions="Fill"
        x:Name="MainGrid">
        <AbsoluteLayout
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            x:Name="ControlPanelLayout">
            <Grid
                AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                HorizontalOptions="Center"
                Margin="5"
                VerticalOptions="Center"
                x:DataType="dataModel:Panel"
                x:Name="DynamicGrid"/>
        </AbsoluteLayout>
    </Grid>
</ContentView>