<!--  PanelPropertyPage.xaml  -->
<ContentPage
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.PropertPages.DynamicPropertyPage"
    x:DataType="viewModel:DynamicPropertyPageViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Content>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Border
                Background="White"
                HorizontalOptions="Center"
                Stroke="{StaticResource Primary}"
                StrokeShape="RoundRectangle 10,10,10,10"
                StrokeThickness="3"
                VerticalOptions="Fill">
                <!--
                    MaximumHeightRequest="500"
                    WidthRequest="500"
                -->

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> 
                        <!--  Title block height  -->
                        <RowDefinition Height="*" />    
                        <!--  Scrollable content  -->
                        <RowDefinition Height="Auto" /> 
                        <!--  Button fixed at the bottom  -->
                    </Grid.RowDefinitions>

                    <Grid
                        BackgroundColor="{StaticResource Primary}"
                        ColumnDefinitions="*,auto"
                        Grid.Row="0"
                        VerticalOptions="Center">
                        <Label
                            Grid.Column="0"
                            Margin="10,0,0,0"
                            Style="{StaticResource LargeLabel}"
                            Text="{Binding PropertyName}"
                            TextColor="White"
                            VerticalOptions="Center" />
                        <ImageButton
                            Aspect="Center"
                            Grid.Column="1"
                            HeightRequest="25"
                            Source="info.png"
                            WidthRequest="25" />
                    </Grid>

                    <!-- <TableView x:Name="PropertyContainer" HasUnevenRows="True" /> -->
                    <ScrollView
                        Grid.Row="1"
                        HorizontalOptions="Fill"
                        VerticalScrollBarVisibility="Always">
                        <VerticalStackLayout
                            HorizontalOptions="Fill"
                            Margin="10,20,0,00"
                            x:Name="PropertyContainer" />
                    </ScrollView>

                    <Button
                        Clicked="ClosePropertyPage"
                        Grid.Row="2"
                        HorizontalOptions="Center"
                        Margin="0,20,0,20"
                        Style="{StaticResource ButtonOutline}"
                        Text="Close"
                        VerticalOptions="End"
                        WidthRequest="150" />
                </Grid>
            </Border>
        </Grid>
    </ContentPage.Content>
</ContentPage>