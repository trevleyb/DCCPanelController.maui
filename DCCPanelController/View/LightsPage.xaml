<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="route_active.png"
    Title="Lights List"
    ios:Page.UseSafeArea="False"
    x:Class="DCCPanelController.View.LightsPage"
    x:DataType="view:LightsViewModel"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bottomSheet="http://schemas.syncfusion.com/maui/toolkit">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding AddLightCommand}" IsEnabled="{Binding CanAddLight}" IconImageSource="{Binding CanAddLight, Converter={StaticResource BoolToIcon}, ConverterParameter=plus_circle}"/>

        <ToolbarItem
            Command="{Binding DeleteLightCommand}" IsEnabled="{Binding IsLightSelected}"
            IconImageSource="{Binding IsLightSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=minus_circle}"/>

        <ToolbarItem Command="{Binding EditLightCommand}" IsEnabled="{Binding IsLightSelected}"
                     IconImageSource="{Binding IsLightSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}"/>
        
        <ToolbarItem
            Command="{Binding RefreshLightsCommand}" IsEnabled="{Binding IsConnected}"
            IconImageSource="{Binding IsConnected, Converter={StaticResource BoolToIcon}, ConverterParameter=refresh_cw}"/>

        <ToolbarItem
            Command="{Binding ToggleConnectionCommand}"
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource ConnectionIconConverter}">
                    <Binding Path="IsConnectionAvailable"/>     <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="ConnectionState"/>           <!-- Parameter 2: bool for name selection -->
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>


    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <Style x:Key="SelectableItemStyle" TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="LightGrey"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>
    
    <Grid>
    <StackLayout x:Name="MainStackLayout">
        <Grid
            ColumnDefinitions="120,*,90"
            HorizontalOptions="Fill">
            <Button
                Command="{Binding SortByColumnCommand}"
                CommandParameter="{Binding LabelID}"
                Grid.Column="0"
                HorizontalOptions="CenterAndExpand"
                Margin="10,0,0,0"
                Style="{StaticResource ColumnLabel}"
                Text="{Binding ColumnLabelID}"/>
            <Button
                Command="{Binding SortByColumnCommand}"
                CommandParameter="{Binding LabelName}"
                Grid.Column="1"
                Style="{StaticResource ColumnLabel}"
                Text="{Binding ColumnLabelName}"/>
            <Button
                Command="{Binding SortByColumnCommand}"
                CommandParameter="{Binding LabelState}"
                Grid.Column="2"
                Style="{StaticResource ColumnLabel}"
                Text="{Binding ColumnLabelState}"/>
        </Grid>
        <BoxView
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="1"
            HorizontalOptions="FillAndExpand"/>
        
        <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshLightsCommand}">

            <Grid VerticalOptions="FillAndExpand"
                  IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, x:DataType=view:LightsViewModel, Path=IsConnected}">
                
                <CollectionView ItemsSource="{Binding Lights}" SelectionMode="Single" SelectedItem="{Binding SelectedLight}">
                    <CollectionView.EmptyView>
                        <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                            <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                                <Label IsVisible="{Binding IsSupported}" Text="No Lights available."/>
                                <Label IsVisible="{Binding IsNotSupported}"
                                       Text="The current server type does not support Lights."/>
                            </StackLayout>
                        </Grid>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dataModel:Light">
                            <!-- <Grid Style="{StaticResource SelectableItemStyle}"> -->
                            <Grid>
                            <StackLayout Padding="0">
                                <Grid ColumnDefinitions="120,*,70,15" Margin="0,5,0,5" Padding="0">
                                    <Label
                                        Grid.Column="0"
                                        Margin="10,0,0,0"
                                        HorizontalOptions="Start"
                                        LineBreakMode="NoWrap"
                                        Style="{StaticResource MediumLabel}"
                                        Text="{Binding Id}"
                                        VerticalOptions="Center"/>
                                    <Label
                                        FontAttributes="Bold"
                                        Grid.Column="1"
                                        HorizontalOptions="FillAndExpand"
                                        LineBreakMode="WordWrap"
                                        Style="{StaticResource MediumLabel}"
                                        Text="{Binding Name}"
                                        VerticalOptions="Center"/>
                                    <Label
                                        Grid.Column="2"
                                        HorizontalOptions="Start"
                                        Style="{StaticResource MediumLabel}"
                                        Text="{Binding State}"
                                        VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, x:DataType=view:LightsViewModel, Path=IsConnected}" Value="True">
                                                <Setter Property="Opacity" Value="1.00" />
                                            </DataTrigger>

                                            <DataTrigger TargetType="Label" Binding="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, x:DataType=view:LightsViewModel, Path=IsConnected}" Value="False">
                                                <Setter Property="Opacity" Value="0.35" />
                                            </DataTrigger>

                                            <DataTrigger
                                                Binding="{Binding State}"
                                                TargetType="Label"
                                                Value="true">
                                                <Setter Property="TextColor" Value="Green"/>
                                                <Setter Property="Text" Value="On"/>
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding State}"
                                                TargetType="Label"
                                                Value="false">
                                                <Setter Property="TextColor" Value="Red"/>
                                                <Setter Property="Text" Value="Off"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, Path=ToggleLightStateCommand}"
                                                CommandParameter="{Binding .}"
                                                x:DataType="{x:Type view:LightsViewModel}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Image
                                        Grid.Column="3"
                                        HeightRequest="32"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"
                                        WidthRequest="42">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, x:DataType=view:LightsViewModel, Path=IsConnected}" Value="True">
                                                <Setter Property="Opacity" Value="1.00" />
                                            </DataTrigger>

                                            <DataTrigger TargetType="Image" Binding="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, x:DataType=view:LightsViewModel, Path=IsConnected}" Value="False">
                                                <Setter Property="Opacity" Value="0.35" />
                                            </DataTrigger>

                                            <DataTrigger
                                                Binding="{Binding State}"
                                                TargetType="Image"
                                                Value="true">
                                                <Setter Property="Source" Value="light_active.png"/>
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding State}"
                                                TargetType="Image"
                                                Value="false">
                                                <Setter Property="Source" Value="light_inactive.png"/>
                                            </DataTrigger>
                                        </Image.Triggers>
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type view:LightsViewModel}}, Path=ToggleLightStateCommand}"
                                                CommandParameter="{Binding .}"
                                                x:DataType="{x:Type view:LightsViewModel}"/>
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                                <BoxView
                                    BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="1"
                                    HorizontalOptions="FillAndExpand"/>
                            </StackLayout>
                                </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>
        
        <BoxView
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="1"
            HorizontalOptions="FillAndExpand"/>
        
        <Grid HorizontalOptions="Center" VerticalOptions="End" Margin="10">
            <Label Text="You can create DCC Lights only if your DCC System supports this functionality."/>
        </Grid>

    </StackLayout>
        <!-- Bottom Sheet for editing the Connection Details -->
        <bottomSheet:SfBottomSheet
            x:Name="BottomSheet"
            CornerRadius="15, 15, 0, 0"
            HalfExpandedRatio="0.50" 
            ContentPadding="10"/>
    </Grid>
</ContentPage>