<?xml version="1.0" encoding="utf-8"?>

<ContentView
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.SensorsEditView"
    x:DataType="view:SensorsEditViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <StackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" Text="System Name (ID)" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5"  Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" IsEnabled="{Binding Sensor.IsEditable}" Text="{Binding Sensor.Id}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="User Name" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5"  Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" IsEnabled="{Binding Sensor.IsEditable}" Text="{Binding Sensor.Name}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="DCC Address" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}" WidthRequest="60">
                <Entry Keyboard="Numeric"  Style="{StaticResource EntryStyle}" Margin="5" HorizontalOptions="Fill" IsEnabled="{Binding Sensor.CanEditDccAddress}" Text="{Binding Sensor.DccAddress}">
                    <Entry.Behaviors>
                        <toolkit:NumericValidationBehavior
                            Flags="ValidateOnValueChanged"
                            MinimumValue="0"
                            MaximumValue="9999"
                            ValidStyle="{StaticResource ValidEntryStyle}"
                            InvalidStyle="{StaticResource InvalidEntryStyle}" />
                    </Entry.Behaviors>
                </Entry>
            </Border>
            <Label Margin="5,0,5,0" HorizontalOptions="Start" Text="Locked?" VerticalOptions="Center"/>
            <Switch Margin="5,0,5,0" IsToggled="{Binding Sensor.DccAddressLocked}"/>
        </HorizontalStackLayout>

        <BoxView Margin="0,10,0,10"
                 BackgroundColor="{StaticResource Primary}"
                 HeightRequest="1"
                 HorizontalOptions="FillAndExpand"/>

        <Label Text="Sensors are defined in your DCC system to trigger on certain events such as when a train is in a block of track. Sensors control Blocks and Blocks will show on the Panel as Occupied or UnOccupied."></Label>
    </StackLayout>
</ContentView>