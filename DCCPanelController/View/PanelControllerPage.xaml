<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    Title="DCC Panel Controller"
    x:Class="DCCPanelController.View.PanelControllerPage"
    x:DataType="view:PanelControllerPageViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:converters="clr-namespace:DCCPanelController.Helpers.Converters"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ColorFallbackConverter x:Key="ColorFallbackConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="IncZoom" IconImageSource="zoom_in.png" />
        <ToolbarItem Clicked="DecZoom" IconImageSource="zoom_out.png" />
        <ToolbarItem Text="{Binding ZoomFactor}" />
        <ToolbarItem Clicked="Refresh" IconImageSource="repeat.png" />
        <ToolbarItem
            Clicked="ShowGrid"
            IconImageSource="maximize_2.png"
            Text="Hide"
            ToolTipProperties.Text="Hide Bottom Tab Bar"
            x:Name="HideUnHide" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid>
            <view:PanelControllerView
                HorizontalOptions="Fill"
                Panel="{Binding Source={RelativeSource AncestorType={x:Type view:PanelControllerPageViewModel}}, x:DataType=view:PanelControllerPageViewModel, Path=SelectedPanel}"
                ShowGrid="{Binding Source={RelativeSource AncestorType={x:Type view:PanelControllerPageViewModel}}, x:DataType=view:PanelControllerPageViewModel, Path=ShowGrid}"
                TrackPieceDoubleTapped="TrackPieceDoubleTapped"
                TrackPieceTapped="TrackPieceTapped"
                VerticalOptions="Fill"
                ZoomFactor="{Binding Source={RelativeSource AncestorType={x:Type view:PanelControllerPageViewModel}}, x:DataType=view:PanelControllerPageViewModel, Path=ZoomFactor}"
                x:DataType="model:Panel"
                x:Name="PanelView" />
        </Grid>



