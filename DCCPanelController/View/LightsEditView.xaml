<?xml version="1.0" encoding="utf-8"?>

<ContentView
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.LightsEditView"
    x:DataType="view:LightsEditViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <StackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" Text="System Name (ID)" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5" HorizontalOptions="Fill" IsEnabled="{Binding Light.IsEditable}" Text="{Binding Light.Id}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="User Name" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5" HorizontalOptions="Fill" IsEnabled="{Binding Light.IsEditable}" Text="{Binding Light.Name}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="DCC Address" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}" WidthRequest="60">
                <Entry Keyboard="Numeric" Margin="5" HorizontalOptions="Fill" IsEnabled="{Binding Light.IsEditable}" Text="{Binding Light.DccAddress}">
                    <Entry.Behaviors>
                        <toolkit:NumericValidationBehavior
                            Flags="ValidateOnValueChanged"
                            MinimumValue="0"
                            MaximumValue="9999"
                            ValidStyle="{StaticResource ValidEntryStyle}"
                            InvalidStyle="{StaticResource InvalidEntryStyle}" />
                    </Entry.Behaviors>
                </Entry>
            </Border>
            <Label Margin="5,0,5,0" HorizontalOptions="Start" Text="Locked?" VerticalOptions="Center"/>
            <Switch Margin="5,0,5,0" IsToggled="{Binding Light.DccAddressLocked}"/>
        </HorizontalStackLayout>

        <BoxView Margin="0,10,0,10"
                 BackgroundColor="{StaticResource Primary}"
                 HeightRequest="1"
                 HorizontalOptions="FillAndExpand"/>

        <Label Text="Lights allow you to control switches on the DCC Layout such as turning on or off lights on buildings, streets etc. These are configured in your DCC system."></Label>
    </StackLayout>
</ContentView>