<?xml version="1.0" encoding="utf-8"?>

<ContentView
    BackgroundColor="Transparent"
    x:Class="DCCPanelController.View.BlocksEditView"
    x:DataType="view:BlocksEditViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel">

    <StackLayout>
        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" Text="System Name (ID)" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5" Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" IsEnabled="{Binding Block.IsEditable}" Text="{Binding Block.Id}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="User Name" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}">
                <Entry Margin="5" Style="{StaticResource EntryStyle}" HorizontalOptions="Fill" IsEnabled="{Binding Block.IsEditable}" Text="{Binding Block.Name}"/>
            </Border>
        </HorizontalStackLayout>

        <HorizontalStackLayout HeightRequest="40">
            <Label WidthRequest="175" HorizontalOptions="Start" Text="Sensor" VerticalOptions="Center"/>
            <Border Padding="0,0,0,0" Style="{StaticResource EntryBorderStyle}" x:DataType="view:BlocksEditViewModel">
                <Picker Margin="5,0,0,0" SelectedIndexChanged="Picker_OnSelectedIndexChanged" ItemsSource="{Binding Sensors}" ItemDisplayBinding="{Binding DisplayFormat, x:DataType=dataModel:Sensor}" SelectedItem="{Binding Sensor}"/>            
            </Border>
        </HorizontalStackLayout>
        <BoxView Margin="0,10,0,10"
                 BackgroundColor="{StaticResource Primary}"
                 HeightRequest="1"
                 HorizontalOptions="FillAndExpand"/>

        <Label Text="Blocks represent blocks of Track which can be occupied or unoccupied. When occupied, they will show on the Panel in a different color. They are controlled by the associated Sensor."></Label>
        
    </StackLayout>
</ContentView>