<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Name="Root"
    x:Class="DCCPanelController.View.TileSelectors.SideSelectorPanel"
    x:DataType="tileSelectors:SideSelectorPanelViewModel"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    ios:Page.UseSafeArea="false"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:tileSelectors="clr-namespace:DCCPanelController.View.TileSelectors"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:tiles="clr-namespace:DCCPanelController.Models.ViewModel.Tiles"
    xmlns:interfaces="clr-namespace:DCCPanelController.Models.ViewModel.Interfaces">

    <ContentView.Resources>
        <tileSelectors:CategoryToTilesConverter x:Key="CategoryToTilesConverter"/>
    </ContentView.Resources>

    <Border BackgroundColor="Transparent"
            StrokeShape="RoundRectangle 15 15 15 15"
            StrokeThickness="2"
            Stroke="{StaticResource Primary}"
            ZIndex="10"
            Margin="5"
            Padding="-2" >
        
        <Grid WidthRequest="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0">
                <Border Grid.Row="0" Margin="10,10,0,0"
                        WidthRequest="10" HeightRequest="10"
                        x:Name="LeftDockButton"
                        Stroke="{StaticResource Primary}"
                        Opacity="0.50"
                        HorizontalOptions="Start" ZIndex="10"
                        StrokeThickness="3">
                    <Border.StrokeShape>
                        <PathGeometry>
                            <PathFigure StartPoint="10,0" IsClosed="True">
                                <LineSegment Point="0,5"/>
                                <LineSegment Point="10,10"/>
                                <LineSegment Point="10,0"/>
                            </PathFigure>
                        </PathGeometry>
                    </Border.StrokeShape>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            CurrentTouchStatusChanged="OnCurrentTouchStatusChangedLeft"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75"/>
                    </Border.Behaviors>
                </Border>

                <Border Grid.Row="0" Margin="0,10,0,0"
                        x:Name="MiddleDockButton"
                        Stroke="{StaticResource Primary}" Opacity="0.50"
                        HorizontalOptions="Center" ZIndex="10"
                        HeightRequest="10" WidthRequest="10" StrokeThickness="3">
                    <Border.StrokeShape>
                        <PathGeometry>
                            <PathFigure StartPoint="0,0" IsClosed="True">
                                <LineSegment Point="10,0"/>
                                <LineSegment Point="5,10"/>
                                <LineSegment Point="0,0"/>
                            </PathFigure>
                        </PathGeometry>
                    </Border.StrokeShape>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            CurrentTouchStatusChanged="OnCurrentTouchStatusChangedMiddle"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75"/>
                    </Border.Behaviors>
                </Border>

                <Border Grid.Row="0" Margin="0,10,10,0"
                        x:Name="RightDockButton"
                        Stroke="{StaticResource Secondary}" Opacity="0.50"
                        HorizontalOptions="End" WidthRequest="10" HeightRequest="10" StrokeThickness="3">
                    <Border.StrokeShape>
                        <PathGeometry>
                            <PathFigure StartPoint="0,0" IsClosed="True">
                                <LineSegment Point="10,5"/>
                                <LineSegment Point="0,10"/>
                                <LineSegment Point="0,0"/>
                            </PathFigure>
                        </PathGeometry>
                    </Border.StrokeShape>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            CurrentTouchStatusChanged="OnCurrentTouchStatusChangedRight"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75"/>
                    </Border.Behaviors>
                </Border>
            </Grid>

            <!-- ============================================================== -->

            <!-- Main content area -->
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <ScrollView Orientation="Vertical">
                    <CollectionView ItemsSource="{Binding Categories}"
                                    SelectionMode="None"
                                    ItemSizingStrategy="MeasureAllItems">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="0" Margin="0,0,0,10">
                                    <Border  BackgroundColor="{StaticResource Primary}"
                                             HeightRequest="14" Margin="0,5,0,2"
                                             StrokeThickness="0"
                                             StrokeShape="RoundRectangle 10 10 0 0"
                                             HorizontalOptions="FillAndExpand">

                                    <Label
                                        x:DataType="x:String"
                                        Text="{Binding .}"
                                        TextColor="White"
                                        FontFamily="OpenSansMedium"
                                        HorizontalTextAlignment="Center"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        FontSize="10"/>

                                    </Border>
                                    
                                    <!-- Tiles for this category -->
                                    <CollectionView
                                        SelectionMode="None"
                                        ItemSizingStrategy="MeasureAllItems">
                                        <CollectionView.ItemsSource>
                                            <MultiBinding Converter="{StaticResource CategoryToTilesConverter}">
                                                <Binding Path="." x:DataType="x:String"/>
                                                <Binding
                                                    Source="{RelativeSource AncestorType={x:Type tileSelectors:SideSelectorPanelViewModel}}"
                                                    x:DataType="tileSelectors:SideSelectorPanelViewModel"/>
                                            </MultiBinding>
                                        </CollectionView.ItemsSource>

                                        <CollectionView.ItemsLayout>
                                            <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="2"
                                                             HorizontalItemSpacing="2"/>
                                        </CollectionView.ItemsLayout>

                                        <CollectionView.ItemTemplate>
                                            <!-- <DataTemplate x:DataType="entities:Entity"> -->
                                            <DataTemplate x:DataType="tiles:Tile">
                                                <ContentView
                                                    HeightRequest="45"
                                                    WidthRequest="45">
                                                    <Grid RowDefinitions="36,10">
                                                    <Border
                                                        Grid.Row="0"
                                                        BackgroundColor="White"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        HorizontalOptions="Fill"
                                                        Padding="5"
                                                        Stroke="{StaticResource Gray500}"
                                                        StrokeShape="RoundRectangle 5,5,5,5"
                                                        StrokeThickness="1"
                                                        VerticalOptions="Fill">
                                                        <ContentView
                                                            Content="{Binding .}"
                                                            HorizontalOptions="Fill"
                                                            VerticalOptions="Fill"
                                                            x:DataType="View">
                                                            <ContentView.GestureRecognizers>
                                                                <DragGestureRecognizer DragStarting="SymbolDragStarting"/>
                                                            </ContentView.GestureRecognizers>
                                                        </ContentView>
                                                    </Border>
                                                    <Label Grid.Row="1"
                                                           Margin="2,0,2,0"
                                                           FontSize="6"
                                                           WidthRequest="32"
                                                           x:DataType="interfaces:ITile"
                                                           TextColor="{DynamicResource PrimaryTextColor}"
                                                           HorizontalTextAlignment="Center"
                                                           LineBreakMode="TailTruncation"
                                                           Text="{Binding Entity.EntityName, FallbackValue=Tile}"/>
                                                    </Grid>
                                                </ContentView>
                                                
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Grid>
        </Grid>
    </Border>
</ContentView>