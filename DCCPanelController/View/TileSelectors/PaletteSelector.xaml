<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Name="Root"
    x:Class="DCCPanelController.View.TileSelectors.PaletteSelector"
    x:DataType="view:PaletteSelector"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:view="clr-namespace:DCCPanelController.View.TileSelectors"
    xmlns:interfaces="clr-namespace:DCCPanelController.Models.ViewModel.Interfaces"
    xmlns:tiles="clr-namespace:DCCPanelController.Models.ViewModel.Tiles"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters">

    <ContentView.Resources>
        <converters:BoolToChevronConverter x:Key="BoolToChevronConverter" />
    </ContentView.Resources>

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill"
          BackgroundColor="Transparent">

        <Border BackgroundColor="GhostWhite"
                StrokeShape="RoundRectangle 15 15 15 15"
                StrokeThickness="2"
                Stroke="{StaticResource Primary}"
                ZIndex="10"
                Margin="5"
                Padding="5">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SideCloseButton"
                        IsVisible="True"
                        Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"
                        HeightRequest="10" WidthRequest="25"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        StrokeThickness="6"
                        StrokeShape="RoundRectangle 15 15 5 5"
                        Stroke="{StaticResource Primary}">
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            TouchGestureCompleted="ClosePalette"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedBackgroundColor="{StaticResource Primary}"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75" />
                    </Border.Behaviors>
                </Border>

                <Border x:Name="BottomCloseButton"
                        IsVisible="False"
                        Grid.Row="1" Grid.Column="0" Margin="0,0,0,4"
                        Rotation="90"
                        HeightRequest="10" WidthRequest="25"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        StrokeThickness="6"
                        StrokeShape="RoundRectangle 15 15 5 5"
                        Stroke="{StaticResource Primary}">
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            TouchGestureCompleted="ClosePalette"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedBackgroundColor="{StaticResource Primary}"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75" />
                    </Border.Behaviors>
                </Border>


                <!-- ============================================================== -->
                <!-- Main content area -->
                <!-- ============================================================== -->
                <Grid Grid.Row="1" Grid.Column="1" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <CollectionView
                        x:Name="PaletteCollectionView"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never"
                        ItemsSource="{Binding Palette, Source={x:Reference Root}}"
                        ItemsLayout="{Binding ItemLayout, Source={x:Reference Root}}"
                        IsGrouped="True"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureAllItems">
                        
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:Name="GroupRoot" x:DataType="view:PaletteGroup">
                                <Border
                                    x:Name="CategoryHeading"
                                    Rotation="{Binding CategoryRotation, Source={x:Reference Root}, x:DataType=view:PaletteSelector}"
                                    BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="20"
                                    WidthRequest="90"
                                    StrokeThickness="0"
                                    Margin="0,5,0,5"
                                    StrokeShape="RoundRectangle 0 0 0 0"
                                    HorizontalOptions="Fill">
                                    <Label
                                        Text="{Binding Category}"
                                        TextColor="White"
                                        FontFamily="OpenSansMedium"
                                        HorizontalTextAlignment="Center"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        FontSize="12" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleExpandCommand}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="view:PaletteItem">
                                <ContentView
                                    x:Name="TileItemTemplate"
                                    HeightRequest="45"
                                    WidthRequest="45">
                                    <Grid RowDefinitions="36,10" Margin="0" Padding="0">
                                        <Border
                                            Grid.Row="0"
                                            BackgroundColor="White"
                                            HeightRequest="32"
                                            WidthRequest="32"
                                            HorizontalOptions="Fill"
                                            Padding="5"
                                            Stroke="{StaticResource Gray500}"
                                            StrokeShape="RoundRectangle 5,5,5,5"
                                            StrokeThickness="1"
                                            VerticalOptions="Fill">
                                            <ContentView
                                                BackgroundColor="Transparent"
                                                Content="{Binding Tile}"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill">
                                                <ContentView.GestureRecognizers>
                                                    <DragGestureRecognizer DragStarting="OnTileCollectionDragStarting" CanDrag="True" />
                                                </ContentView.GestureRecognizers>
                                            </ContentView>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BackgroundColor" Value="{StaticResource Gray200}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                        </Border>

                                        <Label Grid.Row="1"
                                               Margin="2,0,2,0"
                                               FontSize="6"
                                               WidthRequest="32"
                                               TextColor="{DynamicResource PrimaryTextColor}"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               Text="{Binding Tile.Entity.EntityName, FallbackValue=Tile}" />
                                    </Grid>
                                    <ContentView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnItemTapped" />
                                    </ContentView.GestureRecognizers>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</ContentView>