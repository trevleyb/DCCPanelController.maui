<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Name="RootDock"
    x:Class="DCCPanelController.View.TileSelectors.PaletteSelector"
    x:DataType="view:PaletteSelectorViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:view="clr-namespace:DCCPanelController.View.TileSelectors"
    xmlns:interfaces="clr-namespace:DCCPanelController.Models.ViewModel.Interfaces"
    xmlns:tiles="clr-namespace:DCCPanelController.Models.ViewModel.Tiles"
    xmlns:converters="clr-namespace:DCCPanelController.View.Converters">

    <ContentView.Resources>
        <view:CategoryToTilesConverter x:Key="CategoryToTilesConverter" />
        <view:RefEqualsConverter x:Key="RefEqualsConverter" />
        <converters:BoolToChevronConverter x:Key="BoolToChevronConverter" />
    </ContentView.Resources>

    <Grid WidthRequest="110" x:Name="SidePalette" HorizontalOptions="Fill" VerticalOptions="Fill" IsVisible="True"
          BackgroundColor="Transparent">
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 15 15 15 15"
                StrokeThickness="2"
                Stroke="{StaticResource Primary}"
                ZIndex="10"
                Margin="5"
                Padding="0">

            <Grid WidthRequest="90">
                <Grid.RowDefinitions>
                    <RowDefinition Height="9" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Margin="0,4,0,0" HorizontalOptions="Center" WidthRequest="25" StrokeThickness="6"
                        StrokeShape="RoundRectangle 15 15 5 5"
                        Stroke="{StaticResource Primary}">
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            TouchGestureCompleted="SwitchDockPosition"
                            DefaultBackgroundColor="{StaticResource Primary}"
                            DefaultOpacity="0.50"
                            HoveredBackgroundColor="{StaticResource PrimaryDisabled}"
                            HoveredOpacity="1.00"
                            PressedBackgroundColor="{StaticResource Primary}"
                            PressedOpacity="0.75"
                            DefaultScale="1.0"
                            HoveredScale="2.00"
                            PressedScale="0.75" />
                    </Border.Behaviors>
                </Border>

                <!-- ============================================================== -->

                <!-- Main content area -->
                <Grid Grid.Row="1" Margin="0,0,0,5">
                    <CollectionView
                        x:Name="TileCollection"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never"
                        ItemsSource="{Binding Palette}"
                        IsGrouped="True"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureAllItems">

                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:Name="GroupRoot" x:DataType="view:PaletteGroup">
                                <VerticalStackLayout Spacing="0" Margin="-10,0,-10,5">
                                    <Border BackgroundColor="{StaticResource Primary}"
                                            HeightRequest="18" Margin="0,5,0,0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 0 0 6 6"
                                            HorizontalOptions="FillAndExpand">
                                        <HorizontalStackLayout>
                                            <Image Margin="12,0,4,0" HeightRequest="12" WidthRequest="12"  Source="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}">
                                                <Image.Behaviors>
                                                    <toolkit:IconTintColorBehavior TintColor="White"/>
                                                </Image.Behaviors>
                                            </Image>
                                            <Label
                                                Text="{Binding Category}"
                                                TextColor="White"
                                                FontFamily="OpenSansMedium"
                                                HorizontalTextAlignment="Center"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                FontSize="10"/>
                                        </HorizontalStackLayout>
                                        
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleExpandCommand}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="2"
                                             HorizontalItemSpacing="2" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="view:PaletteItem">
                                <ContentView
                                    x:Name="TileItemTemplate"
                                    HeightRequest="45"
                                    WidthRequest="45">
                                    <Grid RowDefinitions="36,10" Margin="0" Padding="0">
                                        <Border
                                            Grid.Row="0"
                                            BackgroundColor="White"
                                            HeightRequest="32"
                                            WidthRequest="32"
                                            HorizontalOptions="Fill"
                                            Padding="5"
                                            Stroke="{StaticResource Gray500}"
                                            StrokeShape="RoundRectangle 5,5,5,5"
                                            StrokeThickness="1"
                                            VerticalOptions="Fill">
                                            <ContentView
                                                BackgroundColor="Transparent"
                                                Content="{Binding Tile}"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill">
                                                <ContentView.GestureRecognizers>
                                                    <DragGestureRecognizer DragStarting="OnTileCollectionDragStarting"
                                                                           CanDrag="True" />
                                                </ContentView.GestureRecognizers>
                                            </ContentView>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}"
                                                                     Value="True">
                                                            <Setter Property="BackgroundColor"
                                                                    Value="{StaticResource Gray200}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                        </Border>

                                        <Label Grid.Row="1"
                                               Margin="2,0,2,0"
                                               FontSize="6"
                                               WidthRequest="32"
                                               TextColor="{DynamicResource PrimaryTextColor}"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               Text="{Binding Tile.Entity.EntityName, FallbackValue=Tile}" />
                                    </Grid>
                                    <ContentView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnItemTapped" />
                                    </ContentView.GestureRecognizers>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>