<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="panels_green.png"
    Title="Panels Editor"
    x:Name="Page"
    x:Class="DCCPanelController.View.PanelEditorPage"
    x:DataType="viewModel:PanelEditorViewModel"
    xmlns:markups="clr-namespace:OnScreenSizeMarkup.Maui;assembly=OnScreenSizeMarkup.Maui"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:DCCPanelController.Components.Elements.Views"
    xmlns:symbols="clr-namespace:DCCPanelController.Components.TrackComponents"
    xmlns:trackComponents="clr-namespace:DCCPanelController.Components.TrackComponents"
    xmlns:converters="clr-namespace:DCCPanelController.Helpers.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BooleanToArrowConverter x:Key="BooleanToArrowConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding SaveCommand}"
                     IsEnabled="{Binding IsNotBusy}"
                     IconImageSource="save.png" />
        <ToolbarItem x:Name="PropertiesToolbarItem" Clicked="PropertiesToolbarItem_OnClicked"
                     ToolTipProperties.Text="Select an Item"
                     IsEnabled="{Binding IsTrackSelected}"
                     Command="{Binding PropertiesSelectedElementCommand}" 
                     IconImageSource="settings_adjust.png" />
        <ToolbarItem x:Name="MultiSelectToolbarItem" Clicked="MultiSelectToolbarItem_OnClicked"
                     Text="Multi-Select"
                     IconImageSource="select.png"
                     ToolTipProperties.Text="Multi-Select Items"
                     Command="{Binding ToggleMultiSelectCommand}"
                     IsEnabled="{Binding IsTrackSelected}" />
        <ToolbarItem x:Name="DeleteTrackToolbarItem" Clicked="DeleteTrackToolbarItem_OnClicked"
                     IconImageSource="trash.png"
                     ToolTipProperties.Text="Delete an Item"
                     Command="{Binding DeleteSelectedElementCommand}"
                     IsEnabled="{Binding IsTrackSelected}" />
        <ToolbarItem x:Name="RotateTrackToolbarItem" Clicked="RotateTrackToolbarItem_OnClicked"
                     IconImageSource="rotate.png"
                     ToolTipProperties.Text="Rotate Selected Items 90"
                     Command="{Binding RotateSelectedElementCommand}"
                     IsEnabled="{Binding IsTrackSelected}" />
        <ToolbarItem x:Name="ExpandTextObject"
                     IconImageSource="side_panel_open.png"
                     ToolTipProperties.Text="Expand Text Size"
                     Command="{Binding ExpandTextSizeCommand}"
                     IsEnabled="{Binding IsTextBlockExpandable}" />
        <ToolbarItem x:Name="ContractTextObject"
                     IconImageSource="side_panel_close.png"
                     ToolTipProperties.Text="Expand Text Size"
                     Command="{Binding ContractTextSizeCommand}"
                     IsEnabled="{Binding IsTextBlockContractable}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>

        <Grid x:Name="EditorContainer">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="{markups:OnScreenSize Medium=50, Large=50, ExtraLarge=120, Default=120}"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowDefinitions="auto,*" >
                <toolkit:Expander x:Name="MyExpander" IsExpanded="False">
                    <toolkit:Expander.Header>
                            <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="10" RowDefinitions="auto,auto" Margin="10,10,10,10">
                                <Label Grid.Column="0" Grid.Row="0" Style="{StaticResource MediumLabel}"
                                       TextColor="{StaticResource Primary}" Text="ID" LineBreakMode="NoWrap" />
                                <Entry Grid.Column="0" Grid.Row="1" Style="{StaticResource PanelEntry}"
                                       WidthRequest="80"
                                       ClearButtonVisibility="Never"  MaxLength="10"
                                       Text="{Binding Panel.Id, Mode=TwoWay}" />
                                <Label Grid.Column="1" Grid.Row="0" Style="{StaticResource MediumLabel}"
                                       TextColor="{StaticResource Primary}" Text="Name or Description"
                                       LineBreakMode="NoWrap" />
                                <Entry Grid.Column="1" Grid.Row="1" Style="{StaticResource PanelEntry}"
                                       ClearButtonVisibility="Never" Text="{Binding Panel.Name, Mode=TwoWay}" />
                                <Image Grid.Column="2" Grid.Row="1" Source="{Binding Source={x:Reference MyExpander}, Path=IsExpanded, Converter={StaticResource BooleanToArrowConverter}}" />
                            </Grid>
                    </toolkit:Expander.Header>
                    <StackLayout>
                        <Grid ColumnDefinitions="auto,auto,*" RowDefinitions="auto,auto,auto">
                            <Label Grid.Column="0" Grid.Row="0" Style="{StaticResource PanelInfoLabel}">
                                <MultiBinding StringFormat="{}Columns: {0}">
                                    <Binding Path="Panel.Cols" />
                                </MultiBinding>
                            </Label>
                            <Stepper Grid.Column="0" Grid.Row="1"
                                     ValueChanged="Stepper_OnValueChanged"
                                     Style="{StaticResource PanelInfoStepper}"
                                     Value="{Binding Panel.Cols}"
                                     Maximum="{Binding MaxPanelCols}"
                                     Minimum="{Binding MinPanelCols}" />

                            <Label Grid.Column="1" Grid.Row="0" Style="{StaticResource PanelInfoLabel}">
                                <MultiBinding StringFormat="{}Rows: {0}">
                                    <Binding Path="Panel.Rows" />
                                </MultiBinding>
                            </Label>
                            <Stepper Grid.Column="1" Grid.Row="1"
                                     ValueChanged="Stepper_OnValueChanged"
                                     Style="{StaticResource PanelInfoStepper}"
                                     Value="{Binding Panel.Rows}"
                                     Maximum="{Binding MaxPanelRows}"
                                     Minimum="{Binding MinPanelRows}" />

                            <Grid Grid.Column="0" Grid.Row="2" ColumnSpan="2">
                                <Label Style="{StaticResource PanelInfoLabel}">
                                    <MultiBinding StringFormat="{}Ratio {0}">
                                        <Binding Path="Panel.PanelRatio" />
                                    </MultiBinding>
                                </Label>
                            </Grid>
                            <Label Grid.Column="2" Grid.Row="1" Text="{Binding Message}"/>
                        </Grid>
                        <BoxView BackgroundColor="{StaticResource Primary}" HeightRequest="3"
                                 HorizontalOptions="FillAndExpand" />
                    </StackLayout>
                </toolkit:Expander>

                <AbsoluteLayout Grid.Row="1" x:Name="PanelEditorContainer" BackgroundColor="{StaticResource Gray100}">
                    <AbsoluteLayout x:Name="PanelEditorViewPane" BackgroundColor="{StaticResource White}">
                        <AbsoluteLayout.GestureRecognizers>
                            <DropGestureRecognizer
                                DropCommand="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelEditorViewModel}}, Path=DropCommand}"
                                DropCommandParameter="{Binding .}"
                                DragLeave="DropGestureRecognizer_OnDragLeave"
                                Drop="DropGestureRecognizer_OnDrop" />
                            <DropGestureRecognizer DragOver="DropGestureRecognizer_OnDragOver" />
                            <TapGestureRecognizer Tapped="TapGestureRecognizerBlankEditor" />
                        </AbsoluteLayout.GestureRecognizers>
                    </AbsoluteLayout>
                    <AbsoluteLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizerBlankEditor" />
                    </AbsoluteLayout.GestureRecognizers>
                </AbsoluteLayout>

            </Grid>

            <Grid Grid.Column="1">
                <BoxView BackgroundColor="{StaticResource Primary}"
                         WidthRequest="3"
                         VerticalOptions="FillAndExpand">
                </BoxView>
            </Grid>

            <!-- Right Panel -->
        <Grid Grid.Column="2" x:Name = "Toolbox" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="{markups:OnScreenSize Medium=50, Large=50, ExtraLarge=120, Default=120}" />
            </Grid.RowDefinitions>

            <!-- Drop Down -->
            <Picker x:Name="SetPicker" 
                    VerticalOptions="Center" 
                    HorizontalOptions="Center"
                    ItemsSource="{Binding SymbolSets}" 
                    SelectedItem="{Binding SelectedSet}"
                    SelectedIndexChanged="Picker_OnSelectedIndexChanged"/>

            <BoxView Grid.Row="1"
                     BackgroundColor="{StaticResource Primary}"
                     HeightRequest="3"
                     VerticalOptions="FillAndExpand"/>

            <!-- Collection View for Symbols -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding FilteredSymbols}" 
                            SelectionMode="Single" >
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <ContentView>
                            <trackComponents:SymbolView Margin="5,5,5,5" WidthRequest="50" HeightRequest="50">
                                <trackComponents:SymbolView.GestureRecognizers>
                                    <DragGestureRecognizer
                                        DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelEditorViewModel}}, Path=SymbolDragCommand}"
                                        DragStartingCommandParameter="{Binding .}" />
                                </trackComponents:SymbolView.GestureRecognizers>
                            </trackComponents:SymbolView>
                        </ContentView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" 
                                     Span="{Binding Span}" />
                </CollectionView.ItemsLayout>
            </CollectionView>

            <BoxView Grid.Row="3"
                     BackgroundColor="{StaticResource Primary}"
                     HeightRequest="3"
                     VerticalOptions="FillAndExpand"/>

            <!-- Color Grid -->
            <Grid x:Name="ColorGrid" Grid.Row="4" HorizontalOptions="Center" VerticalOptions="Center">
                <!-- Generate Color Grid (16x16) -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Populate Grid with Buttons for Colors -->
                <!-- Example for two colors, repeat for all 256 color cells -->
                <!--
                <BoxView Grid.Column="0" Grid.Row="0" BackgroundColor="#000000" WidthRequest="{markups:OnScreenSize Medium=10, Large=10, ExtraLarge=25, Default=25}" HeightRequest="{markups:OnScreenSize Medium=10, Large=10, ExtraLarge=25, Default=25}"/>
                <BoxView Grid.Column="0" Grid.Row="1" BackgroundColor="#FFFFFF" WidthRequest="{markups:OnScreenSize Medium=10, Large=10, ExtraLarge=25, Default=25}" HeightRequest="{markups:OnScreenSize Medium=10, Large=10, ExtraLarge=25, Default=25}"/>
