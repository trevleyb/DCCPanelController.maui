<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    Title="{Binding Panel.Name}"
    x:Class="DCCPanelController.View.PanelEditorPage"
    x:DataType="view:PanelEditorViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:interfaces="clr-namespace:DCCPanelController.Model.Tracks.Interfaces"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:viewModel="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding CancelCommand}" />
    </Shell.BackButtonBehavior>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Clicked="ChangeEditMode"
            IconImageSource="move.png"
            Text="Edit Mode"
            ToolTipProperties.Text="Edit Mode"
            x:Name="EditModeToolbar" />

        <ToolbarItem
            Clicked="RotateLeft"
            IconImageSource="rotate_cw.png"
            IsEnabled="{Binding HasSelectedTracks}"
            Text="Rotate Left"
            ToolTipProperties.Text="Rotate Left" />

        <ToolbarItem
            Clicked="RotateRight"
            IconImageSource="rotate_ccw.png"
            IsEnabled="{Binding HasSelectedTracks}"
            Text="Rotate Right"
            ToolTipProperties.Text="Rotate Right" />

        <ToolbarItem
            Clicked="DeleteTrackPiece"
            IconImageSource="trash_2.png"
            IsEnabled="{Binding HasSelectedTracks}"
            Text="Delete Track"
            ToolTipProperties.Text="Delete Track Piece" />

        <ToolbarItem
            Clicked="ShowEditPropertyPage"
            IconImageSource="edit.png"
            IsEnabled="{Binding CanUsePropertyPage}"
            Text="Properties"
            ToolTipProperties.Text="Panel Properties"
            x:Name="PropertyEditButton" />

        <ToolbarItem />

        <ToolbarItem
            Clicked="ToggleGrid"
            IconImageSource="grid_off.png"
            Text="Show Grid"
            ToolTipProperties.Text="Toggle the Grid On|Off"
            x:Name="GridButton" />

        <ToolbarItem
            Clicked="ShowPropertyPage"
            IconImageSource="settings.png"
            Text="Properties"
            ToolTipProperties.Text="Panel Properties"
            x:Name="PropertyButton" />

        <ToolbarItem
            Command="{Binding SaveCommand}"
            IconImageSource="save.png"
            Text="Save"
            ToolTipProperties.Text="Save this Panel"
            x:Name="SaveButton" />

    </ContentPage.ToolbarItems>

    <Grid
        Margin="0"
        Padding="0"
        x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" x:Name="LeftColumn" />
            <ColumnDefinition Width="60" x:Name="RightColumn" />
        </Grid.ColumnDefinitions>

        <!--  Left Pane  -->
        <ContentView
            Grid.Column="0"
            Margin="10"
            x:Name="LeftPane">
            <view:ControlPanelView
                DesignMode="True"
                HorizontalOptions="Fill"
                Panel="{Binding Panel, Source={RelativeSource AncestorType={x:Type view:PanelEditorViewModel}}}"
                ShowGrid="True"
                TrackPieceChanged="PanelView_OnTrackPieceChanged"
                TrackPieceDoubleTapped="PanelView_OnTrackPieceDoubleTapped"
                TrackPieceTapped="PanelView_OnTrackPieceTapped"
                VerticalOptions="Fill"
                x:Name="PanelView" />
        </ContentView>

        <!--  Right Pane  -->
        <ContentView
            BackgroundColor="{StaticResource Primary}"
            Grid.Column="1"
            x:Name="RightPane">
            <StackLayout Padding="5">
                <CollectionView
                    HorizontalOptions="Center"
                    ItemsSource="{Binding TrackSymbols}"
                    Margin="5"
                    SelectionMode="Single"
                    VerticalOptions="FillAndExpand"
                    x:Name="TrackSymbolCollectionView">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            HorizontalItemSpacing="5"
                            Orientation="Vertical"
                            Span="1"
                            VerticalItemSpacing="5"
                            x:Name="ItemsLayout" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="interfaces:ITrackSymbol">
                            <Border
                                BackgroundColor="Snow"
                                HorizontalOptions="Center"
                                Margin="5"
                                Padding="0"
                                Stroke="#95000000"
                                StrokeShape="RoundRectangle 10,10,10,10"
                                StrokeThickness="2"
                                ToolTipProperties.Text="{Binding Name}"
                                VerticalOptions="Center">
                                <Grid
                                    HeightRequest="24"
                                    Margin="0"
                                    Padding="0"
                                    WidthRequest="24">
                                    <!--  <Label  -->
                                    <!--  FontSize="7"  -->
                                    <!--  HorizontalTextAlignment="Center"  -->
                                    <!--  IsVisible="{Binding ShowAboveSymbol}"  -->
                                    <!--  LineBreakMode="WordWrap"  -->
                                    <!--  Margin="0,0,0,0"  -->
                                    <!--  Text="{Binding Name}"  -->
                                    <!--  VerticalOptions="Start"  -->
                                    <!--  WidthRequest="48" />  -->
                                    <Image
                                        HorizontalOptions="Center"
                                        Rotation="{Binding ImageRotation}"
                                        Source="{Binding SymbolView}"
                                        VerticalOptions="Center" />
                                    <!--  <Label  -->
                                    <!--  FontSize="7"  -->
                                    <!--  HorizontalTextAlignment="Center"  -->
                                    <!--  IsVisible="{Binding ShowBelowSymbol}"  -->
                                    <!--  LineBreakMode="WordWrap"  -->
                                    <!--  Margin="0,0,0,0"  -->
                                    <!--  Text="{Binding Name}"  -->
                                    <!--  VerticalOptions="End"  -->
                                    <!--  WidthRequest="48" />  -->
                                </Grid>
                                <Border.GestureRecognizers>
                                    <DragGestureRecognizer DragStarting="OnSymbolDragStarting" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ContentView>
    </Grid>

</ContentPage>