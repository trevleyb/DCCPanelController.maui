<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Panel.Name}"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
             xmlns:view="clr-namespace:DCCPanelController.View"
             xmlns:interfaces="clr-namespace:DCCPanelController.Tracks.Interfaces"
             x:DataType="viewModel:PanelEditorViewModel"
             x:Class="DCCPanelController.View.PanelEditorPage">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveButton" IconImageSource="save.png" Clicked="SavePanelAndExit" />
        <ToolbarItem x:Name="GridButton" IconImageSource="gridoff.png" Clicked="ToggleGrid"/>
        <ToolbarItem x:Name="ValidateButton" IconImageSource="refresh_double.png" Clicked="ToggleValidation"/>
        <ToolbarItem x:Name="PropertyButton" IconImageSource="tuning.png" Clicked="ShowPropertyPage"/>
        <ToolbarItem x:Name="ExpandCollapse" IconImageSource="right_panel_close_filled.png" Clicked="OnExpandCollapseButtonClicked"/>
    </ContentPage.ToolbarItems>

    <Grid x:Name="MainGrid" Margin="0" Padding="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="RightColumn" Width="120" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane -->
        <ContentView x:Name="LeftPane" Grid.Column="0">
                <view:ControlPanelView
                    x:Name="PanelView"
                    Panel="{Binding Panel}"
                    DesignMode="True"
                    ShowGrid="True"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"/>
        </ContentView>

        <!-- Separator / Resizer -->
        <BoxView x:Name="Separator" WidthRequest="8" Color="Gray" Grid.Column="1" HorizontalOptions="Center">
            <BoxView.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Right Pane -->
        <ContentView
            x:Name="RightPane" 
            BackgroundColor="{StaticResource Primary}" 
            Grid.Column="2">
            <StackLayout>
                <CollectionView x:Name="TrackSymbolCollectionView"
                                ItemsSource="{Binding TrackSymbols}"
                                VerticalOptions="FillAndExpand"
                                HorizontalOptions="Center"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout 
                            x:Name="ItemsLayout"
                            Orientation="Vertical"
                            HorizontalItemSpacing="5"
                            VerticalItemSpacing="5"
                            Span="1"/>
                    </CollectionView.ItemsLayout>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate 
                            x:DataType="interfaces:ITrackSymbol">
                            <Frame Padding="5" 
                                   BackgroundColor="White"
                                   HasShadow="false" 
                                   Margin="5" 
                                   WidthRequest="50"
                                   HeightRequest="50"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                    <Image Source="{Binding SymbolImage}" 
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"  
                                           WidthRequest="50" 
                                           HeightRequest="50"/>
                                <Frame.GestureRecognizers>
                                    <DragGestureRecognizer DragStarting="OnSymbolDragStarting"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                
                <Frame HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="5,20,5,5"
                       WidthRequest="100"
                       HeightRequest="100"
                       BorderColor="Transparent"
                       BackgroundColor="Transparent"
                       x:Name="DragTrashIcon">
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer Drop="DropTrackInTrash" DragOver="DropTrackInTrashHoverOver" DragLeave="DropTrackInTrashHoverLeave" />
                    </Frame.GestureRecognizers>
                        <Image Margin="0" Source="trash.png" WidthRequest="60" HeightRequest="60"/>
                </Frame>
            </StackLayout>
        </ContentView>
    </Grid>

</ContentPage>
