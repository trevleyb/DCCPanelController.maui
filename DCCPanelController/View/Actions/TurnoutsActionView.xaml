<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="DCCPanelController.View.Actions.TurnoutActionsView"
    x:DataType="actions:TurnoutActionsView"
    x:Name="TurnoutActionView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:actions="clr-namespace:DCCPanelController.View.Actions"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="10" Spacing="15">
        <Grid ColumnDefinitions="*,auto">
            <Label
                Grid.Column="0"
                Style="{StaticResource MediumLabel}"
                Text="Turnout Actions" />
            <ImageButton
                Aspect="Center"
                Command="{Binding AddTurnoutActionCommand}"
                Grid.Column="1"
                HeightRequest="25"
                Margin="0,-25,20,0"
                Source="plus_circle.png"
                WidthRequest="25" />
        </Grid>

        <!--  Turnout Actions Table  -->
        <CollectionView ItemsSource="{Binding TurnoutActions}" Margin="0,-10,0,0">
            <CollectionView.Header>
                <Grid ColumnDefinitions="25,2*,*,*">
                    <Label
                        FontAttributes="Bold"
                        Grid.Column="1"
                        Text="Turnout ID"
                        TextColor="{StaticResource Primary}" />
                    <Label
                        FontAttributes="Bold"
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Text="Closed(Straight)"
                        TextColor="{StaticResource Primary}" />
                    <Label
                        FontAttributes="Bold"
                        Grid.Column="3"
                        HorizontalOptions="Center"
                        Text="Thrown(Diverging)"
                        TextColor="{StaticResource Primary}" />
                    <Label
                        FontAttributes="Bold"
                        Grid.Column="4"
                        HorizontalOptions="Center"
                        Text="Cascade"
                        TextColor="{StaticResource Primary}" />
                    <Label
                        FontAttributes="Bold"
                        Grid.Column="5"
                        HorizontalOptions="Center"
                        TextColor="{StaticResource Primary}" />

                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:TurnoutAction">
                    <Grid ColumnDefinitions="25,2*,*,*">
                        <ImageButton
                            Grid.Column="0"
                            Margin="0,0,0,0"
                            Source="minus_circle.png" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding Id}"
                            TextColor="{StaticResource Primary}" />
                        <Label
                            Grid.Column="2"
                            Text="{Binding WhenClosedOrActive}"
                            TextColor="{StaticResource Primary}" />
                        <Label
                            Grid.Column="3"
                            Text="{Binding WhenThrownOrInActive}"
                            TextColor="{StaticResource Primary}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>