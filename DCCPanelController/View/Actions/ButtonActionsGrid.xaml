<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    HeightRequest="{Binding ControlHeight}"
    x:Class="DCCPanelController.View.Actions.ButtonActionsGrid"
    x:DataType="local:ButtonActionsGridViewModel"
    x:Name="ButtonActionsGridView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:converter="clr-namespace:DCCPanelController.Helpers.Converters"
    xmlns:local="clr-namespace:DCCPanelController.View.Actions"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:toolkit="http://communitytoolkit.maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:ButtonActionEnumConverter x:Key="ButtonActionEnumConverter" />
        </ResourceDictionary>
    </ContentView.Resources>

    <ContentView.Content>
        <VerticalStackLayout>
            <Grid ColumnDefinitions="100,auto">
                <Label
                    FontAttributes="Bold"
                    Grid.Column="0"
                    HeightRequest="25"
                    Text="Button Actions"
                    TextColor="{StaticResource Primary}" />
                <ImageButton
                    Aspect="Center"
                    Command="{Binding AddRowCommand}"
                    Grid.Column="1"
                    HeightRequest="25"
                    IsEnabled="{Binding IsAddButtonEnabled}"
                    Margin="0,-5,0,0"
                    Source="plus_circle.png"
                    WidthRequest="25" />
            </Grid>

            <CollectionView ItemsSource="{Binding ButtonActions}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout>
                        <Label Text="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.NoDataText}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Header>
                    <Grid ColumnDefinitions="150,150,150,100,80" ColumnSpacing="5">
                        <BoxView
                            Background="{StaticResource Primary}"
                            Grid.Column="0"
                            HeightRequest="25" />
                        <BoxView
                            Background="{StaticResource Primary}"
                            Grid.Column="1"
                            HeightRequest="25" />
                        <BoxView
                            Background="{StaticResource Primary}"
                            Grid.Column="2"
                            HeightRequest="25" />
                        <BoxView
                            Background="{StaticResource Primary}"
                            Grid.Column="3"
                            HeightRequest="25" />
                        <Label
                            FontAttributes="Bold"
                            Grid.Column="0"
                            Margin="5"
                            Padding="5"
                            Text="ID"
                            TextColor="{StaticResource White}" />
                        <Label
                            FontAttributes="Bold"
                            Grid.Column="1"
                            Margin="5"
                            Padding="5"
                            Text="Active (On)"
                            TextColor="{StaticResource White}" />
                        <Label
                            FontAttributes="Bold"
                            Grid.Column="2"
                            Margin="5"
                            Padding="5"
                            Text="Inactive (Off)"
                            TextColor="{StaticResource White}" />
                        <Label
                            FontAttributes="Bold"
                            Grid.Column="3"
                            Margin="5"
                            Padding="5"
                            Text="Cascade?"
                            TextColor="{StaticResource White}" />
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:ButtonAction">
                        <Grid ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Picker
                                Grid.Column="0"
                                ItemsSource="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.SelectableButtons}"
                                Margin="5,0,0,0"
                                SelectedItem="{Binding Id}"
                                TextColor="Black"
                                VerticalOptions="Center" />

                            <Picker
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                SelectedItem="{Binding WhenActiveOrClosed, Converter={StaticResource ButtonActionEnumConverter}}"
                                TextColor="Black"
                                VerticalOptions="Center">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Active</x:String>
                                        <x:String>Inactive</x:String>
                                        <x:String>Leave</x:String>
                                        <x:String>Toggle</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>

                            <Picker
                                Grid.Column="2"
                                Margin="5,0,0,0"
                                SelectedItem="{Binding WhenInactiveOrThrown, Converter={StaticResource ButtonActionEnumConverter}}"
                                TextColor="Black"
                                VerticalOptions="Center">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Active</x:String>
                                        <x:String>Inactive</x:String>
                                        <x:String>Leave</x:String>
                                        <x:String>Toggle</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>

                            <CheckBox
                                Grid.Column="3"
                                IsChecked="{Binding Cascade}"
                                Margin="5,0,0,0"
                                VerticalOptions="Center" />

                            <ImageButton
                                Aspect="Center"
                                Command="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.RemoveRowCommand}"
                                CommandParameter="{Binding .}"
                                Grid.Column="4"
                                HeightRequest="10"
                                Margin="0,0,0,0"
                                Source="minus_circle.png"
                                VerticalOptions="Center"
                                WidthRequest="10" />

                            <BoxView
                                BackgroundColor="{StaticResource Primary}"
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                HeightRequest="1"
                                VerticalOptions="End" />

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                VerticalOptions="End" />
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>