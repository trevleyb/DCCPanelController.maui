<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="DCCPanelController.View.Actions.ButtonActionsGrid"
    x:DataType="local:ButtonActionsGridViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:local="clr-namespace:DCCPanelController.View.Actions"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:actions="clr-namespace:DCCPanelController.Models.DataModel.Entities.Actions">

    <ContentView.Resources>
        <ResourceDictionary/>
    </ContentView.Resources>

    <ContentView.Content>
        <VerticalStackLayout>
            <Grid Margin="5,5,0,0" ColumnDefinitions="120,auto,auto">
                <Label
                    FontAttributes="Bold"
                    Grid.Column="0"
                    HeightRequest="25"
                    Text="Button Actions"
                    TextColor="{StaticResource Primary}"/>
                <ImageButton
                    Aspect="Center"
                    Command="{Binding AddRowCommand}"
                    Grid.Column="1"
                    HeightRequest="25"
                    IsEnabled="{Binding IsAddButtonEnabled}"
                    Margin="0,-5,0,0"
                    Source="plus_circle.png"
                    WidthRequest="25">
                    <ImageButton.Behaviors>
                        <behaviors:IconTintColorBehavior TintColor="{StaticResource Primary}"/>
                    </ImageButton.Behaviors>
                </ImageButton>
                <Label
                    Grid.Column="2"
                    HeightRequest="25"
                    Style="{StaticResource SmallLabel}"
                    Text="{Binding NoDataText}"
                    VerticalOptions="Center"/>
            </Grid>

            <Grid HeightRequest="{Binding ControlHeight, Mode=OneWay}" IsVisible="{Binding IsGridVisible}">
                <ListView
                    HorizontalOptions="Fill"
                    ItemsSource="{Binding ButtonPanelActions}"
                    SelectionMode="None"
                    VerticalOptions="Fill">

                    <ListView.Header>
                        <Grid
                            ColumnDefinitions="3*,4*,4*,3*,1*"
                            ColumnSpacing="2"
                            RowDefinitions="25">
                            <BoxView Background="{StaticResource Primary}" Grid.Column="0"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="1"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="2"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="3"/>
                            <BoxView Background="{StaticResource Primary}" Grid.Column="4"/>

                            <Label
                                FontAttributes="Bold"
                                Grid.Column="0"
                                Text="Button"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                Margin="10,0,0,0"
                                TextColor="{StaticResource White}"/>

                            <components:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                Margin="2"
                                State="On"/>

                            <components:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                Margin="2"
                                State="Off"/>

                            <components:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                Margin="2"
                                State="Closed"/>

                            <components:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                Margin="2"
                                State="Thrown"/>

                            <Label
                                FontAttributes="Bold"
                                Grid.Column="3"
                                HorizontalOptions="Center"
                                Margin="2"
                                Text="Cascade?"
                                TextColor="{StaticResource White}"/>

                            <Image
                                Grid.Column="4"
                                Margin="2"
                                Source="trash.png">
                                <Image.Behaviors>
                                    <behaviors:IconTintColorBehavior TintColor="Firebrick"/>
                                </Image.Behaviors>
                            </Image>

                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell x:DataType="actions:ButtonAction">
                                <Grid
                                    ColumnDefinitions="3*,4*,4*,3*,1*"
                                    ColumnSpacing="2"
                                    RowDefinitions="25"
                                    VerticalOptions="Center">

                                    <Picker
                                        Grid.Column="0"
                                        Margin="10,0,0,0"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"
                                        BackgroundColor="Transparent"
                                        TextColor="Black"
                                        SelectedItem="{Binding Id, Mode=TwoWay}"
                                        ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type local:ButtonActionsGridViewModel}},x:DataType=local:ButtonActionsGridViewModel, Path=SelectableButtons, Mode=OneWay}"/>

                                    <components:ButtonStateControl
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="1"
                                        HorizontalOptions="Start"
                                        Margin="2,0,0,0"
                                        State="{Binding WhenOn, Mode=TwoWay}"
                                        UnknownText="Leave-AsIs"/>

                                    <components:ButtonStateControl
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="2"
                                        HorizontalOptions="Start"
                                        Margin="2,0,0,0"
                                        State="{Binding WhenOff, Mode=TwoWay}"
                                        UnknownText="Leave-AsIs"/>

                                    <CheckBox
                                        Grid.Column="3"
                                        IsChecked="{Binding Cascade}"
                                        Margin="2,0,0,0"
                                        VerticalOptions="Center"/>

                                    <ImageButton
                                        Aspect="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:ButtonActionsGridViewModel}}, x:DataType=local:ButtonActionsGridViewModel, Path=RemoveRowCommand}"
                                        CommandParameter="{Binding .}"
                                        Grid.Column="4"
                                        HeightRequest="10"
                                        Margin="2,0,0,0"
                                        Source="minus_circle.png"
                                        VerticalOptions="Center"
                                        WidthRequest="10"/>


                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>