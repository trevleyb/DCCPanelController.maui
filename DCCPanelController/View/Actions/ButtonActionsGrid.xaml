<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="DCCPanelController.View.Actions.ButtonActionsGrid"
    x:DataType="local:ButtonActionsGridViewModel"
    x:Name="ButtonActionsGridView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:DCCPanelController.View.Components"
    xmlns:converter="clr-namespace:DCCPanelController.Helpers.Converters"
    xmlns:local="clr-namespace:DCCPanelController.View.Actions"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:toolkit="http://communitytoolkit.maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:ButtonActionEnumConverter x:Key="ButtonActionEnumConverter" />
        </ResourceDictionary>
    </ContentView.Resources>

    <ContentView.Content>
        <VerticalStackLayout>
            <Grid ColumnDefinitions="100,auto,auto">
                <Label
                    FontAttributes="Bold"
                    Grid.Column="0"
                    HeightRequest="25"
                    Text="Button Actions"
                    TextColor="{StaticResource Primary}" />
                <ImageButton
                    Aspect="Center"
                    Command="{Binding AddRowCommand}"
                    Grid.Column="1"
                    HeightRequest="25"
                    IsEnabled="{Binding IsAddButtonEnabled}"
                    Margin="0,-5,0,0"
                    Source="plus_circle.png"
                    WidthRequest="25">
                    <ImageButton.Behaviors>
                        <behaviors:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </ImageButton.Behaviors>
                </ImageButton>
                <Label
                    Grid.Column="2"
                    HeightRequest="25"
                    Style="{StaticResource SmallLabel}"
                    Text="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.NoDataText}"
                    VerticalOptions="Center" />

            </Grid>

            <Grid HeightRequest="{Binding ControlHeight, Mode=OneWay}" IsVisible="{Binding IsGridVisible}">
                <ListView
                    HorizontalOptions="Fill"
                    ItemsSource="{Binding ButtonActions}"
                    VerticalOptions="Fill"
                    WidthRequest="480">

                    <ListView.Header>
                        <Grid
                            ColumnDefinitions="3*,4*,4*,3*,1*"
                            ColumnSpacing="5"
                            RowDefinitions="25">
                            <BoxView Background="{StaticResource Primary}" Grid.Column="0" />
                            <BoxView Background="{StaticResource Primary}" Grid.Column="1" />
                            <BoxView Background="{StaticResource Primary}" Grid.Column="2" />
                            <BoxView Background="{StaticResource Primary}" Grid.Column="3" />
                            <BoxView Background="{StaticResource Primary}" Grid.Column="4" />

                            <Label
                                FontAttributes="Bold"
                                Grid.Column="0"
                                Margin="5"
                                Text="ID"
                                TextColor="{StaticResource White}" />

                            <components:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                State="Active" />

                            <components:ButtonStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsButtonContext}"
                                State="Inactive" />

                            <components:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                State="Closed" />

                            <components:TurnoutStateControl
                                CanToggleState="False"
                                Grid.Column="2"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsTurnoutContext}"
                                State="Thrown" />


                            <Label
                                FontAttributes="Bold"
                                Grid.Column="3"
                                HorizontalOptions="Center"
                                Margin="5"
                                Text="Cascade?"
                                TextColor="{StaticResource White}" />

                            <Image
                                Grid.Column="4"
                                Margin="5"
                                Source="trash.png">
                                <Image.Behaviors>
                                    <behaviors:IconTintColorBehavior TintColor="Red" />
                                </Image.Behaviors>
                            </Image>

                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:ButtonAction">
                            <ViewCell>
                                <Grid ColumnDefinitions="3*,4*,4*,3*,1*" ColumnSpacing="5">
                                    <Picker
                                        Focused="IDPicker_OnFocused"
                                        Grid.Column="0"
                                        ItemsSource="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.AvailableButtons}"
                                        Margin="5,0,0,0"
                                        SelectedItem="{Binding Id}"
                                        TextColor="Black"
                                        Unfocused="IDPicker_OnUnfocused"
                                        VerticalOptions="Center"
                                        x:Name="IDPicker" />

                                    <components:ButtonStateControl
                                        Button="{Binding WhenActiveOrClosed, Converter={StaticResource ButtonActionEnumConverter}}"
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="1"
                                        HorizontalOptions="Start"
                                        Margin="5,0,0,0"
                                        State="Active"
                                        UnknownText="Leave-AsIs" />

                                    <components:ButtonStateControl
                                        Button="{Binding WhenInactiveOrThrown, Converter={StaticResource ButtonActionEnumConverter}}"
                                        CanSetStateUnknown="True"
                                        CanToggleState="True"
                                        Grid.Column="2"
                                        HorizontalOptions="Start"
                                        Margin="5,0,0,0"
                                        State="Inactive"
                                        UnknownText="Leave-AsIs" />

                                    <!--  <Picker  -->
                                    <!--  Grid.Column="1"  -->
                                    <!--  Margin="5,0,0,0"  -->
                                    <!--  SelectedItem="{Binding WhenActiveOrClosed, Converter={StaticResource ButtonActionEnumConverter}}"  -->
                                    <!--  TextColor="Black"  -->
                                    <!--  VerticalOptions="Center">  -->
                                    <!--     <Picker.ItemsSource> -->
                                    <!--         <x:Array Type="{x:Type x:String}"> -->
                                    <!--             <x:String>Active</x:String> -->
                                    <!--             <x:String>Inactive</x:String> -->
                                    <!--             <x:String>Leave</x:String> -->
                                    <!--             <x:String>Toggle</x:String> -->
                                    <!--         </x:Array> -->
                                    <!--     </Picker.ItemsSource> -->
                                    <!-- </Picker> -->
                                    <!--    -->
                                    <!--  <Picker  -->
                                    <!--  Grid.Column="2"  -->
                                    <!--  Margin="5,0,0,0"  -->
                                    <!--  SelectedItem="{Binding WhenInactiveOrThrown, Converter={StaticResource ButtonActionEnumConverter}}"  -->
                                    <!--  TextColor="Black"  -->
                                    <!--  VerticalOptions="Center">  -->
                                    <!--     <Picker.ItemsSource> -->
                                    <!--         <x:Array Type="{x:Type x:String}"> -->
                                    <!--             <x:String>Active</x:String> -->
                                    <!--             <x:String>Inactive</x:String> -->
                                    <!--             <x:String>Leave</x:String> -->
                                    <!--             <x:String>Toggle</x:String> -->
                                    <!--         </x:Array> -->
                                    <!--     </Picker.ItemsSource> -->
                                    <!-- </Picker> -->

                                    <CheckBox
                                        Grid.Column="3"
                                        IsChecked="{Binding Cascade}"
                                        Margin="5,0,0,0"
                                        VerticalOptions="Center" />

                                    <ImageButton
                                        Aspect="Center"
                                        Command="{Binding Source={x:Reference ButtonActionsGridView}, x:DataType=local:ButtonActionsGrid, Path=BindingContext.RemoveRowCommand}"
                                        CommandParameter="{Binding .}"
                                        Grid.Column="4"
                                        HeightRequest="10"
                                        Margin="0,0,0,0"
                                        Source="minus_circle.png"
                                        VerticalOptions="Center"
                                        WidthRequest="10" />
                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>
