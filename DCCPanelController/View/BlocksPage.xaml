<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="route_active.png"
    Title="Blocks List"
    ios:Page.UseSafeArea="False"
    x:Name="Page"
    x:Class="DCCPanelController.View.BlocksPage"
    x:DataType="view:BlocksViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:dataModel="clr-namespace:DCCPanelController.Models.DataModel"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bottomSheet="http://schemas.syncfusion.com/maui/toolkit">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding AddBlockCommand}" IsEnabled="{Binding CanAddBlock}"
            IconImageSource="{Binding CanAddBlock, Converter={StaticResource BoolToIcon}, ConverterParameter=plus_circle}" />

        <ToolbarItem
            Command="{Binding DeleteBlockCommand}" IsEnabled="{Binding IsBlockSelected}"
            IconImageSource="{Binding IsBlockSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=minus_circle}" />

        <ToolbarItem Command="{Binding EditBlockCommand}" IsEnabled="{Binding IsBlockSelected}"
                     IconImageSource="{Binding IsBlockSelected, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}" />

        <ToolbarItem
            Command="{Binding RefreshBlocksCommand}" IsEnabled="{Binding IsConnected}"
            IconImageSource="{Binding IsConnected, Converter={StaticResource BoolToIcon}, ConverterParameter=refresh_cw}" />

        <ToolbarItem
            Command="{Binding ToggleConnectionCommand}"
            IsEnabled="{Binding IsConnectionAvailable}">
            <ToolbarItem.IconImageSource>
                <MultiBinding Converter="{StaticResource ConnectionIconConverter}">
                    <Binding Path="IsConnectionAvailable" />     <!-- Parameter 1: bool for _active/_inactive -->
                    <Binding Path="ConnectionState" />           <!-- Parameter 2: bool for name selection -->
                </MultiBinding>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <Style x:Key="SelectableItemStyle" TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="LightGrey" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>
    <Grid>
        <StackLayout x:Name="MainStackLayout">
            <Grid
                ColumnDefinitions="150,*,120,120"
                HorizontalOptions="Fill">
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelID}"
                    Grid.Column="0"
                    HorizontalOptions="CenterAndExpand"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelID}" />
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelName}"
                    Grid.Column="1"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelName}" />
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelSensor}"
                    Grid.Column="2"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelSensor}" />
                <Button
                    Command="{Binding SortByColumnCommand}"
                    CommandParameter="{Binding LabelState}"
                    Grid.Column="3"
                    Style="{StaticResource ColumnLabel}"
                    Text="{Binding ColumnLabelState}" />
            </Grid>
            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />
            <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshBlocksCommand}">

                <Grid VerticalOptions="FillAndExpand"
                      IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, x:DataType=view:BlocksViewModel, Path=IsConnected}">
                    <CollectionView ItemsSource="{Binding Blocks}" 
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedBlock}">
                        <CollectionView.EmptyView>
                            <Border WidthRequest="350" HeightRequest="100" StrokeShape="RoundRectangle 15" BackgroundColor="WhiteSmoke">
                                <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" >
                                    <Label IsVisible="{Binding IsSupported}" Text="No Occupancy Block data available." VerticalOptions="Center" HorizontalOptions="Center"/>
                                    <Label IsVisible="{Binding IsNotSupported}"
                                           Text="The current server type does not support Occupancy Blocks." VerticalOptions="Center" HorizontalOptions="Center"/>
                                </Grid>
                            </Border>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dataModel:Block">
                                <Grid Style="{StaticResource SelectableItemStyle}">
                                    <StackLayout Padding="0">
                                        <Grid ColumnDefinitions="150,*,120,80,40" Margin="0,5,0,5" Padding="0">
                                            <Label
                                                Grid.Column="0"
                                                HorizontalOptions="Start"
                                                LineBreakMode="NoWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Id}"
                                                Margin="10,0,0,0"
                                                VerticalOptions="Center" />
                                            <Label
                                                FontAttributes="Bold"
                                                Grid.Column="1"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Name}"
                                                VerticalOptions="Center" />
                                            <Label
                                                Grid.Column="2"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding Sensor}"
                                                VerticalOptions="Center" />
                                            <Label
                                                Grid.Column="3"
                                                HorizontalOptions="Start"
                                                Style="{StaticResource MediumLabel}"
                                                Text="{Binding State}"
                                                VerticalOptions="Center">
                                                <Label.Triggers>

                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, x:DataType=view:BlocksViewModel, Path=IsConnected}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1.00" />
                                                    </DataTrigger>

                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, x:DataType=view:BlocksViewModel, Path=IsConnected}"
                                                                 Value="False">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsOccupied}" TargetType="Label"
                                                                 Value="true">
                                                        <Setter Property="TextColor" Value="Red" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOccupied}" TargetType="Label"
                                                                 Value="false">
                                                        <Setter Property="TextColor" Value="Green" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, Path=ToggleBlockStateCommand}"
                                                        CommandParameter="{Binding .}"
                                                        x:DataType="{x:Type view:BlocksViewModel}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                            <Image
                                                Grid.Column="4"
                                                HeightRequest="32"
                                                HorizontalOptions="End"
                                                VerticalOptions="Center"
                                                WidthRequest="42">
                                                <Image.Triggers>
                                                    <DataTrigger TargetType="Image"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, x:DataType=view:BlocksViewModel, Path=IsConnected}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1.00" />
                                                    </DataTrigger>

                                                    <DataTrigger TargetType="Image"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, x:DataType=view:BlocksViewModel, Path=IsConnected}"
                                                                 Value="False">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                        Binding="{Binding IsOccupied}"
                                                        TargetType="Image"
                                                        Value="true">
                                                        <Setter Property="Source" Value="block_occupied.png" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                        Binding="{Binding IsOccupied}"
                                                        TargetType="Image"
                                                        Value="false">
                                                        <Setter Property="Source" Value="block_free.png" />
                                                    </DataTrigger>
                                                </Image.Triggers>
                                                <Image.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type view:BlocksViewModel}}, Path=ToggleBlockStateCommand}"
                                                        CommandParameter="{Binding .}"
                                                        x:DataType="{x:Type view:BlocksViewModel}" />
                                                </Image.GestureRecognizers>

                                            </Image>

                                        </Grid>
                                        <BoxView
                                            BackgroundColor="{StaticResource Primary}"
                                            HeightRequest="1"
                                            HorizontalOptions="FillAndExpand" />
                                    </StackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>

            <BoxView
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="1"
                HorizontalOptions="FillAndExpand" />

            <Grid HorizontalOptions="Center" VerticalOptions="End" Margin="10">
                <Label
                    Text="Blocks can be created and are linked to a Sensor. The state of the block is dependant on the state of the associated Sensor." />
            </Grid>


        </StackLayout>
        <!-- Bottom Sheet for editing the Connection Details -->
        <bottomSheet:SfBottomSheet
            x:Name="BottomSheet"

            CornerRadius="15, 15, 0, 0"
            HalfExpandedRatio="0.50"
            ContentPadding="10" />
    </Grid>
</ContentPage>