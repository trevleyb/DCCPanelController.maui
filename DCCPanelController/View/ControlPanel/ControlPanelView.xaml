<ContentView
    x:Name="ControlPanelViewRoot"
    x:Class="DCCPanelController.View.ControlPanel.ControlPanelView"
    x:DataType="controlPanel:ControlPanelView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controlPanel="clr-namespace:DCCPanelController.View.ControlPanel">

    <ContentView.Resources>
        <ResourceDictionary/>
    </ContentView.Resources>

    <Grid
        x:Name="MainGrid"
        HorizontalOptions="Fill"
        VerticalOptions="Fill">
        <AbsoluteLayout
            x:Name="ControlPanelLayout"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"/>

        <ActivityIndicator
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsRunning="{Binding Source={x:Reference ControlPanelViewRoot}, Path=IsPanelDrawing}"
            IsVisible="{Binding Source={x:Reference ControlPanelViewRoot}, Path=IsPanelDrawing}"
            Color="{StaticResource Primary}"/>
    </Grid>

</ContentView>