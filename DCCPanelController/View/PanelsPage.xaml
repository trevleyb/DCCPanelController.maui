<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    IconImageSource="panels_green.png"
    Title="Panels"
    x:Class="DCCPanelController.View.PanelsPage"
    x:DataType="viewModel:PanelsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:converters="clr-namespace:DCCPanelController.Helpers.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:PanelToCardHeightConverter x:Key="PanelToCardHeightConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding AddNewPanelCommand}" IconImageSource="add.png" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>

        <Grid x:Name="MainGrid"
              BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

            <CollectionView x:Name="PanelsCollectionView" ItemsSource="{Binding Panels}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                        <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                            <Label Text="No Panels were found. Please use + to add a new Panel." />
                        </StackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <GridItemsLayout x:Name="PanelsCollectionViewLayout" Orientation="Vertical" Span="2" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView x:Name="PanelCardSwipeView">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem IconImageSource="edit.png" Text="Edit"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelsViewModel}}, Path=EditPanelCommand}"
                                               CommandParameter="{Binding}"
                                               BackgroundColor="Green" />
                                    <SwipeItem IconImageSource="trash.png" Text="Delete"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelsViewModel}}, Path=DeletePanelCommand}"
                                               CommandParameter="{Binding}"
                                               BackgroundColor="Red" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <SwipeView.Content>
                                <Grid HorizontalOptions="Fill" Padding="10" x:Name="PanelCard">
                                    <Grid.HeightRequest>
                                        <MultiBinding Converter="{StaticResource PanelToCardHeightConverter}">
                                            <Binding Path="." />
                                            <Binding Source="{x:Reference PanelCard}" Path="Width" />
                                        </MultiBinding>
                                    </Grid.HeightRequest>
                                    
                                    <Border Style="{StaticResource CardView}" Grid.Row="0" >
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer
                                                DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelsViewModel}}, Path=DragCommand}"
                                                DragStartingCommandParameter="{Binding}" />
                                            <DropGestureRecognizer
                                                DropCommand="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelsViewModel}}, Path=DropCommand}"
                                                DropCommandParameter="{Binding}" />
                                            <TapGestureRecognizer Tapped="GoToSelectedPanelEditor" />
                                        </Border.GestureRecognizers>
                                        <StackLayout>
                                                <view:ControlPanelView Panel="{Binding .}"
                                                                       DesignMode="False"
                                                                       ShowGrid="False"
                                                                  HorizontalOptions="FillAndExpand"
                                                                  VerticalOptions="FillAndExpand"/>
                                            
                                                <BoxView
                                                    BackgroundColor="{StaticResource Primary}"
                                                    HeightRequest="2"/>

                                                <Label Style="{StaticResource PanelLabel}"
                                                       TextColor="{StaticResource Primary}"
                                                       FontSize="12"
                                                       VerticalOptions="End"
                                                       HorizontalOptions="Center"
                                                       VerticalTextAlignment="Center"
                                                       HorizontalTextAlignment="Center">
                                                    <MultiBinding StringFormat="{}{0}: {1}">
                                                        <Binding Path="Name" FallbackValue="Unknown Panel" />
                                                    </MultiBinding>
                                                </Label>
                                        </StackLayout>
                                    </Border>
                                </Grid>
                            </SwipeView.Content>
                        </SwipeView>
                            
