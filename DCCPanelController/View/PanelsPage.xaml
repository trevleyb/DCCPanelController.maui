<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    IconImageSource="panels_green.png"
    Title="Panels"
    x:Class="DCCPanelController.View.PanelsPage"
    x:DataType="viewModel:PanelsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:model="clr-namespace:DCCPanelController.Model"
    xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding AddNewPanelCommand}" Text="+" />
    </ContentPage.ToolbarItems>

    <Grid
        BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground},
                                          Dark={StaticResource DarkBackground}}"
        ColumnDefinitions="*,*"
        ColumnSpacing="5"
        RowDefinitions="*,Auto"
        RowSpacing="0">
        <RefreshView
            Command="{Binding GetPanelsCommand}"
            Grid.ColumnSpan="2"
            IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Panels}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                        <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                            <Label Text="No Panels were found. Please use + to add a new Panel." />
                        </StackLayout>
                    </Grid>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Panel">
                        <Grid HorizontalOptions="Fill" Padding="10">
                            <Frame HeightRequest="275" Style="{StaticResource CardView}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:PanelsViewModel}}, Path=GoToDetailsCommand}" CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid RowDefinitions="auto,*" ColumnDefinitions="*,2*" Padding="0">
                                    <StackLayout Grid.Column="0" Padding="10" VerticalOptions="Center">
                                        <Label Style="{StaticResource MediumLabel}" TextColor="{StaticResource Primary}">
                                            <MultiBinding StringFormat="{}{0}: {1}">
                                                <Binding Path="Id" />
                                                <Binding Path="Name" />
                                            </MultiBinding>
                                        </Label>
                                    </StackLayout>

                                    <Image Grid.ColumnSpan="2"
                                           Grid.Row="1"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Aspect="AspectFit"
                                           Source="{Binding Image}" />
                                </Grid>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button
            Command="{Binding GetPanelsCommand}"
            Grid.Column="0"
            Grid.Row="1"
            IsEnabled="{Binding IsNotBusy}"
            Margin="8"
            Style="{StaticResource ButtonOutline}"
            Text="Load Panels" />

        <ActivityIndicator
            Color="{StaticResource Primary}"
            Grid.ColumnSpan="2"
            Grid.RowSpan="2"
            HorizontalOptions="Fill"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />
    </Grid>
</ContentPage>