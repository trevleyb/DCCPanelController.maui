<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:DCCPanelController.ViewModel"
             x:DataType="viewModel:ControlPanelViewModel"
             x:Class="DCCPanelController.View.ControlPanelPage">
    
    <ContentPage.BindingContext>
        <viewModel:ControlPanelViewModel />
    </ContentPage.BindingContext>
    
    <ContentPage.Content>
        <ScrollView>
            <StackLayout>
            <Label Text="Show Grid"/>
            <CheckBox IsChecked="{Binding ShowGrid}"/>
            <Grid x:Name="ControlPanelLayout"
                  HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type IView}}, Path=Height}" 
                  WidthRequest ="{Binding Source={RelativeSource AncestorType={x:Type IView}}, Path=Width}" 
                  HorizontalOptions="Center"  
                  VerticalOptions="Center" >
            
                <Grid x:Name="ControlPanelGrid" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Grid>
            </StackLayout>
        
        </ScrollView>
    </ContentPage.Content>
</ContentPage>