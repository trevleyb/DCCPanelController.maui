<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:DCCPanelController.View"
             xmlns:tileSelectors="clr-namespace:DCCPanelController.View.TileSelectors"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:controlPanel="clr-namespace:DCCPanelController.View.ControlPanel"
             xmlns:services="clr-namespace:DCCPanelController.Services"
             xmlns:components="clr-namespace:DCCPanelController.View.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             ios:Page.UseSafeArea="false"
             x:DataType="view:PanelEditorViewModel"
             Title="{Binding Panel.Title}"
             x:Class="DCCPanelController.View.PanelEditor">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="{Binding CanPressBackButton}"
                            IsVisible="{Binding CanPressBackButton}"
                            x:DataType="view:PanelEditorViewModel"
                            Command="{Binding BackButtonPressedCommand}"/>
    </Shell.BackButtonBehavior>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="{Binding CanSetModes, Converter={StaticResource BoolToIcon}, ConverterParameter=move}"
            Text="Mode" x:Name="ModeToolbar"
            IsEnabled="{Binding CanSetModes}"
            Command="{Binding Path=SwitchModeCommand}">
            
        </ToolbarItem>

        <ToolbarItem
            IconImageSource="{Binding CanEditProperties, Converter={StaticResource BoolToIcon}, ConverterParameter=settings}"
            Text="Edit" x:Name="EditToolbar"
            Command="{Binding Path=EditPanelPropertiesPopupCommand}"
            IsEnabled="{Binding CanEditProperties}"/>

        <ToolbarItem
            IconImageSource="{Binding CanToggleGrid, Converter={StaticResource BoolToIcon}, ConverterParameter=grid_off}"
            Text="Grid" x:Name="GridToolbar"
            IsEnabled="{Binding CanToggleGrid}"
            Command="{Binding Path=ToggleGridCommand}"/>

        <ToolbarItem
            IsEnabled="{Binding CanToggleGrid}"
            IconImageSource="{Binding PaletteState, Converter={StaticResource PaletteIconConverter}}"
            Text="Palette"
            Clicked="PaletteClicked"/> 

        <ToolbarItem
            IconImageSource="{Binding CanPressBackButton, Converter={StaticResource BoolToIcon}, ConverterParameter=save}"
            Text="Save" x:Name="SaveToolbar"
            IsEnabled="{Binding CanPressBackButton}"
            Command="{Binding Path=SaveButtonPressedCommand}"/>
    </ContentPage.ToolbarItems>

    <toolkit:DockLayout x:Name="Dock">
        <Grid toolkit:DockLayout.DockPosition="Top"
              x:Name="TileToolbar"
              x:DataType="services:AppStateService"
              HeightRequest="35"
              VerticalOptions="Fill" HorizontalOptions="Fill" Margin="0"
              BackgroundColor="{Binding Source={x:Static services:AppStateService.Instance}, Path=ShellBackgroundColor}">

            <ScrollView HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never" Orientation="Horizontal" HorizontalOptions="Fill" HeightRequest="35"  >
                <HorizontalStackLayout HorizontalOptions="End" x:DataType="view:PanelEditorViewModel" Padding="5">
                    <Border IsVisible="{Binding ShowEditTextBox}" Padding="5,2,5,2" StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="White" >
                        <HorizontalStackLayout Spacing="1" Padding="0" >
                            <Entry TextColor="White" Text="{Binding TextEntity.EditText, Mode=TwoWay}" HorizontalOptions="Start" WidthRequest="100"/>
                            <ImageButton HorizontalOptions="End" Margin="5,0,0,0" MinimumWidthRequest="15" WidthRequest="15" Source="plus_active.png" Command="{Binding Path=IncreaseTextSizeCommand}">
                                <ImageButton.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="White"/>
                                </ImageButton.Behaviors>
                            </ImageButton>
                            <ImageButton HorizontalOptions="End" Margin="5,0,5,0" MinimumWidthRequest="15" WidthRequest="15" Source="minus_active.png" Command="{Binding Path=DecreaseTextSizeCommand}">
                                <ImageButton.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="White"/>
                                </ImageButton.Behaviors>
                            </ImageButton>
                            <Label HorizontalOptions="End" TextColor="White" Margin="0,0,5,0" Text="{Binding TextEntity.TextSize}"/>
                        </HorizontalStackLayout>
                    </Border>
                        
                    <ImageButton IsVisible="{Binding CanLinkATiles}" Command="{Binding Path=LinkTilesActionClosedCommand}" Source="{Binding CanLinkATiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link_closed}"/>
                    <ImageButton IsVisible="{Binding CanLinkATiles}" Command="{Binding Path=LinkTilesActionDivergingCommand}" Source="{Binding CanLinkATiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link_diverging}"/>
                    <ImageButton IsVisible="{Binding CanLinkTiles}"  Command="{Binding Path=LinkTilesClosedCommand}" Source="{Binding CanLinkTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link_closed}"/>
                    <ImageButton IsVisible="{Binding CanLinkTiles}"  Command="{Binding Path=LinkTilesDivergingCommand}" Source="{Binding CanLinkTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link_diverging}"/>
                    <ImageButton IsEnabled="{Binding CanRotateTiles}" Command="{Binding Path=RotateTileLeftCommand}" Source="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_ccw}"/>
                    <ImageButton IsEnabled="{Binding CanRotateTiles}" Command="{Binding Path=RotateTileRightCommand}" Source="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_cw}"/>
                    <ImageButton IsEnabled="{Binding CanChangeLayers}" Command="{Binding Path=ChangeLayersCommand}" Source="{Binding CanChangeLayers, Converter={StaticResource BoolToIcon}, ConverterParameter=layers}"/>
                    <ImageButton IsEnabled="{Binding CanDeleteTiles}" Source="{Binding CanDeleteTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=trash_2}" Command="{Binding Path=DeleteTileCommand}"/>
                    <ImageButton IsEnabled="{Binding CanEditTileProperties}" Source="{Binding CanEditTileProperties, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}" Command="{Binding Path=EditTilePropertiesPopupCommand}"/>
                    
                </HorizontalStackLayout>
            </ScrollView>
            </Grid>

        <Grid toolkit:DockLayout.DockPosition="Bottom" x:Name="StatusContainer" HeightRequest="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>  
                <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            <BoxView Grid.Row="0" HeightRequest="0.5" BackgroundColor="{StaticResource Primary}" HorizontalOptions="Fill"/>

            <Grid Grid.Row="1" Margin="10,0,10,0">
                <Grid ColumnDefinitions="auto,*,auto" HorizontalOptions="Fill" VerticalOptions="Center">
                    <Label Grid.Column="0" HorizontalOptions="Start" FontSize="15" FontFamily="OpenSansLight" x:Name="SelectionText" TextColor="{StaticResource Primary}"/>
                    <Label Grid.Column="2" HorizontalOptions="End" FontSize="15" FontFamily="OpenSansLight" x:Name="ChangesText" TextColor="{StaticResource Primary}"/>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="SidePaletteContainer" toolkit:DockLayout.DockPosition="Right" WidthRequest="110" IsVisible="True">
            <tileSelectors:PaletteSelector x:Name="SidePaletteSelector" Orientation="Vertical" Palette="{Binding SidePalette}" OnClosePalette="SidePaletteClosed" />
        </Grid>
                
        <Grid x:Name="BottomPaletteContainer" toolkit:DockLayout.DockPosition="Bottom" HeightRequest="125" IsVisible="False">
            <tileSelectors:PaletteSelector x:Name="BottomPaletteSelector" Orientation="Horizontal" Palette="{Binding BottomPalette}" OnClosePalette="BottomPaletteClosed"/>
        </Grid>

        <Grid toolkit:DockLayout.DockPosition="None"
              x:Name="PanelEditorContainer" 
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <controlPanel:ControlPanelView
                Margin="5"
                BackgroundColor="Transparent"
                DesignMode="true"
                Interactive="False"
                EditMode="{Binding Source={RelativeSource AncestorType={x:Type view:PanelEditorViewModel}}, Path=EditMode, Mode=OneWay}"
                Grid.Column="0"
                HorizontalOptions="Fill"
                Panel="{Binding Source={RelativeSource AncestorType={x:Type view:PanelEditorViewModel}}, Path=Panel, Mode=OneWay}"
                VerticalOptions="Fill"
                x:Name="PanelView"/>
        </Grid>

    </toolkit:DockLayout>
    
</ContentPage>    
   