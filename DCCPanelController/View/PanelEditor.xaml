<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:DCCPanelController.View"
             xmlns:tileSelectors="clr-namespace:DCCPanelController.View.TileSelectors"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:controlPanel="clr-namespace:DCCPanelController.View.ControlPanel"
             xmlns:services="clr-namespace:DCCPanelController.Services"
             xmlns:components="clr-namespace:DCCPanelController.View.Components"
             ios:Page.UseSafeArea="false"
             x:DataType="view:PanelEditorViewModel"
             Title="{Binding Panel.Title}"
             x:Class="DCCPanelController.View.PanelEditor">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="{Binding CanPressBackButton}"
                            x:DataType="view:PanelEditorViewModel"
                            Command="{Binding BackButtonPressedCommand}"/>
    </Shell.BackButtonBehavior>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="{Binding CanSetModes, Converter={StaticResource BoolToIcon}, ConverterParameter=move}"
            Text="Mode" x:Name="ModeToolbar"
            IsEnabled="{Binding CanSetModes}"
            Command="{Binding Path=SwitchModeCommand}">
            
        </ToolbarItem>

        <ToolbarItem
            IconImageSource="{Binding CanEditProperties, Converter={StaticResource BoolToIcon}, ConverterParameter=settings}"
            Text="Edit" x:Name="EditToolbar"
            Command="{Binding Path=EditPanelPropertiesPopupCommand}"
            IsEnabled="{Binding CanEditProperties}"/>

        <ToolbarItem
            IconImageSource="{Binding CanToggleGrid, Converter={StaticResource BoolToIcon}, ConverterParameter=grid_off}"
            Text="Grid" x:Name="GridToolbar"
            IsEnabled="{Binding CanToggleGrid}"
            Command="{Binding Path=ToggleGridCommand}"/>

        <ToolbarItem
            IconImageSource="{Binding CanPressBackButton, Converter={StaticResource BoolToIcon}, ConverterParameter=save}"
            Text="Save" x:Name="SaveToolbar"
            IsEnabled="{Binding CanPressBackButton}"
            Command="{Binding Path=SaveButtonPressedCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- <ContentPage.Content> -->
        <Grid x:Name="MainGrid" BackgroundColor="WhiteSmoke" HorizontalOptions="Fill" VerticalOptions="Fill">

            <!-- Initially: 1 column, 3 rows (standard layout) -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" x:Name="MainColumn"/>
                <ColumnDefinition Width="Auto" x:Name="SidePalette"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" x:Name="ToolbarRow"/>
                <RowDefinition Height="*" x:Name="PanelRow"/>
                <RowDefinition Height="Auto" x:Name="BottomPalette"/>
                <RowDefinition Height="30" x:Name="StatusRow"/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" x:DataType="services:AppStateService"
                  VerticalOptions="Fill" HorizontalOptions="Fill" Margin="0"
                  BackgroundColor="{Binding Source={x:Static services:AppStateService.Instance}, Path=ShellBackgroundColor}">
                
                <HorizontalStackLayout HorizontalOptions="End" x:DataType="view:PanelEditorViewModel" Margin="0,0,5,0" Spacing="10" Padding="5">
                    <ImageButton
                        IsEnabled="{Binding CanLinkTiles}"
                        Command="{Binding Path=LinkTilesCommand}"
                        Source="{Binding CanLinkTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link}"/>

                    <ImageButton
                        IsEnabled="{Binding CanRotateTiles}"
                        Command="{Binding Path=RotateTileLeftCommand}"
                        Source="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_ccw}"/>
                
                    <ImageButton
                        IsEnabled="{Binding CanRotateTiles}"
                        Command="{Binding Path=RotateTileRightCommand}"
                        Source="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_cw}"/>
                
                    <ImageButton
                        IsEnabled="{Binding CanChangeLayers}"
                        Command="{Binding Path=ChangeLayersCommand}"
                        Source="{Binding CanChangeLayers, Converter={StaticResource BoolToIcon}, ConverterParameter=layers}"/>
                
                    <ImageButton
                        Source="{Binding CanDeleteTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=trash_2}"
                        IsEnabled="{Binding CanDeleteTiles}"
                        Command="{Binding Path=DeleteTileCommand}"/>
                
                    <ImageButton
                        Source="{Binding CanEditTileProperties, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}"
                        Command="{Binding Path=EditTilePropertiesPopupCommand}"
                        IsEnabled="{Binding CanEditTileProperties}"/>
                        
                    
                </HorizontalStackLayout>
                
                <!-- <components:InlineToolbar HorizontalOptions="End" x:DataType="view:PanelEditorViewModel" Margin="5,5,10,5" Spacing="30" Padding="10" IconSize="24" BackgroundColor="Aqua"> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         Text="Link" x:Name="LinkToolbar" -->
                <!--         IsEnabled="{Binding CanLinkTiles}" -->
                <!--         Command="{Binding Path=LinkTilesCommand}" -->
                <!--         IconImageSource="{Binding CanLinkTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=link}"/> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         Text="Rotate" x:Name="RotateToolbarLeft" -->
                <!--         IsEnabled="{Binding CanRotateTiles}" -->
                <!--         Command="{Binding Path=RotateTileLeftCommand}" -->
                <!--         IconImageSource="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_ccw}"/> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         Text="Rotate" x:Name="RotateToolbarRight" -->
                <!--         IsEnabled="{Binding CanRotateTiles}" -->
                <!--         Command="{Binding Path=RotateTileRightCommand}" -->
                <!--         IconImageSource="{Binding CanRotateTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=rotate_cw}"/> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         Text="Layers" x:Name="LayersToolbar" -->
                <!--         IsEnabled="{Binding CanChangeLayers}" -->
                <!--         Command="{Binding Path=ChangeLayersCommand}" -->
                <!--         IconImageSource="{Binding CanChangeLayers, Converter={StaticResource BoolToIcon}, ConverterParameter=layers}"/> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         IconImageSource="{Binding CanDeleteTiles, Converter={StaticResource BoolToIcon}, ConverterParameter=trash_2}" -->
                <!--         Text="Delete" x:Name="DeleteToolbar" -->
                <!--         IsEnabled="{Binding CanDeleteTiles}" -->
                <!--         Command="{Binding Path=DeleteTileCommand}"/> -->
                <!-- -->
                <!--     <components:InlineToolbarItem -->
                <!--         IconImageSource="{Binding CanEditTileProperties, Converter={StaticResource BoolToIcon}, ConverterParameter=edit}" -->
                <!--         Text="Edit" x:Name="EditTileToolbar" -->
                <!--         Command="{Binding Path=EditTilePropertiesPopupCommand}" -->
                <!--         IsEnabled="{Binding CanEditTileProperties}"/> -->
                <!-- -->
                <!-- </components:InlineToolbar> -->
                
            </Grid>
            
                <!-- Row 0: Panel Editor -->
            <Grid x:Name="PanelEditorContainer" Grid.Row="1" Grid.Column="0" HorizontalOptions="Fill"
                  VerticalOptions="Fill">
                <controlPanel:ControlPanelView
                    Margin="5"
                    BackgroundColor="Transparent"
                    DesignMode="true"
                    Interactive="False"
                    EditMode="{Binding Source={RelativeSource AncestorType={x:Type view:PanelEditorViewModel}}, Path=EditMode, Mode=OneWay}"
                    Grid.Column="0"
                    HorizontalOptions="Fill"
                    Panel="{Binding Source={RelativeSource AncestorType={x:Type view:PanelEditorViewModel}}, Path=Panel, Mode=OneWay}"
                    VerticalOptions="Fill"
                    x:Name="PanelView"/>
            </Grid>

            <Grid x:Name="SidePaletteContainer" Grid.Column="1" Grid.Row="1" RowSpan="2"  IsClippedToBounds="True">
                <tileSelectors:SideSelectorPanel
                    x:Name="SidePaletteSelector"
                    HorizontalOptions="Center"
                    OnDockSideChanged="PaletteDockSideChanged"/>
            </Grid>

            <Grid x:Name="BottomPaletteContainer" Grid.Column="0" Grid.Row="2" IsClippedToBounds="True">
                <tileSelectors:PillSelectorPanel
                    x:Name="PillPaletteSelector"
                    HorizontalOptions="Center"
                    OnDockSideChanged="PaletteDockSideChanged"/>
            </Grid>

            <Grid x:Name="StatusContainer" Grid.Column="0" Grid.Row="3" Margin="2" ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1"/>   <!-- Top border -->
                    <RowDefinition Height="*"/>   <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Top Border -->
                <BoxView Grid.Row="0" HeightRequest="0.5"
                         BackgroundColor="{StaticResource Primary}"
                         HorizontalOptions="Fill"/>

                <!-- Content -->
                <Grid Grid.Row="1">
                    <Grid ColumnDefinitions="auto,*,auto" HorizontalOptions="Fill" VerticalOptions="Fill">
                        <Label Grid.Column="0" HorizontalOptions="Start" FontSize="15" FontFamily="OpenSansLight"
                               x:Name="SelectionText" TextColor="{StaticResource Primary}"/>
                        <Label Grid.Column="2" HorizontalOptions="End" FontSize="15" FontFamily="OpenSansLight"
                               x:Name="ChangesText" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Loading Overlay -->
            <Grid IsVisible="{Binding IsProcessing}"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">

                <ActivityIndicator WidthRequest="100" HeightRequest="100" IsRunning="{Binding IsProcessing}" Color="{StaticResource Primary}"/>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>