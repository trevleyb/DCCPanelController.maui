<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="DCCPanelController.View.TileSelector"
    x:DataType="view:TileSelectorViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentView.GestureRecognizers>
        <DragGestureRecognizer DragStarting="DragGestureRecognizer_OnDragStarting" />
        <DropGestureRecognizer DragOver="DropGestureRecognizer_OnDragOver" />
        <DropGestureRecognizer Drop="DropGestureRecognizer_OnDrop" />
    </ContentView.GestureRecognizers>

    <AbsoluteLayout>
        <Grid
            AbsoluteLayout.LayoutBounds="{Binding LayoutBounds}"
            AbsoluteLayout.LayoutFlags="All"
            HeightRequest="58"
            Margin="100,0,100,0">
            <Border
                BackgroundColor="WhiteSmoke"
                Padding="5"
                Stroke="{StaticResource Gray500}"
                StrokeShape="RoundRectangle 10,10,10,10"
                StrokeThickness="2">
                <Border.Shadow>
                    <Shadow
                        Brush="{StaticResource Gray500}"
                        Offset="5,5"
                        Opacity="0.7" />
                </Border.Shadow>
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout>
                        <Grid WidthRequest="25">
                            <Border
                                BackgroundColor="Gainsboro"
                                HeightRequest="12"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Black}"
                                VerticalOptions="Center"
                                WidthRequest="12" />
                        </Grid>
                        <CollectionView
                            ItemSizingStrategy="MeasureAllItems"
                            ItemsSource="{Binding Tiles}"
                            SelectionMode="None">

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout
                                    HorizontalItemSpacing="2"
                                    Orientation="Horizontal"
                                    SnapPointsType="MandatorySingle"
                                    Span="1" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="view:TileSelectorViewModel">
                                    <ContentView HeightRequest="{Binding GridSize}" WidthRequest="{Binding GridSize}">
                                        <Border
                                            BackgroundColor="White"
                                            HeightRequest="{Binding GridSize}"
                                            HorizontalOptions="Fill"
                                            Padding="5"
                                            Stroke="{StaticResource Gray500}"
                                            StrokeShape="RoundRectangle 10,10,10,10"
                                            StrokeThickness="1"
                                            VerticalOptions="Fill"
                                            WidthRequest="{Binding GridSize}">
                                            <ContentView
                                                Content="{Binding .}"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill"
                                                x:DataType="View">
                                                <ContentView.GestureRecognizers>
                                                    <DragGestureRecognizer DragStarting="SymbolDragStarting" />
                                                </ContentView.GestureRecognizers>
                                            </ContentView>
                                        </Border>
                                    </ContentView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </HorizontalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </AbsoluteLayout>
</ContentView>