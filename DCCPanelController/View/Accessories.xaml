<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    Title="Accessories"
    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
    x:Class="DCCPanelController.View.AccessoriesPage"
    x:DataType="view:AccessoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:view="clr-namespace:DCCPanelController.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="10">

            <!-- Header Section -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="Accessories Manager"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{StaticResource Primary}"/>

                <Label
                    Text="Manage and configure your DCC system accessories"
                    FontSize="16"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                    Margin="0,0,0,20"/>
            </VerticalStackLayout>
            <!-- Info Section -->
            <Border
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#4B5563}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#F0F9FF, Dark=#1E3A5F}"
                Padding="15"
                Margin="0,10,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="ℹ️ Getting Started"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"/>
                    <Label
                        Text="Tap any card above to navigate to that accessory editor. Most accessories are synchronized with your DCC System, so ensure you're connected before making changes."
                        FontSize="14"
                        LineBreakMode="WordWrap"
                        TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Turnouts Card -->
            <Border
                StrokeShape="RoundRectangle 15"
                Stroke="{StaticResource Primary}"
                StrokeThickness="2"
                BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2A2A2A}"
                Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTurnoutsClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20" ColumnSpacing="15">
                    <Image
                        Grid.Column="0"
                        Source="turnout_closed.png"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <Label
                            Text="Turnouts"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"/>
                        <Label
                            Text="Create, edit, and view turnouts defined in your DCC System. Control turnout states and manage their addresses."
                            FontSize="14"
                            LineBreakMode="WordWrap"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="2"
                        Text="›"
                        FontSize="32"
                        VerticalOptions="Center"
                        TextColor="{StaticResource Primary}"/>
                </Grid>
            </Border>

            <!-- Routes Card -->
            <Border
                StrokeShape="RoundRectangle 15"
                Stroke="{StaticResource Primary}"
                StrokeThickness="2"
                BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2A2A2A}"
                Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRoutesClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20" ColumnSpacing="15">
                    <Image
                        Grid.Column="0"
                        Source="route_active.png"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <Label
                            Text="Routes"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"/>
                        <Label
                            Text="Define and manage routes that control multiple turnouts with a single command. Simplify complex track configurations."
                            FontSize="14"
                            LineBreakMode="WordWrap"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="2"
                        Text="›"
                        FontSize="32"
                        VerticalOptions="Center"
                        TextColor="{StaticResource Primary}"/>
                </Grid>
            </Border>

            <!-- Blocks Card -->
            <Border
                StrokeShape="RoundRectangle 15"
                Stroke="{StaticResource Primary}"
                StrokeThickness="2"
                BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2A2A2A}"
                Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBlocksClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20" ColumnSpacing="15">
                    <Image
                        Grid.Column="0"
                        Source="block_free.png"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <Label
                            Text="Blocks"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"/>
                        <Label
                            Text="Manage track blocks and occupancy detection. Monitor which sections of your layout are occupied by trains."
                            FontSize="14"
                            LineBreakMode="WordWrap"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="2"
                        Text="›"
                        FontSize="32"
                        VerticalOptions="Center"
                        TextColor="{StaticResource Primary}"/>
                </Grid>
            </Border>

            <!-- Lights Card -->
            <Border
                StrokeShape="RoundRectangle 15"
                Stroke="{StaticResource Primary}"
                StrokeThickness="2"
                BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2A2A2A}"
                Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLightsClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20" ColumnSpacing="15">
                    <Image
                        Grid.Column="0"
                        Source="light_active.png"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <Label
                            Text="Lights"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"/>
                        <Label
                            Text="Control lighting accessories including signals, building lights, and other illuminated elements on your layout."
                            FontSize="14"
                            LineBreakMode="WordWrap"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="2"
                        Text="›"
                        FontSize="32"
                        VerticalOptions="Center"
                        TextColor="{StaticResource Primary}"/>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>