<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:DCCPanelController.View"
             x:DataType="view:PanelSurfaceEditorViewModel"
             x:Class="DCCPanelController.View.PanelSurfaceEditor">
    <ContentPage.Content>
        <view:PanelSurfaceView
            Margin="5"
            BackgroundColor="Transparent"
            EditTool="Move"
            ShowGrid="True"
            GridColor="Bisque"
            GridThickness="2"
            InteractionMode="Edit"
             TileChanged="PanelView_OnTileChanged"
            TileSelected="PanelView_OnTileSelected"
            TileTapped="PanelView_OnTileTapped"
            HorizontalOptions="Fill"
            Panel="{Binding SelectedPanel, Mode=OneWay}"
            VerticalOptions="Fill"
            x:Name="PanelView"/>

    </ContentPage.Content>
</ContentPage>